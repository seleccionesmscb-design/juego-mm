function guardarHerr() {
  const nombre = document.getElementById('f-nombre').value.trim();
  const contenido = document.getElementById('f-contenido').value.trim();
  if (!nombre)    return toast('El nombre es obligatorio', true);
  if (!contenido) return toast('El contenido es obligatorio', true);
  const pqs = obtenerDatosPreguntas();
  if (!pqs[0] || !pqs[0].pregunta) return toast('La primera pregunta es obligatoria', true);
  if (!pqs[0].respuesta) return toast('La respuesta de la primera pregunta es obligatoria', true);
  const d = {
    _fila:        parseInt(document.getElementById('f-fila').value)||0,
    nombre:       nombre,
    era:          document.getElementById('f-era').value,
    nivel:        document.getElementById('f-nivel').value,
    area:         document.getElementById('f-area').value.trim(),
    puntaje:      parseInt(document.getElementById('f-puntaje').value)||5,
    competencia:  document.getElementById('f-competencia').value,
    contenido:    contenido,
    videoUrl:     document.getElementById('f-video').value.trim(),
    infografiaUrl:document.getElementById('f-infografia').value.trim(),
    insigniaID:   document.getElementById('f-insignia').value.trim(),
    pregunta:     pqs[0] ? pqs[0].pregunta : '',
    respuesta:    pqs[0] ? pqs[0].respuesta : '',
    opcionA:      pqs[0] ? pqs[0].opcionA : '',
    opcionB:      pqs[0] ? pqs[0].opcionB : '',
    opcionC:      pqs[0] ? pqs[0].opcionC : '',
    opcionD:      pqs[0] ? pqs[0].opcionD : '',
    pregunta2:    pqs[1] ? pqs[1].pregunta : '',
    respuesta2:   pqs[1] ? pqs[1].respuesta : '',
    opcionA2:     pqs[1] ? pqs[1].opcionA : '',
    opcionB2:     pqs[1] ? pqs[1].opcionB : '',
    opcionC2:     pqs[1] ? pqs[1].opcionC : '',
    opcionD2:     pqs[1] ? pqs[1].opcionD : '',
    pregunta3:    pqs[2] ? pqs[2].pregunta : '',
    respuesta3:   pqs[2] ? pqs[2].respuesta : '',
    opcionA3:     pqs[2] ? pqs[2].opcionA : '',
    opcionB3:     pqs[2] ? pqs[2].opcionB : '',
    opcionC3:     pqs[2] ? pqs[2].opcionC : '',
    opcionD3:     pqs[2] ? pqs[2].opcionD : ''
  };
  google.script.run
    .withSuccessHandler(function(){ toast('Herramienta guardada ✓'); ocultarForms(); recargar(); })
    .withFailureHandler(function(e){ toast('Error: '+e.message, true); })
    .guardarHerramienta(d);
}

