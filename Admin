<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Misión Muni · Admin</title>
<style>
:root {
  --navy:    #0f1b2d;
  --navy2:   #162035;
  --gold:    #e6bd85;
  --gold-br: #b8860b;
  --green:   #2e7d50;
  --red:     #8b2020;
  --blue:    #1a4a7a;
  --border:  rgba(230,189,133,.18);
  --card:    rgba(255,255,255,.04);
  --text:    #ddd;
  --sub:     #999;
  font-family: system-ui,-apple-system,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--navy);color:var(--text);min-height:100vh;}

/* LOGIN */
#login-wrap{display:flex;align-items:center;justify-content:center;min-height:100vh;}
.login-box{background:var(--navy2);border:1px solid var(--border);border-radius:16px;padding:40px 36px;width:360px;text-align:center;}
.login-logo{font-size:40px;margin-bottom:8px;}
.login-title{font-size:20px;font-weight:700;color:var(--gold);margin-bottom:4px;}
.login-sub{font-size:13px;color:var(--sub);margin-bottom:28px;}
.inp{width:100%;background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:8px;padding:12px 14px;color:#fff;font-size:15px;margin-bottom:12px;outline:none;}
.inp:focus{border-color:var(--gold-br);}
.btn{padding:13px;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;transition:.15s;width:100%;}
.btn-gold{background:var(--gold-br);color:#fff;}
.btn-gold:hover{background:#9a700a;}
.btn-ghost{background:transparent;border:1px solid var(--border);color:var(--text);}
.btn-ghost:hover{background:var(--card);}
.err-msg{color:#e57373;font-size:13px;margin-top:8px;display:none;}

/* APP */
#app{display:none;}
.topbar{background:var(--navy2);border-bottom:1px solid var(--border);padding:14px 24px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
.topbar-title{font-size:15px;font-weight:700;color:var(--gold);flex:1;min-width:200px;}
.topbar-btn{background:transparent;border:1px solid var(--border);color:var(--gold);border-radius:8px;padding:7px 14px;font-size:13px;cursor:pointer;white-space:nowrap;}
.topbar-btn:hover{background:var(--card);}
.topbar-btn.new{background:var(--green);border-color:var(--green);color:#fff;}
.topbar-btn.new:hover{background:#256642;}

/* TABS */
.tabs{display:flex;gap:0;border-bottom:1px solid var(--border);padding:0 24px;background:var(--navy2);}
.tab-btn{padding:12px 20px;background:transparent;border:none;border-bottom:2px solid transparent;color:var(--sub);font-size:14px;font-weight:600;cursor:pointer;transition:.15s;}
.tab-btn.active{color:var(--gold);border-bottom-color:var(--gold-br);}
.tab-btn:hover:not(.active){color:var(--text);}

.content{max-width:1100px;margin:0 auto;padding:24px 20px 60px;}

/* CARDS LIST */
.mod-grid{display:grid;gap:10px;}
.mod-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:14px 18px;display:flex;align-items:center;gap:14px;transition:.12s;}
.mod-card:hover{border-color:rgba(230,189,133,.35);}
.mod-icon{font-size:26px;min-width:38px;text-align:center;}
.mod-info{flex:1;min-width:0;}
.mod-name{font-size:14px;font-weight:600;color:#eee;margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.mod-meta{font-size:12px;color:var(--sub);}
.mod-badges{display:flex;gap:6px;flex-wrap:wrap;align-items:center;}
.mod-badge{font-size:11px;background:rgba(184,134,11,.2);color:var(--gold);border-radius:20px;padding:3px 10px;white-space:nowrap;}
.mod-badge.blue{background:rgba(26,74,122,.4);color:#7ab3e8;}
.mod-badge.green{background:rgba(46,125,80,.25);color:#7ec89a;}
.mod-badge.era1{background:rgba(26,74,122,.35);color:#7ab3e8;}
.mod-badge.era2{background:rgba(42,82,11,.35);color:#a8c06e;}
.mod-badge.era3{background:rgba(100,30,60,.35);color:#c89ab4;}
.mod-actions{display:flex;gap:8px;flex-shrink:0;}
.act-btn{border:1px solid var(--border);border-radius:8px;padding:6px 12px;font-size:12px;cursor:pointer;background:transparent;transition:.12s;white-space:nowrap;}
.act-edit{color:var(--gold);}
.act-edit:hover{background:rgba(184,134,11,.15);}
.act-del{color:#e57373;border-color:rgba(229,115,115,.3);}
.act-del:hover{background:rgba(229,115,115,.12);}

.empty-state{text-align:center;padding:60px 20px;color:var(--sub);font-size:15px;}
.spin{display:none;border:3px solid rgba(255,255,255,.1);border-top-color:var(--gold);border-radius:50%;width:36px;height:36px;animation:spin .7s linear infinite;margin:60px auto;}
@keyframes spin{to{transform:rotate(360deg);}}

/* FORM */
#form-panel{display:none;}
.form-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:24px 24px 32px;}
.form-title{font-size:17px;font-weight:700;color:var(--gold);margin-bottom:20px;}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.form-group{display:flex;flex-direction:column;gap:5px;}
.form-group.full{grid-column:1/-1;}
.form-lbl{font-size:11px;font-weight:600;color:var(--sub);text-transform:uppercase;letter-spacing:.5px;}
.form-inp,.form-sel,.form-ta{background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:#fff;font-size:14px;outline:none;width:100%;}
.form-inp:focus,.form-sel:focus,.form-ta:focus{border-color:var(--gold-br);}
.form-ta{min-height:110px;resize:vertical;font-family:inherit;}
.form-sel option{background:var(--navy2);}
.form-hint{font-size:11px;color:var(--sub);}
.form-actions{display:flex;gap:10px;margin-top:20px;flex-wrap:wrap;}
.btn-save{background:var(--green);color:#fff;flex:1;padding:12px 20px;}
.btn-save:hover{background:#256642;}
.btn-cancel{background:transparent;border:1px solid var(--border);color:var(--text);padding:12px 18px;}

/* PREGUNTAS MÚLTIPLES */
.pq-block{background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:12px;padding:16px;margin-bottom:12px;}
.pq-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.pq-label{font-size:13px;font-weight:700;color:var(--gold);}
.pq-remove{background:transparent;border:1px solid rgba(229,115,115,.3);color:#e57373;border-radius:6px;padding:4px 10px;font-size:12px;cursor:pointer;}
.pq-remove:hover{background:rgba(229,115,115,.12);}
.pq-opciones{display:none;margin-top:10px;}
.pq-opciones.visible{display:block;}
.btn-add-pq{background:transparent;border:1px dashed var(--border);color:var(--gold);border-radius:8px;padding:10px 16px;font-size:13px;cursor:pointer;width:100%;text-align:center;margin-top:4px;}
.btn-add-pq:hover{background:rgba(184,134,11,.08);}
.btn-add-pq:disabled{opacity:.4;cursor:not-allowed;}

/* SIT GROUP */
.sit-group{margin-bottom:8px;border:1px solid var(--border);border-radius:12px;overflow:hidden;}
.sit-header{background:rgba(255,255,255,.03);padding:12px 16px;display:flex;align-items:center;gap:12px;cursor:pointer;}
.sit-header:hover{background:rgba(255,255,255,.06);}
.sit-hname{flex:1;font-size:14px;font-weight:600;color:#eee;}
.sit-hmeta{font-size:12px;color:var(--sub);}
.sit-hbadge{font-size:11px;border-radius:20px;padding:2px 10px;background:rgba(26,74,122,.4);color:#7ab3e8;}
.sit-hbadge.II{background:rgba(42,82,11,.4);color:#a8c06e;}
.sit-hbadge.III{background:rgba(100,30,60,.4);color:#c89ab4;}
.sit-cartas{display:none;}
.sit-cartas.open{display:block;}
.carta-row{padding:10px 16px 10px 48px;border-top:1px solid var(--border);display:flex;align-items:flex-start;gap:12px;}
.carta-num{font-size:18px;min-width:28px;}
.carta-info{flex:1;min-width:0;}
.carta-tipo{font-size:11px;font-weight:600;color:var(--sub);text-transform:uppercase;margin-bottom:2px;}
.carta-texto{font-size:13px;color:#ddd;}
.carta-herr{font-size:12px;color:var(--gold);margin-top:2px;}
.carta-actions{display:flex;gap:6px;flex-shrink:0;}

/* COMPETENCIA BADGES en lista */
.comp-badge{display:inline-block;font-size:11px;border-radius:20px;padding:2px 8px;margin:2px 2px 0 0;}
.comp-Liderazgo{background:rgba(26,74,122,.35);color:#7ab3e8;}
.comp-Planificación{background:rgba(42,82,11,.35);color:#a8c06e;}
.comp-Gestión{background:rgba(100,30,60,.35);color:#c89ab4;}
.comp-Comunicación{background:rgba(140,80,20,.35);color:#e0b07a;}

/* TOAST + CONFIRM */
.toast{position:fixed;bottom:24px;right:24px;z-index:9999;background:var(--green);color:#fff;border-radius:10px;padding:14px 22px;font-size:14px;font-weight:600;transform:translateY(80px);opacity:0;transition:.25s ease;pointer-events:none;}
.toast.show{transform:translateY(0);opacity:1;}
.toast.err{background:var(--red);}
#confirm-modal{display:none;position:fixed;inset:0;z-index:5000;background:rgba(0,0,0,.7);align-items:center;justify-content:center;}
#confirm-modal.open{display:flex;}
.confirm-box{background:var(--navy2);border:1px solid var(--border);border-radius:16px;padding:32px 28px;width:340px;text-align:center;}
.confirm-title{font-size:17px;font-weight:700;color:#eee;margin-bottom:10px;}
.confirm-sub{font-size:14px;color:var(--sub);margin-bottom:24px;}
.confirm-actions{display:flex;gap:12px;}
.btn-confirm-del{background:var(--red);color:#fff;flex:1;padding:12px;}
.btn-confirm-del:hover{background:#6b1818;}
.btn-confirm-cancel{background:transparent;border:1px solid var(--border);color:var(--text);flex:1;padding:12px;}

@media(max-width:640px){
  .form-grid{grid-template-columns:1fr;}
  .form-group.full{grid-column:1;}
  .mod-card{flex-wrap:wrap;}
}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-wrap">
  <div class="login-box">
    <div class="login-logo">🏛️</div>
    <div class="login-title">Panel de Administración</div>
    <div class="login-sub">Misión Muni · Gestión de contenido</div>
    <input class="inp" id="pin-inp" type="password" placeholder="PIN de acceso"
      onkeydown="if(event.key==='Enter')login()">
    <button class="btn btn-gold" onclick="login()">INGRESAR</button>
    <div class="err-msg" id="login-err">PIN incorrecto.</div>
  </div>
</div>

<!-- APP -->
<div id="app">
  <div class="topbar">
    <span class="topbar-title">🏛️ Misión Muni · Panel de contenido</span>
    <button class="topbar-btn" onclick="recargar()">↺ Actualizar</button>
    <button class="topbar-btn new" id="btn-nuevo" onclick="nuevo()">+ Nuevo</button>
  </div>

  <div class="tabs">
    <button class="tab-btn active" id="tab-herr" onclick="cambiarTab('herr')">📚 Herramientas</button>
    <button class="tab-btn" id="tab-sit"  onclick="cambiarTab('sit')">⚡ Situaciones</button>
  </div>

  <div class="content">
    <div class="spin" id="spin-list"></div>

    <!-- ── HERRAMIENTAS ── -->
    <div id="panel-herr">
      <div class="mod-grid" id="herr-list"></div>
    </div>

    <!-- ── SITUACIONES ── -->
    <div id="panel-sit" style="display:none">
      <div id="sit-list"></div>
    </div>

    <!-- ── FORM HERRAMIENTA ── -->
    <div id="form-panel">
      <div class="form-card">
        <div class="form-title" id="form-title">Nueva herramienta</div>
        <input type="hidden" id="f-fila">
        <div class="form-grid">

          <div class="form-group full">
            <label class="form-lbl">Nombre de la herramienta *</label>
            <input class="form-inp" id="f-nombre" placeholder="ej: Delegación Efectiva">
            <span class="form-hint">El nombre ES el identificador — debe coincidir con el usado en Situaciones.</span>
          </div>

          <div class="form-group">
            <label class="form-lbl">ERA a la que corresponde</label>
            <select class="form-sel" id="f-era">
              <option value="">— todas las eras —</option>
              <option value="ERA I">ERA I · Organización del Trabajo</option>
              <option value="ERA II">ERA II · Gestión del Desempeño</option>
              <option value="ERA III">ERA III · Desarrollo del Equipo</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-lbl">Nivel de dificultad</label>
            <select class="form-sel" id="f-nivel">
              <option value="Fácil">Fácil</option>
              <option value="Compleja">Compleja</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-lbl">Área municipal</label>
            <input class="form-inp" id="f-area" placeholder="ej: Hacienda">
          </div>

          <div class="form-group">
            <label class="form-lbl">Puntos que otorga esta capacitación</label>
            <select class="form-sel" id="f-puntaje">
              <option value="5">5 puntos (herramienta fácil)</option>
              <option value="10">10 puntos (herramienta compleja)</option>
            </select>
          </div>

          <div class="form-group full">
            <label class="form-lbl">Competencia que fortalece</label>
            <select class="form-sel" id="f-competencia">
              <option value="">— ninguna —</option>
              <option value="Liderazgo">🔵 Liderazgo</option>
              <option value="Planificación">🟢 Planificación</option>
              <option value="Gestión de equipo">🟣 Gestión de equipo</option>
              <option value="Comunicación">🟠 Comunicación</option>
            </select>
          </div>

          <div class="form-group full">
            <label class="form-lbl">Contenido a estudiar *</label>
            <textarea class="form-ta" id="f-contenido" placeholder="Escribí el contenido del módulo de aprendizaje…"></textarea>
          </div>

          <div class="form-group">
            <label class="form-lbl">URL de video (opcional)</label>
            <input class="form-inp" id="f-video" placeholder="https://youtube.com/...">
          </div>

          <div class="form-group">
            <label class="form-lbl">URL de infografía (opcional)</label>
            <input class="form-inp" id="f-infografia" placeholder="https://...">
          </div>

          <div class="form-group">
            <label class="form-lbl">ID de insignia (opcional)</label>
            <input class="form-inp" id="f-insignia" placeholder="ej: INS_LIDERAZGO">
          </div>

        </div>

        <!-- PREGUNTAS DE COMPROBACIÓN -->
        <div style="margin-top:20px;margin-bottom:8px;">
          <div style="font-size:13px;font-weight:700;color:var(--gold);margin-bottom:12px;">Preguntas de comprobación</div>
          <div id="pq-container"></div>
          <button class="btn-add-pq" id="btn-add-pq" onclick="agregarPregunta()">+ Agregar pregunta</button>
        </div>

        <div class="form-actions">
          <button class="btn btn-save" onclick="guardarHerr()">💾 GUARDAR</button>
          <button class="btn btn-cancel btn-ghost" onclick="cancelarForm()">Cancelar</button>
        </div>
      </div>
    </div>

    <!-- ── FORM SITUACIÓN (carta individual) ── -->
    <div id="form-sit-panel" style="display:none">
      <div class="form-card">
        <div class="form-title" id="sit-form-title">Editar carta</div>
        <input type="hidden" id="sf-fila">
        <div class="form-grid">
          <div class="form-group">
            <label class="form-lbl">ERA *</label>
            <select class="form-sel" id="sf-era">
              <option value="ERA I ORGANIZACION DEL TRABAJO">ERA I · Organización del Trabajo</option>
              <option value="ERA II GESTION DEL DESEMPEÑO">ERA II · Gestión del Desempeño</option>
              <option value="ERA III DESARROLLO DEL EQUIPO">ERA III · Desarrollo del Equipo</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-lbl">Trayecto</label>
            <select class="form-sel" id="sf-trayecto">
              <option value="Operativo">Operativo</option>
              <option value="Estratégico">Estratégico</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-lbl">Área municipal *</label>
            <select class="form-sel" id="sf-area">
              <option value="Hacienda">Hacienda</option>
              <option value="Servicios Públicos">Servicios Públicos</option>
              <option value="Capital Humano">Capital Humano</option>
              <option value="Obras Particulares">Obras Particulares</option>
              <option value="Direcciones">Direcciones</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-lbl">Competencia que fortalece</label>
            <select class="form-sel" id="sf-competencia">
              <option value="">— ninguna —</option>
              <option value="Liderazgo">🔵 Liderazgo</option>
              <option value="Planificación">🟢 Planificación</option>
              <option value="Gestión de equipo">🟣 Gestión de equipo</option>
              <option value="Comunicación">🟠 Comunicación</option>
            </select>
          </div>
          <div class="form-group full">
            <label class="form-lbl">Nombre de la situación *</label>
            <input class="form-inp" id="sf-sit" placeholder="ej: Sobrecarga de tareas">
          </div>
          <div class="form-group full">
            <label class="form-lbl">Descripción de la situación *</label>
            <textarea class="form-ta" id="sf-desc" style="min-height:80px"></textarea>
          </div>
          <div class="form-group">
            <label class="form-lbl">N° de carta (1-4)</label>
            <input class="form-inp" id="sf-nro" type="number" min="1" max="4">
          </div>
          <div class="form-group">
            <label class="form-lbl">Tipo de respuesta</label>
            <select class="form-sel" id="sf-tipo">
              <option value="Sin capacitación (neutro)">Sin capacitación (neutro)</option>
              <option value="Herramienta fácil">Herramienta fácil</option>
              <option value="Herramienta compleja">Herramienta compleja</option>
            </select>
          </div>
          <div class="form-group full">
            <label class="form-lbl">Texto de la acción/respuesta *</label>
            <textarea class="form-ta" id="sf-texto" style="min-height:80px"></textarea>
          </div>
          <div class="form-group">
            <label class="form-lbl">Puntaje</label>
            <select class="form-sel" id="sf-puntaje">
              <option value="0">0 — sin herramienta</option>
              <option value="5">5 — herramienta fácil</option>
              <option value="10">10 — herramienta compleja</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-lbl">Herramienta requerida (cartas 3-4)</label>
            <select class="form-sel" id="sf-herr">
              <option value="">— ninguna —</option>
            </select>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn btn-save" onclick="guardarSit()">💾 GUARDAR CARTA</button>
          <button class="btn btn-cancel btn-ghost" onclick="cancelarSitForm()">Cancelar</button>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- CONFIRM -->
<div id="confirm-modal">
  <div class="confirm-box">
    <div class="confirm-title">¿Eliminar?</div>
    <div class="confirm-sub" id="confirm-sub"></div>
    <div class="confirm-actions">
      <button class="btn btn-confirm-del" onclick="confirmarEliminar()">SÍ, ELIMINAR</button>
      <button class="btn btn-confirm-cancel btn-ghost" onclick="cancelarEliminar()">Cancelar</button>
    </div>
  </div>
</div>
<div class="toast" id="toast"></div>

<script>
const COMPETENCIAS = [
  { codigo: "Liderazgo",         emoji: "🔵" },
  { codigo: "Planificación",     emoji: "🟢" },
  { codigo: "Gestión de equipo", emoji: "🟣" },
  { codigo: "Comunicación",      emoji: "🟠" }
];
const ERAS = [
  { valor: "ERA I",   label: "ERA I",   cls: "era1" },
  { valor: "ERA II",  label: "ERA II",  cls: "era2" },
  { valor: "ERA III", label: "ERA III", cls: "era3" }
];

let herramientas = [], situaciones = [];
let tabActual = 'herr';
let pendingDelete = null;
let numPreguntas = 0;

// ── AUTH ──
function login() {
  const pin = document.getElementById('pin-inp').value.trim();
  if (!pin) return;
  document.getElementById('login-err').style.display = 'none';
  google.script.run
    .withSuccessHandler(function(ok) {
      if (ok) {
        document.getElementById('login-wrap').style.display = 'none';
        document.getElementById('app').style.display = 'block';
        cargarTodo();
      } else {
        document.getElementById('login-err').style.display = 'block';
        document.getElementById('pin-inp').value = '';
      }
    })
    .withFailureHandler(function(){ toast('Error de conexión', true); })
    .verificarAdminPin(pin);
}

// ── CARGA ──
function cargarTodo() {
  spin(true);
  google.script.run
    .withSuccessHandler(function(d) {
      herramientas = d.herramientas || [];
      situaciones  = d.situaciones  || [];
      llenarHerramientasSelect();
      renderTab();
      spin(false);
    })
    .withFailureHandler(function(e){ spin(false); toast('Error: '+e.message, true); })
    .obtenerDatosAdmin();
}
function recargar() { ocultarForms(); cargarTodo(); }

// ── TABS ──
function cambiarTab(t) {
  tabActual = t;
  ['herr','sit'].forEach(function(x){
    document.getElementById('tab-'+x).classList.toggle('active', x===t);
    document.getElementById('panel-'+x).style.display = x===t ? 'block' : 'none';
  });
  ocultarForms();
  document.getElementById('btn-nuevo').textContent = t==='herr' ? '+ Nueva herramienta' : '+ Nueva situación (carta)';
  renderTab();
}

function nuevo() {
  if (tabActual === 'herr') nuevaHerr();
  else nuevaSit();
}

// ── RENDER HERRAMIENTAS ──
function renderHerr() {
  const el = document.getElementById('herr-list');
  if (!herramientas.length) {
    el.innerHTML = '<div class="empty-state">No hay herramientas cargadas. Creá la primera con "+ Nueva herramienta".</div>';
    return;
  }
  el.innerHTML = herramientas.map(function(h) {
    const ic = (h.nivel||'').toLowerCase().indexOf('comp') > -1 ? '🔧' : '📖';
    const eraTag = eraClass(h.era);
    const compTag = h.competencia ? '<span class="comp-badge comp-'+h.competencia.split(' ')[0]+'">'+esc(h.competencia)+'</span>' : '';
    const ptsBadge = h.puntaje ? '<span class="mod-badge green">'+h.puntaje+' pts</span>' : '';
    const eraBadge = eraTag ? '<span class="mod-badge '+eraTag.cls+'">'+eraTag.label+'</span>' : '';
    const numPqs = [h.pregunta, h.pregunta2, h.pregunta3].filter(Boolean).length;
    const pqBadge = numPqs > 0 ? '<span class="mod-badge blue">'+numPqs+' pregunta'+(numPqs>1?'s':'')+'</span>' : '';
    return '<div class="mod-card">' +
      '<div class="mod-icon">'+ic+'</div>' +
      '<div class="mod-info">' +
        '<div class="mod-name">'+esc(h.nombre)+'</div>' +
        '<div class="mod-meta">'+esc(h.area||'—')+' · '+esc(h.nivel||'')+'</div>' +
        (compTag ? '<div style="margin-top:4px">'+compTag+'</div>' : '') +
      '</div>' +
      '<div class="mod-badges">'+eraBadge+ptsBadge+pqBadge+'</div>' +
      '<div class="mod-actions">' +
        '<button class="act-btn act-edit" onclick="editarHerr('+h._fila+')">✏️ Editar</button>' +
        '<button class="act-btn act-del" onclick="pedirEliminar(\'herr\','+h._fila+',\''+esc(h.nombre)+'\')">🗑️</button>' +
      '</div>' +
    '</div>';
  }).join('');
}

function eraClass(era) {
  if (!era) return null;
  const s = era.toUpperCase();
  if (s.indexOf('III') > -1) return { cls: 'era3', label: 'ERA III' };
  if (s.indexOf('II') > -1)  return { cls: 'era2', label: 'ERA II' };
  if (s.indexOf('I') > -1)   return { cls: 'era1', label: 'ERA I' };
  return null;
}

// ── RENDER SITUACIONES ──
function renderSit() {
  const el = document.getElementById('sit-list');
  if (!situaciones.length) {
    el.innerHTML = '<div class="empty-state">No hay situaciones cargadas. Agregá una con "+ Nueva situación (carta)".</div>';
    return;
  }
  const grupos = {};
  situaciones.forEach(function(s) {
    const k = s.era+'||'+s.area+'||'+s.situacion;
    if (!grupos[k]) grupos[k] = { era: s.era, area: s.area, situacion: s.situacion, comp: s.competencia, cartas: [] };
    grupos[k].cartas.push(s);
  });
  const keys = Object.keys(grupos).sort();
  el.innerHTML = keys.map(function(k) {
    const g = grupos[k];
    const eraNum = g.era.indexOf('I ORGAN') > -1 ? 'I' : g.era.indexOf('II GESTI') > -1 ? 'II' : 'III';
    const cartasHTML = g.cartas.sort(function(a,b){ return a.nroCarta - b.nroCarta; }).map(function(c) {
      const ics = ['','1️⃣','2️⃣','3️⃣','4️⃣'];
      return '<div class="carta-row">' +
        '<div class="carta-num">'+(ics[c.nroCarta]||c.nroCarta)+'</div>' +
        '<div class="carta-info">' +
          '<div class="carta-tipo">'+esc(c.tipoRespuesta)+(c.puntaje?' · '+c.puntaje+' pts':'')+'</div>' +
          '<div class="carta-texto">'+esc(c.textoRespuesta)+'</div>' +
          (c.herramienta ? '<div class="carta-herr">🔧 '+esc(c.herramienta)+'</div>' : '') +
        '</div>' +
        '<div class="carta-actions">' +
          '<button class="act-btn act-edit" onclick="editarSit('+c._fila+')">✏️</button>' +
          '<button class="act-btn act-del" onclick="pedirEliminar(\'sit\','+c._fila+',\'carta '+c.nroCarta+' de '+esc(c.situacion)+'\')">🗑️</button>' +
        '</div>' +
      '</div>';
    }).join('');
    return '<div class="sit-group">' +
      '<div class="sit-header" onclick="toggleSit(this)">' +
        '<span class="sit-hbadge '+eraNum+'">ERA '+eraNum+'</span>' +
        '<span class="sit-hname">'+esc(g.situacion)+'</span>' +
        '<span class="sit-hmeta">'+esc(g.area)+' · '+esc(g.comp)+'</span>' +
        '<span style="color:var(--sub);font-size:12px">▼</span>' +
      '</div>' +
      '<div class="sit-cartas">'+cartasHTML+'</div>' +
    '</div>';
  }).join('');
}
function toggleSit(hdr) {
  const c = hdr.nextElementSibling;
  c.classList.toggle('open');
  hdr.querySelector('span:last-child').textContent = c.classList.contains('open') ? '▲' : '▼';
}

function renderTab() {
  if (tabActual === 'herr') renderHerr();
  else renderSit();
}

// ── PREGUNTAS DINÁMICAS ──
function crearBloquePregunta(n, data) {
  data = data || {};
  const tieneOpciones = !!(data.opcionA || data.opcionB);
  const div = document.createElement('div');
  div.className = 'pq-block';
  div.id = 'pq-block-'+n;
  div.innerHTML =
    '<div class="pq-header">' +
      '<span class="pq-label">Pregunta '+n+(n===1?' (requerida)':'')+'</span>' +
      (n > 1 ? '<button class="pq-remove" onclick="quitarPregunta('+n+')">✕ Quitar</button>' : '') +
    '</div>' +
    '<div class="form-group full" style="margin-bottom:10px">' +
      '<label class="form-lbl">Texto de la pregunta</label>' +
      '<input class="form-inp" id="pq'+n+'-pregunta" placeholder="ej: ¿Cuáles son los pasos del proceso?" value="'+esc(data.pregunta||'')+'">'+
    '</div>' +
    '<div class="form-group" style="margin-bottom:10px">' +
      '<label class="form-lbl">Tipo de respuesta</label>' +
      '<select class="form-sel" id="pq'+n+'-tipo" onchange="togglePqTipo('+n+')">' +
        '<option value="libre"'+(tieneOpciones?'':' selected')+'>Respuesta libre</option>' +
        '<option value="multiple"'+(tieneOpciones?' selected':'')+'>Opción múltiple</option>' +
      '</select>' +
    '</div>' +
    '<div class="pq-opciones'+(tieneOpciones?' visible':'')+'" id="pq'+n+'-opciones">' +
      '<div class="form-grid" style="margin-bottom:8px">' +
        '<div class="form-group"><label class="form-lbl">Opción A</label><input class="form-inp" id="pq'+n+'-opA" value="'+esc(data.opcionA||'')+'"></div>' +
        '<div class="form-group"><label class="form-lbl">Opción B</label><input class="form-inp" id="pq'+n+'-opB" value="'+esc(data.opcionB||'')+'"></div>' +
        '<div class="form-group"><label class="form-lbl">Opción C (opc.)</label><input class="form-inp" id="pq'+n+'-opC" value="'+esc(data.opcionC||'')+'"></div>' +
        '<div class="form-group"><label class="form-lbl">Opción D (opc.)</label><input class="form-inp" id="pq'+n+'-opD" value="'+esc(data.opcionD||'')+'"></div>' +
      '</div>' +
      '<div class="form-group">' +
        '<label class="form-lbl">Respuesta correcta (texto exacto de la opción)</label>' +
        '<input class="form-inp" id="pq'+n+'-respuesta-multi" value="'+esc(tieneOpciones ? data.respuesta||'' : '')+'">'+
      '</div>' +
    '</div>' +
    '<div class="form-group" id="pq'+n+'-libre-wrap" style="'+(tieneOpciones?'display:none':'')+';margin-top:8px">' +
      '<label class="form-lbl">Respuesta correcta</label>' +
      '<input class="form-inp" id="pq'+n+'-respuesta-libre" placeholder="ej: situacion, comportamiento, impacto" value="'+esc(!tieneOpciones ? data.respuesta||'' : '')+'">'+
      '<span class="form-hint">El jugador debe escribir exactamente esto. Para confirmar lectura usá "si".</span>'+
    '</div>';
  return div;
}

function inicializarPreguntas(h) {
  numPreguntas = 0;
  document.getElementById('pq-container').innerHTML = '';
  const bloques = [
    { pregunta: h.pregunta||'', respuesta: h.respuesta||'', opcionA: h.opcionA||'', opcionB: h.opcionB||'', opcionC: h.opcionC||'', opcionD: h.opcionD||'' },
    { pregunta: h.pregunta2||'', respuesta: h.respuesta2||'', opcionA: h.opcionA2||'', opcionB: h.opcionB2||'', opcionC: h.opcionC2||'', opcionD: h.opcionD2||'' },
    { pregunta: h.pregunta3||'', respuesta: h.respuesta3||'', opcionA: h.opcionA3||'', opcionB: h.opcionB3||'', opcionC: h.opcionC3||'', opcionD: h.opcionD3||'' }
  ];
  // Siempre agregar al menos la pregunta 1
  agregarPregunta(bloques[0]);
  if (bloques[1].pregunta) agregarPregunta(bloques[1]);
  if (bloques[2].pregunta) agregarPregunta(bloques[2]);
}

function agregarPregunta(data) {
  if (numPreguntas >= 3) return;
  numPreguntas++;
  const container = document.getElementById('pq-container');
  container.appendChild(crearBloquePregunta(numPreguntas, data || {}));
  actualizarBtnAgregar();
}

function quitarPregunta(n) {
  const el = document.getElementById('pq-block-'+n);
  if (el) el.remove();
  // Renumerar
  const bloques = document.querySelectorAll('.pq-block');
  numPreguntas = 0;
  bloques.forEach(function(b) {
    numPreguntas++;
    const num = numPreguntas;
    b.id = 'pq-block-'+num;
    b.querySelector('.pq-label').textContent = 'Pregunta '+num+(num===1?' (requerida)':'');
    const btn = b.querySelector('.pq-remove');
    if (btn) btn.setAttribute('onclick','quitarPregunta('+num+')');
    // Actualizar IDs internos
    b.querySelectorAll('[id]').forEach(function(el){
      el.id = el.id.replace(/^pq\d+-/, 'pq'+num+'-');
    });
    b.querySelectorAll('[onchange]').forEach(function(el){
      el.setAttribute('onchange','togglePqTipo('+num+')');
    });
  });
  actualizarBtnAgregar();
}

function togglePqTipo(n) {
  const t = document.getElementById('pq'+n+'-tipo').value;
  document.getElementById('pq'+n+'-opciones').classList.toggle('visible', t==='multiple');
  document.getElementById('pq'+n+'-libre-wrap').style.display = t==='libre' ? '' : 'none';
}

function actualizarBtnAgregar() {
  const btn = document.getElementById('btn-add-pq');
  btn.disabled = numPreguntas >= 3;
  btn.textContent = numPreguntas >= 3 ? '(máximo 3 preguntas)' : '+ Agregar otra pregunta';
}

function obtenerDatosPreguntas() {
  const pqs = [];
  for (let i = 1; i <= numPreguntas; i++) {
    const bloque = document.getElementById('pq-block-'+i);
    if (!bloque) continue;
    const tipo = document.getElementById('pq'+i+'-tipo').value;
    const pregunta = document.getElementById('pq'+i+'-pregunta').value.trim();
    const respuesta = tipo === 'multiple'
      ? document.getElementById('pq'+i+'-respuesta-multi').value.trim().toLowerCase()
      : document.getElementById('pq'+i+'-respuesta-libre').value.trim().toLowerCase();
    const opcionA = tipo === 'multiple' ? document.getElementById('pq'+i+'-opA').value.trim() : '';
    const opcionB = tipo === 'multiple' ? document.getElementById('pq'+i+'-opB').value.trim() : '';
    const opcionC = tipo === 'multiple' ? document.getElementById('pq'+i+'-opC').value.trim() : '';
    const opcionD = tipo === 'multiple' ? document.getElementById('pq'+i+'-opD').value.trim() : '';
    pqs.push({ pregunta, respuesta, opcionA, opcionB, opcionC, opcionD });
  }
  return pqs;
}

