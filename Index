}
.modal-preg{font-family:'Cinzel',serif;font-size:10px;letter-spacing:1px;color:var(--gold);margin-bottom:10px;text-align:center;}
.modal-inp{
  width:100%;padding:11px 14px;
  background:var(--perg);border:2px solid rgba(28,46,74,.3);
