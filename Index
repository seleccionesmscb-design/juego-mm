.modal-titulo{font-family:'Cinzel',serif;font-size:16px;font-weight:700;color:var(--navy);margin-bottom:10px;letter-spacing:1px;}
.modal-cont{
  font-size:14px;line-height:1.8;color:var(--navy-md);
  margin-bottom:16px;
