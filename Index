<script>
const REC = {
  desarrollo:{lbl:'Desarrollo',sub:'Crecimiento del equipo',color:'#4a2109'},
  clima:{lbl:'Clima',sub:'Vínculos y motivación',color:'#6b7530'},
  recursos:{lbl:'Recursos',sub:'Insumos y capacidad operativa',color:'#a06a1f'},
  planificacion:{lbl:'Planificación',sub:'Organización operativa',color:'#8a4d1e'},
  desempenio:{lbl:'Desempeño',sub:'Resultados del área',color:'#b5461f'}
};
const COMP_COLORS = ['#b5461f','#4a2109','#6b7530','#a06a1f','#8a4d1e','#a8410f','#59642a'];
// Agrupa las 7 competencias de gestión en 4 categorías genéricas para mostrar
// en la pantalla de bienvenida (el detalle completo se mantiene en el juego).
const GRUPOS_COMPETENCIA = [
  { nombre: 'Comunicación',    match: n => /presión/i.test(n) },
  { nombre: 'Liderazgo',       match: n => /liderazgo|decisiones/i.test(n) },
  { nombre: 'Planificación',   match: n => /estratégica|políticas|planificación/i.test(n) },
  { nombre: 'Gestión de equipo', match: n => /personas|desarrollo/i.test(n) }
];
// Devuelve [{nombre, items:[{codigo,nombre,definicion}, ...]}] agrupando el
// catálogo de 7 competencias en las 4 categorías genéricas.
function agruparCompetenciasDetalle(catalogo) {
  const grupos = [];
  (catalogo||[]).forEach(c => {
    const gDef = GRUPOS_COMPETENCIA.find(g => g.match(c.nombre||''));
    const nombre = gDef ? gDef.nombre : (c.nombre||'');
    let grupo = grupos.find(g => g.nombre === nombre);
    if (!grupo) { grupo = { nombre, items: [] }; grupos.push(grupo); }
    grupo.items.push(c);
  });
  return grupos;
}
const ENC = {
  2:{titulo:'Encuentro 1 · Era I Completada',desc:'Completaste la Organización del Trabajo (10 situaciones). Reunite con los otros equipos para compartir aprendizajes y llevar los recursos obtenidos.'},
  3:{titulo:'Encuentro 2 · Era II Completada',desc:'Completaste la Gestión del Desempeño (10 situaciones). Nueva reunión grupal para evaluar el avance e integrar herramientas de gestión.'}
};

let g = null, agenteData = null, currentScreen = 'tablero', selectedCard = null, capHerr = null, capTab = 'texto', capOpcionSeleccionada = null, capPreguntaIndex = 0;

/* ── LOGIN ── */
function validarLegajo() {
  const legajo = document.getElementById('inp-legajo').value.trim();
  if(!legajo){showStatus('Ingresá un número de legajo','err');return;}
  showStatus('Buscando en el registro municipal…','loading');
  showLoader();
  google.script.run
    .withSuccessHandler(res => {
      hideLoader();
      if(res && res.encontrado) {
        agenteData = { legajo: legajo, nombre: res.nombre, direccion: res.direccion };
        document.getElementById('ac-nombre').innerText = res.nombre;
        document.getElementById('ac-info').innerText = 'Legajo ' + legajo + ' · ' + res.direccion;
        document.getElementById('ac-equipo').innerText = 'Dirección de ' + res.direccion;
        document.getElementById('agente-card').classList.add('visible');
        document.getElementById('legajo-form').style.display = 'none';
      } else {
        showStatus('Legajo no encontrado. Verificá el número o consultá con RRHH.','err');
        document.getElementById('agente-card').classList.remove('visible');
      }
    })
    .withFailureHandler(e => { hideLoader(); showStatus('Error al consultar. Intentá de nuevo.','err'); })
    .buscarAgente(legajo);
}
function showStatus(msg, type) {
  const el = document.getElementById('legajo-status');
  el.innerText = msg; el.className = 'legajo-status ' + type;
}

/* ── BIENVENIDA ── */
function mostrarPresentacion() {
  if(!agenteData) return;
  document.getElementById('screen-login').style.display = 'none';
  document.getElementById('screen-bienvenida').style.display = 'block';

  document.getElementById('bv-nombre').innerText = agenteData.nombre.toUpperCase() + '!';
  document.getElementById('bv-legajo').innerText = 'Legajo ' + agenteData.legajo;
  document.getElementById('bv-dir').innerText = 'Dirección de ' + agenteData.direccion;

  showLoader();
  google.script.run
    .withSuccessHandler(res => {
      hideLoader(); g = res;
      document.getElementById('bv-team').innerHTML = (g.estado.equipo||[]).map(m =>
        `<div class="bt-av"><div class="bt-circ">${(m.nombre||'').split(' ').map(w=>w[0]).slice(0,2).join('')}</div><div class="bt-nm">${m.nombre}</div><div class="bt-role">${m.rol||''}</div></div>`
      ).join('') || '<span style="font-size:12px;font-style:italic;color:var(--gold-br)">Tu equipo se irá completando durante la partida.</span>';
      g.gruposCompetencia = agruparCompetenciasDetalle(g.competenciasCatalogo);
      document.getElementById('bv-inds').innerHTML = g.gruposCompetencia.map((grupo,i) => `
        <div class="bt-item" style="margin-bottom:8px;cursor:pointer;flex-direction:column;align-items:stretch;gap:0" onclick="toggleGrupoBienvenida(${i})">
          <div style="display:flex;align-items:center;gap:8px"><div class="bt-dot"></div><span style="flex:1">${grupo.nombre}</span><span id="bv-grupo-arrow-${i}" style="font-size:11px;color:var(--gold-br)">▾</span></div>
          <div id="bv-grupo-detalle-${i}" style="display:none;margin:8px 0 2px;padding-top:8px;border-top:1px dashed rgba(150,80,35,.3)">
            ${grupo.items.map(it => `<div style="margin-bottom:6px"><div style="font-family:'Cinzel',serif;font-weight:700;font-size:11px;color:var(--navy)">${it.nombre}</div><div style="font-size:11.5px;line-height:1.4;color:var(--navy-md)">${it.definicion||''}</div></div>`).join('')}
          </div>
        </div>`
      ).join('') || '<span style="font-size:12px;font-style:italic;color:var(--gold-br)">Sin competencias cargadas.</span>';
    })
    .withFailureHandler(e => { hideLoader(); alert('Error: '+e.message); })
    .iniciarPartida(agenteData.legajo, agenteData.direccion, null, agenteData.nombre);
}

function toggleGrupoBienvenida(i) {
  const det = document.getElementById('bv-grupo-detalle-'+i);
  const arrow = document.getElementById('bv-grupo-arrow-'+i);
  const abierto = det.style.display === 'block';
  det.style.display = abierto ? 'none' : 'block';
  arrow.innerText = abierto ? '▾' : '▴';
}

function competenciaColor(idx) { return COMP_COLORS[idx % COMP_COLORS.length]; }

function renderCompetencias() {
  if(!g || !g.competenciasCatalogo) return '';
  const grupos = agruparCompetenciasDetalle(g.competenciasCatalogo);
  return grupos.map((grupo,i) => {
    const valores = grupo.items.map(it => g.estado.competencias[it.codigo] || 0);
    const v = valores.reduce((a,b)=>a+b,0) / valores.length;
    const color = competenciaColor(i);
    return `<div class="ind-row"><div class="ind-row-top"><div class="ind-row-lbl"><div class="ind-dot" style="background:${color}"></div>${grupo.nombre}</div><div class="ind-row-val">${v.toFixed(1)}/5</div></div><div class="ind-bar-bg"><div class="ind-bar-fg" style="width:${v*20}%;background:${color}"></div></div></div>`;
  }).join('');
}

/* ── INICIAR JUEGO ── */
function iniciarJuego() {
  document.getElementById('screen-bienvenida').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  document.getElementById('profile-av').innerText = (agenteData.nombre||'').split(' ').map(w=>w[0]).slice(0,2).join('');
  document.getElementById('profile-nm').innerText = agenteData.nombre;
  document.getElementById('profile-tm').innerText = 'Dirección de ' + agenteData.direccion;
  document.getElementById('tab-dir-title').innerText = 'Dirección de ' + agenteData.direccion;
  go('tablero');
  render();
}

function go(screen) {
  currentScreen = screen;
  ['tablero','situacion','capacitacion'].forEach(s => {
    document.getElementById('scr-'+s).classList.toggle('active', s===screen);
    document.getElementById('nav-'+s).classList.toggle('active', s===screen);
  });
  if(screen==='capacitacion' && !capHerr) volverABiblioteca();
}

/* ── RENDER GENERAL ── */
function render() {
  if(!g) return;
  const e = g.estado;
  renderLanes(e.casillero);
  document.getElementById('tab-inds').innerHTML = renderCompetencias();
  document.getElementById('sit-inds').innerHTML = renderCompetencias();
  document.getElementById('cap-inds').innerHTML = renderCompetencias();

  document.getElementById('ins-row').innerHTML = e.insignias.length
    ? e.insignias.map(i=>`<div class="ins-badge" title="${i}">🎖</div>`).join('')
    : `<span style="font-size:11px;font-style:italic;color:var(--navy-md)">Completá módulos para ganar insignias</span>`;

  const tipo = (g.situacion.tipo||'situacion').toLowerCase();
  const tipoEl = document.getElementById('sit-tipo');
  tipoEl.className = 'situ-badge '+tipo;
  tipoEl.innerText = tipo==='crisis'?'⚡ CRISIS':tipo==='final'?'🏆 MISIÓN COMPLETADA':'📋 SITUACIÓN';
  document.getElementById('sit-title').innerText = g.situacion.titulo;
  document.getElementById('sit-desc').innerText = g.situacion.desc;

  const posGlobal = e.casillero + 1;
  const posEnEra = ((posGlobal - 1) % 10) + 1;
  document.getElementById('sit-pos').innerText = tipo==='final' ? '' : `SITUACIÓN ${Math.min(posEnEra,10)} DE 10 · ${g.situacion.era||''}`;

  renderCartas();
  renderBibList();
}

/* ── TABLERO: ERAS/LANES (10 situaciones por Era) ── */
function renderLanes(cas) {
  const ERAS = [
    {r:'I',nm:'Organización del trabajo',color:'var(--era1)',off:0,enc:'ENCUENTRO 1'},
    {r:'II',nm:'Gestión del desempeño',color:'var(--era2)',off:10,enc:'ENCUENTRO 2'},
    {r:'III',nm:'Desarrollo del equipo',color:'var(--era3)',off:20,enc:null}
  ];
  let html = '';
  ERAS.forEach(era => {
    html += `<div class="lane"><div class="lane-hdr"><div class="lane-chip" style="background:${era.color}">ERA ${era.r}</div><div class="lane-nm">${era.nm}</div></div><div class="lane-stops">`;
    const posActual = cas + 1;
    for(let i=1;i<=10;i++){
      const n = era.off + i;
      const st = n < posActual ? 'done' : n === posActual ? 'current' : 'pending';
      const onclk = st==='current' ? ` onclick="go('situacion')" title="Ir a tu situación actual"` : '';
      html += `<div class="lane-stop"><div class="lane-med ${st}"${onclk}>${st==='done'?'✓':i}</div></div>`;
    }
    html += `</div>`;
    if(era.enc) html += `<div style="margin-top:12px;display:inline-block;padding:5px 12px;background:rgba(196,144,48,.16);border:1px solid rgba(196,144,48,.4);border-radius:7px;font-family:'Cinzel',serif;font-size:9px;font-weight:700;letter-spacing:1.5px;color:var(--gold)">${era.enc}</div>`;
    html += `</div>`;
  });
  document.getElementById('lanes-wrap').innerHTML = html;
}

/* ── CARTAS ── */
function normCat(s){ return String(s||'').toLowerCase().normalize("NFD").replace(/[̀-ͯ]/g,""); }
function catColor(cat) {
  if(!cat) return {band:'#6b4423',med:'linear-gradient(160deg,#93a04f,#59642a)',frame:'linear-gradient(160deg,#5d6a2c,#38401a)',stud:'#93a04f'};
  const c = normCat(cat);
  if(c.includes('comunic')) return {band:'#1a5a3a',med:'linear-gradient(160deg,#4a9a6a,#1a5a3a)',frame:'linear-gradient(160deg,#2a6a4a,#1a3a28)',stud:'#4a9a6a'};
  if(c.includes('liderazg')||c.includes('profesion')) return {band:'#a8410f',med:'linear-gradient(160deg,#e39445,#a8410f)',frame:'linear-gradient(160deg,#a8551f,#6e3212)',stud:'#e39445'};
  if(c.includes('gestion')||c.includes('equipo')) return {band:'#5a3a7a',med:'linear-gradient(160deg,#9a6ab0,#5a3a7a)',frame:'linear-gradient(160deg,#6a4a8a,#3a2050)',stud:'#9a6ab0'};
  if(c.includes('planif')||c.includes('organiz')) return {band:'#6b4423',med:'linear-gradient(160deg,#93a04f,#59642a)',frame:'linear-gradient(160deg,#5d6a2c,#38401a)',stud:'#93a04f'};
  return {band:'#6b4423',med:'linear-gradient(160deg,#93a04f,#59642a)',frame:'linear-gradient(160deg,#5d6a2c,#38401a)',stud:'#93a04f'};
}
function catIcon(cat) {
  if(!cat) return '⚡'; const c = normCat(cat);
  if(c.includes('comunic')) return '💬';
  if(c.includes('liderazg')||c.includes('profesion')) return '🧭';
  if(c.includes('gestion')||c.includes('equipo')) return '🤝';
  if(c.includes('planif')||c.includes('organiz')) return '📋';
  return '⚡';
}

function renderCartas() {
  const grid = document.getElementById('cards-grid');
  if(!g.cartas||!g.cartas.length){
    grid.innerHTML='<p style="font-style:italic;color:var(--navy-md);padding:18px">Recorrido completo.</p>';
    document.getElementById('confirm-bar').classList.remove('visible');
    return;
  }
  grid.innerHTML = g.cartas.map(c => {
    const col = catColor(c.cat);
    const ico = catIcon(c.cat);
    const reward = (c.recursoGanado && c.cantidadRecurso > 0) ? `+${c.cantidadRecurso} ${(REC[c.recursoGanado]?.lbl||c.recursoGanado).toUpperCase()}` : '';
    const isSel = selectedCard && selectedCard.id===c.id;

    if(c.bloqueada) {
      const herr = g.biblioteca ? g.biblioteca.find(h=>h.id===c.req) : null;
      const hn = herr ? herr.nombre : c.req;
      const lockCol = catColor(c.competencia);
      return `<div class="mm-card" onclick="abrirHerrDesdeCarta('${c.req}')">
        <div class="mm-frame" style="background:linear-gradient(160deg,#8a7a62,#5a4d3c);border:1px solid rgba(40,20,8,.5)">
          <div class="mm-inner locked">
            <div class="mm-band" style="background:#8c7a63">REQUIERE CAPACITACIÓN</div>
            <div class="mm-lock">🔒</div>
            <div class="mm-title">${c.texto}</div>
            <div class="mm-desc" style="font-style:italic">Estudiá "${hn}" para desbloquear</div>
            ${c.competencia?`<div class="mm-foot" style="background:${lockCol.band};color:#fff;font-size:9px;padding:3px 6px;text-align:center;border-radius:3px;margin-top:4px">⭐ FORTALECE: ${c.competencia.toUpperCase()}${c.puntaje?' · '+c.puntaje+' PTS':''}</div>`:''}
          </div>
        </div>
      </div>`;
    }

    const puntos = c.valor > 0 ? `${c.valor} PTS` : '';
    return `<div class="mm-card ${isSel?'selected':''}" onclick="seleccionarCarta('${c.id}','${c.cat}','${c.recursoGanado}',${c.cantidadRecurso||0},${c.valor||0},'${(c.texto||'').split("'").join("\\'")}')">
      <div class="mm-frame" style="background:${col.frame};border:1px solid rgba(40,20,8,.5)${isSel?';outline:3px solid var(--gold-br);outline-offset:2px':''}">
        <div class="mm-inner">
          <div class="mm-stud" style="top:7px;left:7px;background:${col.stud}"></div>
          <div class="mm-stud" style="top:7px;right:7px;background:${col.stud}"></div>
          <div class="mm-stud" style="bottom:7px;left:7px;background:${col.stud}"></div>
          <div class="mm-stud" style="bottom:7px;right:7px;background:${col.stud}"></div>
          <div class="mm-band" style="background:${col.band}">${(c.cat||'').toUpperCase()}${puntos?` · ${puntos}`:''}</div>
          <div class="mm-med" style="background:${col.med}">${ico}</div>
          <div class="mm-title">${c.texto}</div>
          <div class="mm-pips"><div class="mm-pip" style="background:${col.stud}"></div>${c.req?`<div class="mm-pip" style="background:${col.stud}"></div>`:''}</div>
          ${reward?`<div class="mm-foot" style="color:var(--teal);background:rgba(107,117,48,.16)">${reward}</div>`:''}
        </div>
      </div>
    </div>`;
  }).join('');
  updateConfirmBar();
}

function seleccionarCarta(id,cat,recurso,cantidad,valor,texto) {
  selectedCard = {id,cat,recurso,cantidad,valor,texto};
  renderCartas();
}
function cancelarSeleccion() { selectedCard = null; renderCartas(); }
function updateConfirmBar() {
  const bar = document.getElementById('confirm-bar');
  if(!selectedCard) { bar.classList.remove('visible'); return; }
  bar.classList.add('visible');
  document.getElementById('confirm-txt').innerHTML = `Vas a elegir: <strong>${selectedCard.texto}</strong>`;
}
function confirmarAccion() {
  if(!selectedCard) return;
  const d = selectedCard; selectedCard = null; showLoader();
  google.script.run
    .withSuccessHandler(res=>{
      const bib=g.biblioteca, cat=g.competenciasCatalogo, grp=g.gruposCompetencia;
      g=res;
      if(!g.biblioteca) g.biblioteca=bib;
      if(!g.competenciasCatalogo) g.competenciasCatalogo=cat;
      if(!g.gruposCompetencia) g.gruposCompetencia=grp;
      hideLoader();
      if(res.finalizado) mostrarFinal();
      else if(res.encuentro) mostrarEncuentro(res.nroEncuentro);
      else render();
    })
    .withFailureHandler(e=>{hideLoader();alert(e.message);})
    .procesarAccion(g.estado,d.id,d.cat,d.recurso,d.cantidad,d.valor);
}

/* ── CAPACITACIÓN ── */
function renderBibList() {
  if(!g.biblioteca) return;
  document.getElementById('bib-list').innerHTML = g.biblioteca.map(h => {
    const done = g.estado.herramientas.includes(h.id);
    return `<div class="bib-list-item ${done?'done':''}" onclick="${done?'':`abrirHerramienta('${h.id}')`}">
      <div class="hi-tit">${done?'✅':'📖'} ${h.nombre}</div>
      <div class="hi-sub">${done?'Completado · insignia obtenida':'Clic para estudiar el módulo'}</div>
    </div>`;
  }).join('');
}
function volverABiblioteca() {
  capHerr = null;
  document.getElementById('cap-card-list').style.display = 'block';
  document.getElementById('cap-card-detail').style.display = 'none';
}
function abrirHerrDesdeCarta(id) { go('capacitacion'); abrirHerramienta(id); }
function abrirHerramienta(id) {
  const h = g.biblioteca.find(x=>x.id===id); if(!h) return;
  capHerr = h;
  capPreguntaIndex = 0;
  document.getElementById('cap-card-list').style.display = 'none';
  document.getElementById('cap-card-detail').style.display = 'block';
  document.getElementById('cap-area-badge').innerText = (h.area||'').toUpperCase();
  document.getElementById('cap-tit').innerText = h.nombre;
  document.getElementById('cap-err').style.display = 'none';
  capOpcionSeleccionada = null;
  mostrarPreguntaActual();

  const disponibles = [];
  if(h.videoUrl) disponibles.push('video');
  if(h.infografiaUrl) disponibles.push('infografia');
  disponibles.push('texto');
  capTab = disponibles[0];
  renderCapTabs(disponibles);
  renderCapContenido();

  if(currentScreen!=='capacitacion') go('capacitacion');
}
function renderCapTabs(disponibles) {
  const wrap = document.getElementById('cap-tabs');
  if(disponibles.length <= 1) { wrap.style.display = 'none'; wrap.innerHTML=''; return; }
  const labels = {video:'Video', infografia:'Infografía', texto:'Texto'};
  wrap.style.display = 'flex';
  wrap.innerHTML = disponibles.map(t =>
    `<button class="cap-tab-btn ${t===capTab?'active':''}" onclick="cambiarCapTab('${t}')">${labels[t]}</button>`
  ).join('');
}
function cambiarCapTab(t) {
  capTab = t;
  const disponibles = [];
  if(capHerr.videoUrl) disponibles.push('video');
  if(capHerr.infografiaUrl) disponibles.push('infografia');
  disponibles.push('texto');
  renderCapTabs(disponibles);
  renderCapContenido();
}
function extraerIdYoutube(url) {
  const marcadores = ['v=', 'youtu.be/', 'embed/'];
  for (let i = 0; i < marcadores.length; i++) {
    const idx = url.indexOf(marcadores[i]);
    if (idx > -1) {
      let id = url.substring(idx + marcadores[i].length);
      const amp = id.indexOf('&');
      if (amp > -1) id = id.substring(0, amp);
      return id;
    }
  }
  return '';
}
function embedVideo(url) {
  const esYoutube = url.indexOf('youtube.com') > -1 || url.indexOf('youtu.be') > -1;
  if (esYoutube) {
    const ifr = document.createElement('iframe');
    ifr.setAttribute('src', 'https://www.youtube.com/embed/' + extraerIdYoutube(url));
    ifr.setAttribute('allowfullscreen', 'true');
    return ifr;
  }
  const v = document.createElement('video');
  v.setAttribute('src', url);
  v.setAttribute('controls', 'true');
  return v;
}
function renderCapContenido() {
  const h = capHerr; if(!h) return;
  const el = document.getElementById('cap-cont');
  el.innerHTML = '';
  if(capTab==='video' && h.videoUrl) {
    el.appendChild(embedVideo(h.videoUrl));
  } else if(capTab==='infografia' && h.infografiaUrl) {
    const img = document.createElement('img');
    img.setAttribute('src', h.infografiaUrl);
    img.setAttribute('alt', 'Infografía');
    el.appendChild(img);
  } else {
    el.innerText = h.contenido;
  }
}
function _preguntasDeHerr(h) {
  return h.preguntas && h.preguntas.length
    ? h.preguntas
    : [{ pregunta: h.pregunta || '¿Confirmás la lectura del módulo?', respuesta: h.respuesta || 'si', opciones: h.opciones || [] }];
}
function mostrarPreguntaActual() {
  const h = capHerr; if(!h) return;
  const preguntas = _preguntasDeHerr(h);
  const pq = preguntas[capPreguntaIndex] || preguntas[0];
  const total = preguntas.length;
  document.getElementById('cap-preg').innerText = (total > 1 ? `Pregunta ${capPreguntaIndex + 1} de ${total}: ` : '') + (pq.pregunta || '¿Confirmás la lectura del módulo?');
  document.getElementById('cap-inp').value = '';
  document.getElementById('cap-err').style.display = 'none';
  capOpcionSeleccionada = null;
  renderCapOpciones({ opciones: pq.opciones || [] });
}
function renderCapOpciones(h) {
  const wrap = document.getElementById('cap-opciones');
  const inp = document.getElementById('cap-inp');
  const esMultiple = h.opciones && h.opciones.length >= 2;
  if(!esMultiple) { wrap.style.display = 'none'; wrap.innerHTML = ''; inp.style.display = 'block'; return; }
  inp.style.display = 'none';
  wrap.style.display = 'block';
  wrap.innerHTML = h.opciones.map((op,i) =>
    `<div class="cap-opcion ${capOpcionSeleccionada===i?'selected':''}" onclick="seleccionarOpcionCap(${i})"><div class="cap-opcion-dot"></div><span>${op}</span></div>`
  ).join('');
}
function seleccionarOpcionCap(i) {
  capOpcionSeleccionada = i;
  renderCapOpciones(capHerr);
}
function verificarCapacitacion() {
  if(!capHerr) return;
  const h = capHerr;
  const preguntas = _preguntasDeHerr(h);
  const pq = preguntas[capPreguntaIndex] || preguntas[0];
  const esMultiple = pq.opciones && pq.opciones.length >= 2;
  let correcto;
  if (esMultiple) {
    correcto = capOpcionSeleccionada !== null && (pq.opciones[capOpcionSeleccionada]||'').trim().toLowerCase() === pq.respuesta;
  } else {
    const resp = document.getElementById('cap-inp').value.trim().toLowerCase();
    correcto = resp === pq.respuesta;
  }
  if(!correcto) { document.getElementById('cap-err').style.display = 'block'; return; }
  document.getElementById('cap-err').style.display = 'none';
  capPreguntaIndex++;
  if(capPreguntaIndex < preguntas.length) {
    mostrarPreguntaActual();
    return;
  }
  showLoader();
  google.script.run
    .withSuccessHandler(res=>{ g.estado=res.estado; g.cartas=res.cartas; hideLoader(); volverABiblioteca(); render(); go('situacion'); })
    .withFailureHandler(e=>{hideLoader();alert(e.message);})
    .completarCapacitacion(g.estado, h.id, h.insigniaID);
}

/* ── MODAL REGLAS ── */
function abrirReglas() { document.getElementById('modal-reglas').classList.add('open'); }
function cerrarReglas() { document.getElementById('modal-reglas').classList.remove('open'); }

/* ── ENCUENTRO ── */
function mostrarEncuentro(nro) {
  const info = ENC[nro]||{titulo:'Encuentro Presencial',desc:'Reunite con los otros equipos.'};
  document.getElementById('enc-titulo').innerText = info.titulo;
  document.getElementById('enc-desc').innerText = info.desc;
  document.getElementById('enc-modal').style.display = 'flex';
}
function cerrarEncuentro(){document.getElementById('enc-modal').style.display='none';render();}

/* ── FINAL ── */
function mostrarFinal() {
  google.script.run.withSuccessHandler(p=>{
    document.getElementById('final-equipo').innerText = ('Dirección de '+(g.estado.direccion||'')).toUpperCase();
    document.getElementById('final-score').innerText = p.promedioCompetencias+' / 5';
    document.getElementById('final-nivel').innerText = p.nivel.toUpperCase();
    document.getElementById('final-detail').innerHTML =
      `Puntaje acumulado: <span>${p.puntaje||0}</span><br>Recursos totales: <span>${p.totalRecursos}</span><br>Insignias obtenidas: <span>${p.insignias}</span><br>Competencias fortalecidas: <span>${(p.competenciasFortalecidas||[]).join(', ')||'—'}</span>`;
    document.getElementById('final-screen').style.display='flex';
    google.script.run.guardarResultado(g.estado, p);
  }).calcularPuntajeFinal(g.estado);
}

/* ── RANKING ── */
function cargarRanking() {
  google.script.run
    .withSuccessHandler(function(ranking) {
      const el = document.getElementById('ranking-list');
      if(!el) return;
      if(!ranking || !ranking.length) { el.innerHTML = '<div class="ranking-empty">Sin partidas completadas aún. ¡Sé el primero!</div>'; return; }
      const medals = ['🥇','🥈','🥉'];
      el.innerHTML = ranking.map(function(r,i) {
        const medal = i < 3 ? '<span class="ranking-medal">'+medals[i]+'</span><span class="ranking-pos"></span>' : '<span class="ranking-medal"></span><span class="ranking-pos">'+(i+1)+'°</span>';
        return '<div class="ranking-row">'+medal+'<div class="ranking-name">'+(r.nombre||r.legajo)+'<br><span class="ranking-dir">'+(r.equipo||r.direccion||'')+'</span></div><div class="ranking-score">'+(r.puntaje||0)+'<br><span class="ranking-nivel">'+(r.nivel||'')+'</span></div></div>';
      }).join('');
    })
    .withFailureHandler(function(){})
    .obtenerRanking();
}

/* ── ASISTENTE IA ── */
function preguntarIA() {
  const inp = document.getElementById('ia-input');
  const pregunta = inp ? inp.value.trim() : '';
  if(!pregunta) return;
  const msgs = document.getElementById('ia-msgs');
  if(msgs) { msgs.innerHTML += '<div class="ia-msg user">'+pregunta+'</div>'; msgs.scrollTop = msgs.scrollHeight; }
  if(inp) inp.value = '';
  const btn = document.getElementById('ia-send');
  if(btn) btn.disabled = true;
  if(msgs) { msgs.innerHTML += '<div class="ia-msg bot" id="ia-thinking">Pensando…</div>'; msgs.scrollTop = msgs.scrollHeight; }
  google.script.run
    .withSuccessHandler(function(res) {
      const t = document.getElementById('ia-thinking'); if(t) t.remove();
      if(msgs) { msgs.innerHTML += '<div class="ia-msg bot">'+(res.respuesta||'No pude responder.')+'</div>'; msgs.scrollTop = msgs.scrollHeight; }
      if(btn) btn.disabled = false;
    })
    .withFailureHandler(function() {
      const t = document.getElementById('ia-thinking'); if(t) t.remove();
      if(msgs) msgs.innerHTML += '<div class="ia-msg bot">Error al conectar. Intentá de nuevo.</div>';
      if(btn) btn.disabled = false;
    })
    .consultarAsistenteIA(pregunta);
}

/* ── UTILS ── */
function showLoader(){document.getElementById('loader').style.display='flex';}
function hideLoader(){document.getElementById('loader').style.display='none';}

cargarRanking();
</script>
