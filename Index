<!DOCTYPE html>
<html lang="es">
<head>
  <base target="_top">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <style>
/* ══════════════════════════════════════
   TOKENS — Mapa antiguo de Bariloche
══════════════════════════════════════ */
:root{
  --perg:#ede0ba; --perg-lt:#f8f0d8; --perg-dk:#ceb87a; --perg-mid:#dfd0a0;
  --navy:#1c2e4a; --navy-md:#2a4268; --navy-lt:#3d5f8a;
  --gold:#7a5e1a; --gold-lt:#a07828; --gold-br:#c49030;
  --era1:#2a6a4a; --era2:#1c2e4a; --era3:#7a2020;
  --grn:#2a5024; --red:#8b2020; --teal:#2a6a4a;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Crimson Text',Georgia,serif;background:var(--perg);color:var(--navy);min-height:100vh;overflow:hidden}

/* ── FONDO MAPA (toda la app) — pergamino/mapa antiguo en CSS ── */
#map-bg{
  position:fixed;inset:0;z-index:0;
  background:
    repeating-linear-gradient(60deg, rgba(122,94,26,.04) 0 2px, transparent 2px 26px),
    repeating-linear-gradient(-30deg, rgba(122,94,26,.035) 0 2px, transparent 2px 32px),
    radial-gradient(circle at 28% 32%, transparent 0 70px, rgba(122,94,26,.05) 70px 72px, transparent 72px 130px, rgba(122,94,26,.04) 130px 132px, transparent 132px),
    radial-gradient(circle at 74% 66%, transparent 0 60px, rgba(42,106,74,.05) 60px 62px, transparent 62px 120px, rgba(42,106,74,.04) 120px 122px, transparent 122px),
    radial-gradient(ellipse at 20% 25%, rgba(206,184,122,.45), transparent 55%),
    radial-gradient(ellipse at 85% 75%, rgba(122,94,26,.20), transparent 55%),
    linear-gradient(135deg, #f1e6c4 0%, #e3d3a3 45%, #d3bd7e 100%);
}

/* ── LOADER ── */
#loader{display:none;position:fixed;inset:0;z-index:9000;background:rgba(232,213,163,.94);align-items:center;justify-content:center;}
.loader-inn{background:var(--navy);border:2px solid var(--gold-br);padding:22px 38px;}
.loader-txt{font-family:'Cinzel',serif;font-size:11px;letter-spacing:5px;color:var(--perg);animation:pulse 1.2s infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* avatar reutilizable */
.avatar{border-radius:50%;background:linear-gradient(135deg,var(--gold-lt),var(--gold-br));color:var(--navy);
  display:flex;align-items:center;justify-content:center;font-family:'Cinzel',serif;font-weight:900;flex-shrink:0;
  border:2px solid var(--gold-br);overflow:hidden;}

/* ══════════════════════════════════════
   PANTALLA 1: BIENVENIDA + TABLERO
══════════════════════════════════════ */
#screen-welcome{position:fixed;inset:0;z-index:100;display:flex;flex-direction:column;overflow:hidden;}
.hdr-welcome{background:rgba(28,46,74,.97);border-bottom:3px solid var(--gold-br);padding:10px 28px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;position:relative;z-index:2;}
.logo-grp{display:flex;align-items:center;gap:12px;}
.logo-ico{font-size:22px;}
.game-nm{font-family:'Cinzel',serif;font-size:22px;font-weight:900;letter-spacing:5px;color:var(--perg);line-height:1;}
.game-sub{font-family:'Cinzel',serif;font-size:7px;letter-spacing:3px;color:var(--perg-dk);text-transform:uppercase;margin-top:2px;}
.hdr-tag{font-family:'Cinzel',serif;font-size:7px;letter-spacing:2px;color:var(--perg-dk);text-align:right;line-height:1.9;}
.welcome-body{flex:1;display:flex;overflow:hidden;position:relative;z-index:1;}
.tablero-fondo{flex:1;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;}
.tablero-fondo::after{content:'';position:absolute;inset:0;background:rgba(237,224,186,.25);pointer-events:none;}
#tablero-svg{width:100%;height:100%;position:absolute;inset:0;}

.welcome-card{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:10;width:390px;background:rgba(237,224,186,.97);border:2px solid rgba(28,46,74,.3);border-top:4px solid var(--gold-br);box-shadow:0 8px 40px rgba(28,46,74,.35);padding:28px 30px 24px;}
.reg-eyebrow{font-family:'Cinzel',serif;font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:6px;display:flex;align-items:center;gap:6px;}
.reg-eyebrow::after{content:'';flex:1;height:1px;background:var(--gold);opacity:.3;}
.reg-h1{font-family:'Cinzel',serif;font-size:20px;font-weight:900;color:var(--navy);line-height:1.2;margin-bottom:6px;}
.reg-p{font-size:13px;line-height:1.6;color:var(--navy-md);margin-bottom:16px;}
.legajo-box{background:rgba(255,255,255,.6);border:2px solid rgba(28,46,74,.2);padding:14px 16px;margin-bottom:14px;}
.legajo-lbl{font-family:'Cinzel',serif;font-size:8px;letter-spacing:2.5px;text-transform:uppercase;color:var(--navy-md);margin-bottom:8px;display:block;}
.legajo-row{display:flex;gap:8px;}
.legajo-inp{flex:1;padding:11px 14px;background:rgba(255,255,255,.8);border:1.5px solid rgba(28,46,74,.3);font-family:'Cinzel',serif;font-size:16px;font-weight:700;color:var(--navy);outline:none;letter-spacing:2px;transition:.18s;}
.legajo-inp:focus{border-color:var(--gold-br);background:white;}
.legajo-inp::placeholder{color:#b0a070;font-weight:400;font-size:13px;letter-spacing:.5px;}
.btn-validar{padding:11px 18px;background:var(--navy);color:var(--perg);border:2px solid var(--gold-br);font-family:'Cinzel',serif;font-size:11px;font-weight:700;letter-spacing:2px;cursor:pointer;transition:.18s;white-space:nowrap;}
.btn-validar:hover{background:var(--gold-br);color:var(--navy);}
.legajo-status{font-size:12px;margin-top:8px;min-height:16px;}
.legajo-status.ok{color:var(--grn);font-weight:700;}
.legajo-status.err{color:var(--red);}
.legajo-status.loading{color:var(--navy-md);font-style:italic;}
.agente-card{display:none;background:rgba(28,46,74,.07);border:1px solid rgba(28,46,74,.2);padding:12px 14px;margin-top:10px;align-items:center;gap:12px;}
.agente-card.visible{display:flex;}
.ac-txt{flex:1;}
.ac-nombre{font-family:'Cinzel',serif;font-size:14px;font-weight:700;color:var(--navy);margin-bottom:2px;}
.ac-info{font-size:13px;color:var(--navy-md);margin-bottom:4px;}
.ac-equipo-nm{font-family:'Cinzel',serif;font-size:12px;font-weight:700;color:var(--teal);}
.btn-comenzar{width:100%;padding:13px;background:var(--teal);color:var(--perg-lt);border:2px solid rgba(42,106,74,.4);font-family:'Cinzel',serif;font-size:14px;font-weight:700;letter-spacing:4px;cursor:pointer;transition:.18s;margin-top:10px;}
.btn-comenzar:hover{background:var(--navy);border-color:var(--gold-br);}
.card-footer{display:flex;justify-content:center;margin-top:14px;}
.btn-reglas{background:none;border:none;font-family:'Cinzel',serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);cursor:pointer;padding:4px 8px;text-decoration:underline;text-underline-offset:3px;}
.btn-reglas:hover{color:var(--navy);}

/* ── MODAL REGLAS ── */
#modal-reglas{display:none;position:fixed;inset:0;z-index:5000;background:rgba(28,46,74,.75);align-items:center;justify-content:center;}
#modal-reglas.open{display:flex;}
.reglas-box{background:var(--perg-lt);border:3px solid var(--navy);border-top:5px solid var(--gold-br);max-width:520px;width:90%;max-height:80vh;overflow-y:auto;padding:30px 36px;}
.reglas-box h3{font-family:'Cinzel',serif;font-size:16px;font-weight:900;color:var(--navy);letter-spacing:2px;margin-bottom:20px;border-bottom:2px solid var(--perg-dk);padding-bottom:10px;}
.rule-it{display:flex;gap:12px;margin-bottom:14px;}
.rule-n{font-family:'Cinzel',serif;font-size:20px;color:var(--gold-br);flex-shrink:0;width:24px;font-weight:700;}
.rule-it p{font-size:14px;line-height:1.65;color:var(--navy-md);padding-top:2px;}
.rule-it p strong{color:var(--navy);}
.rules-hr{height:1px;background:var(--perg-dk);margin:14px 0;}
.btn-cerrar-reglas{width:100%;padding:12px;margin-top:20px;background:var(--navy);color:var(--perg);border:2px solid var(--gold-br);font-family:'Cinzel',serif;font-size:11px;font-weight:700;letter-spacing:3px;cursor:pointer;transition:.18s;}
.btn-cerrar-reglas:hover{background:var(--gold-br);color:var(--navy);}

/* ══════════════════════════════════════
   PANTALLA 2: PRESENTACIÓN DEL AGENTE
══════════════════════════════════════ */
#screen-agente{display:none;position:fixed;inset:0;z-index:200;background:rgba(28,46,74,.88);align-items:center;justify-content:center;overflow-y:auto;padding:20px;}
.agente-presentacion{background:var(--perg-lt);border:3px solid var(--navy);border-top:5px solid var(--gold-br);max-width:840px;width:100%;padding:32px 40px;}
.ap-grid{display:grid;grid-template-columns:auto 1fr auto;gap:24px;align-items:center;margin-bottom:24px;}
.ap-avatar{width:84px;height:84px;font-size:30px;}
.ap-eyebrow{font-family:'Cinzel',serif;font-size:8px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:5px;}
.ap-nombre{font-family:'Cinzel',serif;font-size:26px;font-weight:900;color:var(--navy);letter-spacing:1px;line-height:1.1;margin-bottom:4px;}
.ap-legajo{font-size:14px;color:var(--navy-md);margin-bottom:4px;}
.ap-dir{font-size:14px;color:var(--navy-md);}
.ap-equipo-badge{display:inline-block;margin-top:8px;padding:5px 16px;background:var(--navy);border:2px solid var(--gold-br);font-family:'Cinzel',serif;font-size:12px;font-weight:700;letter-spacing:3px;color:var(--perg);}
.ap-equipo-panel{background:rgba(28,46,74,.06);border:1.5px solid rgba(28,46,74,.2);padding:14px 18px;min-width:160px;text-align:center;}
.ap-eq-lbl{font-family:'Cinzel',serif;font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:8px;}
.ap-mision{background:rgba(28,46,74,.06);border:1px solid rgba(28,46,74,.15);padding:14px 18px;margin-bottom:20px;font-size:14px;line-height:1.75;color:var(--navy-md);}
.ap-mision strong{color:var(--gold-br);}
.ap-inds{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:22px;}
.ind-c{background:var(--perg);border:1.5px solid rgba(28,46,74,.15);padding:10px 6px;text-align:center;}
.ind-ico{font-size:18px;margin-bottom:3px;}
.ind-lbl{font-family:'Cinzel',serif;font-size:7px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:5px;}
.ind-val100{font-family:'Cinzel',serif;font-size:13px;font-weight:700;color:var(--navy);}
.btn-empezar{padding:13px 52px;background:var(--navy);color:var(--perg);border:2px solid var(--gold-br);font-family:'Cinzel',serif;font-size:14px;font-weight:700;letter-spacing:5px;cursor:pointer;transition:.2s;display:block;margin:0 auto;}
.btn-empezar:hover{background:var(--gold-br);color:var(--navy);}

/* ══════════════════════════════════════
   PANTALLA 3: DASHBOARD
══════════════════════════════════════ */
#app{display:none;position:relative;z-index:10;height:100vh;
  grid-template-columns:200px 1fr 230px;grid-template-rows:50px 54px 1fr;gap:4px;padding:4px;}
.app-hdr{grid-column:1/4;background:rgba(28,46,74,.97);border-bottom:3px solid var(--gold-br);display:flex;align-items:center;justify-content:space-between;padding:0 16px;}
.app-hdr-left{display:flex;align-items:center;gap:12px;}
.app-logo{font-family:'Cinzel',serif;font-size:16px;font-weight:900;letter-spacing:5px;color:var(--perg);}
.app-dir{font-family:'Cinzel',serif;font-size:8px;font-weight:600;letter-spacing:2px;color:var(--perg);padding:3px 9px;border:1px solid rgba(196,144,48,.4);text-transform:uppercase;}
/* progreso de era en el header */
.hdr-prog{display:flex;align-items:center;gap:10px;}
.prog-dots{display:flex;align-items:center;gap:5px;}
.pdot{width:9px;height:9px;border-radius:50%;background:rgba(237,224,186,.3);border:1px solid var(--gold-br);}
.pdot.done{background:var(--gold-br);}
.pdot.active{background:var(--perg);box-shadow:0 0 7px var(--gold-br);}
.hdr-prog-txt{font-family:'Cinzel',serif;font-size:8px;letter-spacing:2px;color:var(--perg-dk);}
.hdr-pct{font-family:'Cinzel',serif;font-size:11px;font-weight:700;color:var(--gold-br);background:rgba(196,144,48,.15);border:1px solid var(--gold-br);border-radius:20px;padding:3px 11px;}
/* jugador en header */
.app-hdr-avatar{display:flex;align-items:center;gap:10px;}
.hdr-av{width:34px;height:34px;font-size:13px;}
.hdr-player-info{font-family:'Cinzel',serif;font-size:8px;letter-spacing:1px;color:var(--perg-dk);text-align:right;line-height:1.6;}
.hdr-player-info strong{color:var(--perg);font-size:10px;display:block;}
.hdr-pts{color:var(--gold-br);}
.hdr-lvl{display:inline-block;background:var(--teal);color:var(--perg-lt);font-size:7px;letter-spacing:1px;padding:1px 6px;border-radius:10px;margin-left:4px;}

/* ── TABLERO DE ERAS ── */
.era-board{grid-column:1/4;position:relative;border:2px solid rgba(28,46,74,.45);display:flex;align-items:center;padding:0 10px;gap:0;overflow:hidden;min-height:54px;}
.era-board::before{content:'';position:absolute;inset:0;z-index:0;
  background:radial-gradient(ellipse at 15% 50%, rgba(206,184,122,.5), transparent 60%),linear-gradient(90deg,#e8dab0,#d8c690);opacity:.6;}
.era-board::after{content:'';position:absolute;inset:0;z-index:1;background:rgba(237,224,186,.62);}
.era-board>*{position:relative;z-index:2;}
.sb{font-family:'Cinzel',serif;font-size:8px;font-weight:700;letter-spacing:2px;padding:5px 8px;background:var(--navy);color:var(--perg);white-space:nowrap;flex-shrink:0;border:1px solid var(--gold-br);}
.eb{font-family:'Cinzel',serif;font-size:8px;font-weight:700;letter-spacing:2px;padding:5px 8px;background:var(--gold-br);color:var(--navy);white-space:nowrap;flex-shrink:0;}
.enc-b{font-family:'Cinzel',serif;font-size:7px;font-weight:700;letter-spacing:1px;padding:3px 7px;background:rgba(28,46,74,.12);color:var(--navy);border:1px solid rgba(28,46,74,.25);white-space:nowrap;flex-shrink:0;}
.era-blk{display:flex;align-items:center;flex:1;}
.era-lbl{font-family:'Cinzel',serif;font-size:7px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:0 5px;flex-shrink:0;white-space:nowrap;}
.era-lbl.e1{color:var(--era1);}.era-lbl.e2{color:var(--era2);}.era-lbl.e3{color:var(--era3);}
.era-nds{display:flex;align-items:center;flex:1;}
.esep{width:1px;height:32px;background:rgba(28,46,74,.2);margin:0 6px;flex-shrink:0;}
.node{width:30px;height:30px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:'Cinzel',serif;font-size:9px;font-weight:700;transition:all .35s;cursor:default;border:2.5px solid;background:rgba(237,224,186,.92);box-shadow:0 1px 5px rgba(28,46,74,.22);}
.node.n1{border-color:var(--era1);color:var(--era1);}
.node.n1.done{background:var(--era1);border-color:var(--era1);color:white;}
.node.n1.active{background:var(--era1);border-color:var(--gold-br);color:white;transform:scale(1.25);box-shadow:0 0 12px rgba(42,106,74,.55);}
.node.n2{border-color:var(--era2);color:var(--era2);}
.node.n2.done{background:var(--era2);border-color:var(--era2);color:var(--perg);}
.node.n2.active{background:var(--era2);border-color:var(--gold-br);color:var(--perg);transform:scale(1.25);box-shadow:0 0 12px rgba(28,46,74,.55);}
.node.n3{border-color:var(--era3);color:var(--era3);}
.node.n3.done{background:var(--era3);border-color:var(--era3);color:white;}
.node.n3.active{background:var(--era3);border-color:var(--gold-br);color:white;transform:scale(1.25);box-shadow:0 0 12px rgba(122,32,32,.55);}
.nl{flex:1;height:2px;min-width:3px;max-width:16px;opacity:.4;}
.nl1{background:var(--era1);}.nl2{background:var(--era2);}.nl3{background:var(--era3);}

/* Paneles laterales */
.panel{background:rgba(237,224,186,.96);border:2px solid rgba(28,46,74,.28);overflow-y:auto;}
.phdr{background:var(--navy);color:var(--perg);font-family:'Cinzel',serif;font-size:8px;font-weight:700;letter-spacing:3px;padding:6px 12px;flex-shrink:0;}
.pbody{padding:10px 12px;}
.left-p{grid-row:3/4;}.right-p{grid-row:3/4;}
.center-p{grid-row:3/4;background:rgba(237,224,186,.96);border:2px solid rgba(28,46,74,.28);display:flex;flex-direction:column;overflow:hidden;}

/* Mini avatar panel izq */
.mini-agente{display:flex;align-items:center;gap:10px;padding-bottom:10px;border-bottom:1px solid var(--perg-dk);margin-bottom:10px;}
.mini-av{width:42px;height:42px;font-size:15px;}
.mini-nm{font-family:'Cinzel',serif;font-size:11px;font-weight:700;color:var(--navy);}
.mini-dir{font-size:11px;color:var(--navy-md);font-style:italic;}
.mini-equipo{font-family:'Cinzel',serif;font-size:10px;font-weight:700;color:var(--teal);}

/* Indicadores X/100 */
.stat{margin-bottom:9px;}
.stat-row{display:flex;justify-content:space-between;margin-bottom:3px;align-items:center;}
.stat-lbl{font-family:'Cinzel',serif;font-size:7px;letter-spacing:1.5px;text-transform:uppercase;color:var(--navy-md);}
.stat-val{font-family:'Cinzel',serif;font-size:9px;font-weight:700;color:var(--navy);}
.bar-bg{height:5px;background:var(--perg-dk);border-radius:3px;overflow:hidden;}
.bar-fg{height:100%;transition:width .6s;border-radius:3px;}
.bc1{background:#c84060;}.bc2{background:var(--gold-br);}.bc3{background:var(--grn);}.bc4{background:var(--teal);}

/* RANKING */
.rank-row{display:flex;align-items:center;gap:8px;padding:6px 4px;border-bottom:1px solid var(--perg-dk);}
.rank-row:last-child{border-bottom:none;}
.rank-row.me{background:var(--navy);margin:2px -8px;padding:7px 12px;border-radius:3px;}
.rank-row.me .rk-nm,.rank-row.me .rk-pos{color:var(--perg);}
.rank-row.me .rk-dir{color:var(--perg-dk);}
.rank-row.me .rk-pts{color:var(--gold-br);}
.rk-pos{font-family:'Cinzel',serif;font-size:11px;font-weight:700;color:var(--gold);width:18px;text-align:center;flex-shrink:0;}
.rk-pos.medal{font-size:13px;}
.rk-info{flex:1;min-width:0;}
.rk-nm{font-family:'Cinzel',serif;font-size:10px;font-weight:700;color:var(--navy);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.rk-dir{font-size:9px;color:var(--navy-md);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.rk-pts{font-family:'Cinzel',serif;font-size:10px;font-weight:700;color:var(--navy);flex-shrink:0;}
.rank-sep{text-align:center;color:var(--navy-md);font-size:12px;line-height:.6;padding:2px 0;}

/* Situación */
.sit-box{padding:13px 14px 10px;border-bottom:2px solid rgba(28,46,74,.15);flex-shrink:0;}
.sit-tipo{font-family:'Cinzel',serif;font-size:8px;font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-bottom:5px;}
.sit-tipo.situacion{color:var(--teal);}.sit-tipo.crisis{color:var(--red);}.sit-tipo.final{color:var(--gold-br);}
.sit-tit{font-family:'Cinzel',serif;font-size:15px;font-weight:700;color:var(--navy);margin-bottom:6px;line-height:1.3;}
.sit-desc{font-size:13px;line-height:1.6;color:var(--navy-md);}

/* Biblioteca */
.bib-tog{padding:7px 13px;border-bottom:1px solid rgba(28,46,74,.12);font-family:'Cinzel',serif;font-size:8px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--navy);cursor:pointer;display:flex;justify-content:space-between;align-items:center;background:var(--perg-mid);flex-shrink:0;transition:.15s;}
.bib-tog:hover{background:var(--navy);color:var(--perg);}
.bib-panel{display:none;border-bottom:2px solid rgba(28,46,74,.15);max-height:150px;overflow-y:auto;flex-shrink:0;}
.hi{padding:8px 13px;border-bottom:1px solid var(--perg-dk);cursor:pointer;font-size:12px;border-left:3px solid transparent;transition:.15s;}
.hi:hover{background:var(--perg);border-left-color:var(--gold-br);}
.hi.done{border-left-color:var(--grn);color:#557;cursor:default;}
.hi-tit{font-family:'Cinzel',serif;font-size:10px;font-weight:700;color:var(--navy);margin-bottom:1px;}
.hi-sub{font-size:10px;color:var(--navy-md);}

/* CARTAS */
.cards-area{flex:1;overflow-y:auto;padding:10px 11px;}
.cards-lbl{font-family:'Cinzel',serif;font-size:7px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:8px;text-align:center;}
.cards-grid{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;}
.card{width:162px;background:var(--perg-lt);border:2px solid rgba(28,46,74,.28);cursor:pointer;font-size:12px;text-align:left;transition:all .22s;position:relative;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 3px 10px rgba(28,46,74,.14);}
.card:hover:not(.locked){transform:translateY(-6px) scale(1.025);box-shadow:0 12px 28px rgba(28,46,74,.24);border-color:var(--gold-br);}
.card-head{padding:8px 10px;display:flex;align-items:center;gap:7px;flex-shrink:0;border-bottom:1px solid rgba(28,46,74,.15);}
.card-head-icon{width:28px;height:28px;border-radius:50%;border:2px solid rgba(255,255,255,.5);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;background:rgba(255,255,255,.25);}
.card-head-info{flex:1;min-width:0;}
.card-cat{font-family:'Cinzel',serif;font-size:7px;font-weight:700;letter-spacing:2px;text-transform:uppercase;opacity:.85;}
.card-tipo-badge{font-family:'Cinzel',serif;font-size:7px;font-weight:600;letter-spacing:1px;text-transform:uppercase;padding:1px 6px;border:1px solid;display:inline-block;margin-top:1px;}
.card-body{padding:9px 10px;flex:1;}
.card-txt{font-size:12px;line-height:1.45;color:var(--navy);}
.card-foot{padding:7px 10px;border-top:1px solid rgba(28,46,74,.1);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.card-reward{font-family:'Cinzel',serif;font-size:9px;font-weight:700;}
.card-arr{font-size:12px;color:var(--gold);opacity:.45;transition:.18s;}
.card:hover:not(.locked) .card-arr{opacity:1;transform:translateX(3px);}
.cc-com .card-head{background:linear-gradient(135deg,#2a6a4a,#1a5a3a);}
.cc-com .card-cat{color:rgba(255,255,255,.9);}
.cc-com .card-tipo-badge{color:rgba(255,255,255,.85);border-color:rgba(255,255,255,.35);}
.cc-com .card-reward{color:#2a6a4a;}
.cc-lid .card-head{background:linear-gradient(135deg,#1c2e4a,#0e1e34);}
.cc-lid .card-head-icon{border-color:rgba(196,144,48,.5);}
.cc-lid .card-cat{color:var(--perg);}
.cc-lid .card-tipo-badge{color:var(--gold-br);border-color:rgba(196,144,48,.4);}
.cc-lid .card-reward{color:#1c2e4a;}
.cc-bien .card-head{background:linear-gradient(135deg,#2a5024,#1a3a18);}
.cc-bien .card-cat{color:rgba(255,255,255,.9);}
.cc-bien .card-tipo-badge{color:rgba(255,255,255,.85);border-color:rgba(255,255,255,.35);}
.cc-bien .card-reward{color:#2a5024;}
.cc-plan .card-head{background:linear-gradient(135deg,#6b4423,#4a2e14);}
.cc-plan .card-cat{color:rgba(255,255,255,.9);}
.cc-plan .card-tipo-badge{color:rgba(255,255,255,.85);border-color:rgba(255,255,255,.35);}
.cc-plan .card-reward{color:#6b4423;}
.cc-def .card-head{background:linear-gradient(135deg,#2a4268,#1a2e54);}
.cc-def .card-head-icon{border-color:rgba(196,144,48,.5);}
.cc-def .card-cat{color:var(--perg);}
.cc-def .card-tipo-badge{color:var(--gold-br);border-color:rgba(196,144,48,.4);}
.cc-def .card-reward{color:#2a4268;}
.tipo-prof{background:rgba(28,46,74,.1);color:var(--navy-md);border-color:rgba(28,46,74,.2);}
.tipo-bas{background:rgba(160,80,20,.1);color:#884010;border-color:rgba(160,80,20,.25);}
.cc-com .tipo-prof,.cc-lid .tipo-prof,.cc-bien .tipo-prof,.cc-plan .tipo-prof{background:rgba(255,255,255,.15);color:white;border-color:rgba(255,255,255,.3);}
.cc-com .tipo-bas,.cc-lid .tipo-bas,.cc-bien .tipo-bas,.cc-plan .tipo-bas{background:rgba(255,200,100,.2);color:#ffd080;border-color:rgba(255,200,100,.4);}
.card.locked{background:var(--perg-mid);border:2px dashed rgba(28,46,74,.2);cursor:pointer;opacity:.72;}
.card.locked:hover{opacity:1;border-color:var(--gold-br);transform:translateY(-3px);box-shadow:0 8px 20px rgba(28,46,74,.18);}
.lock-badge{position:absolute;top:8px;right:8px;background:var(--navy);color:var(--perg);font-family:'Cinzel',serif;font-size:7px;letter-spacing:1px;padding:2px 6px;text-transform:uppercase;border:1px solid var(--gold-br);}
.unlock-h{font-family:'Cinzel',serif;font-size:8px;font-weight:700;letter-spacing:1px;color:var(--gold);text-transform:uppercase;margin-top:4px;}
.unlock-s{font-size:10px;color:var(--navy-md);margin-top:2px;}

/* Recursos */
.res-row{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--perg-dk);}
.res-row:last-child{border-bottom:none;}
.rdot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
.rinfo{flex:1;}
.rnm{font-family:'Cinzel',serif;font-size:8px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;}
.rsub{font-size:10px;color:var(--navy-md);line-height:1.3;}
.rval{font-family:'Cinzel',serif;font-size:20px;font-weight:700;color:var(--navy);min-width:26px;text-align:right;}
.ins-row{display:flex;flex-wrap:wrap;gap:5px;padding-top:3px;}
.ins-badge{width:34px;height:34px;border-radius:50%;border:2px solid var(--gold-br);display:flex;align-items:center;justify-content:center;font-size:16px;background:var(--perg);cursor:default;transition:.15s;}
.ins-badge:hover{transform:scale(1.1);}

/* MODAL CAPACITACIÓN / ACCIÓN */
#modal{display:none;position:fixed;inset:0;z-index:500;background:rgba(28,46,74,.85);align-items:center;justify-content:center;}
.modal-box{background:var(--perg-lt);border:3px solid var(--navy);border-top:5px solid var(--gold-br);max-width:600px;width:96%;padding:0;max-height:92vh;overflow-y:auto;}
.modal-hdr{background:var(--navy);padding:16px 22px;display:flex;align-items:center;gap:12px;}
.modal-hdr-ico{font-size:24px;}
.modal-hdr-titulo{font-family:'Cinzel',serif;font-size:14px;font-weight:900;color:var(--perg);letter-spacing:1px;}
.modal-hdr-sub{font-family:'Cinzel',serif;font-size:8px;letter-spacing:3px;color:var(--gold-br);text-transform:uppercase;margin-top:2px;}
.modal-body{padding:20px 24px;}
.modal-badge{display:inline-block;background:rgba(28,46,74,.08);border:1px solid rgba(28,46,74,.2);padding:3px 13px;font-family:'Cinzel',serif;font-size:8px;letter-spacing:2px;color:var(--navy-md);text-transform:uppercase;margin-bottom:12px;}
/* tabs estilo microlearning */
.ml-tabs{display:flex;gap:6px;margin-bottom:12px;}
.ml-tab{flex:1;text-align:center;font-family:'Cinzel',serif;font-size:8px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:6px;border:1px solid rgba(28,46,74,.2);background:var(--perg);color:var(--navy-md);cursor:pointer;transition:.15s;}
.ml-tab.active{background:var(--navy);color:var(--perg);border-color:var(--navy);}
.ml-video{background:#0e1622;border:1px solid rgba(28,46,74,.4);border-radius:4px;height:170px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;position:relative;overflow:hidden;}
.ml-video .play{width:54px;height:54px;border-radius:50%;background:rgba(255,255,255,.9);display:flex;align-items:center;justify-content:center;font-size:22px;color:var(--navy);box-shadow:0 4px 18px rgba(0,0,0,.4);}
.ml-video .vlabel{position:absolute;bottom:8px;left:10px;font-family:'Cinzel',serif;font-size:8px;letter-spacing:1px;color:rgba(255,255,255,.65);}
.modal-cont{font-size:14px;line-height:1.8;color:var(--navy-md);margin-bottom:16px;background:rgba(255,255,255,.5);border:1px solid rgba(28,46,74,.1);padding:12px 14px;}
.modal-preg{font-family:'Cinzel',serif;font-size:11px;letter-spacing:.5px;color:var(--navy);margin-bottom:10px;font-weight:700;}
.modal-preg .qnum{display:block;font-size:8px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:4px;}
.modal-inp{width:100%;padding:11px 14px;background:var(--perg);border:2px solid rgba(28,46,74,.3);font-family:'Cinzel',serif;font-size:13px;color:var(--navy);outline:none;margin-bottom:14px;transition:.18s;}
.modal-inp:focus{border-color:var(--gold-br);}
.modal-btns{display:flex;gap:9px;justify-content:flex-end;}
.mbtn{padding:10px 26px;font-family:'Cinzel',serif;font-size:11px;font-weight:700;letter-spacing:2px;cursor:pointer;transition:.18s;border:2px solid var(--navy);}
.mbtn.prim{background:var(--navy);color:var(--perg);}
.mbtn.prim:hover{background:var(--gold-br);color:var(--navy);border-color:var(--gold-br);}
.mbtn.sec{background:transparent;color:var(--navy);}
.mbtn.sec:hover{background:var(--perg-dk);}
.modal-accion-preview{background:rgba(28,46,74,.06);border:1px solid rgba(28,46,74,.15);padding:12px 16px;margin-bottom:16px;display:flex;align-items:center;gap:12px;}
.map-ico{font-size:28px;flex-shrink:0;}
.map-cat{font-family:'Cinzel',serif;font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:3px;}
.map-txt{font-size:14px;color:var(--navy);line-height:1.4;}
.map-efecto{font-family:'Cinzel',serif;font-size:10px;color:var(--teal);margin-top:4px;font-weight:700;}

/* RESULTADO de la acción */
#res-modal{display:none;position:fixed;inset:0;z-index:560;background:rgba(28,46,74,.88);align-items:center;justify-content:center;}
.res-box{background:var(--perg-lt);border:3px solid var(--navy);border-top:5px solid var(--gold-br);max-width:440px;width:94%;padding:30px 32px;text-align:center;}
.res-check{width:64px;height:64px;border-radius:50%;background:var(--grn);color:white;font-size:30px;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;}
.res-box h2{font-family:'Cinzel',serif;font-size:20px;font-weight:900;color:var(--navy);letter-spacing:1px;margin-bottom:4px;}
.res-box .res-sub{font-size:13px;color:var(--navy-md);margin-bottom:18px;}
.res-deltas{text-align:left;background:rgba(28,46,74,.05);border:1px solid rgba(28,46,74,.12);padding:12px 14px;margin-bottom:18px;}
.res-d-lbl{font-family:'Cinzel',serif;font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:8px;}
.res-d-row{display:flex;justify-content:space-between;align-items:center;font-size:13px;padding:3px 0;color:var(--navy-md);}
.res-d-val{font-family:'Cinzel',serif;font-weight:700;}
.res-d-val.up{color:var(--grn);}.res-d-val.zero{color:var(--navy-md);opacity:.6;}.res-d-val.down{color:var(--red);}

/* NUEVA CARTA DESBLOQUEADA */
#unlock-modal{display:none;position:fixed;inset:0;z-index:620;background:rgba(28,46,74,.93);align-items:center;justify-content:center;}
.unlock-box{background:var(--navy);border:3px solid var(--gold-br);max-width:460px;width:94%;padding:34px;text-align:center;box-shadow:0 0 60px rgba(196,144,48,.35);}
.unlock-tag{font-family:'Cinzel',serif;font-size:9px;letter-spacing:4px;text-transform:uppercase;color:var(--gold-br);margin-bottom:14px;}
.unlock-card-vis{background:var(--perg-lt);border:2px solid var(--gold-br);width:180px;margin:0 auto 16px;padding:18px 14px;}
.unlock-card-ico{width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,var(--gold-lt),var(--gold-br));display:flex;align-items:center;justify-content:center;font-size:26px;margin:0 auto 10px;}
.unlock-card-nm{font-family:'Cinzel',serif;font-size:13px;font-weight:700;color:var(--navy);line-height:1.3;}
.unlock-box h2{font-family:'Cinzel',serif;font-size:18px;font-weight:900;color:var(--perg);letter-spacing:1px;margin-bottom:8px;}
.unlock-box p{font-size:13px;line-height:1.6;color:var(--perg-dk);margin-bottom:20px;}

/* ENCUENTRO */
#enc-modal{display:none;position:fixed;inset:0;z-index:600;background:rgba(28,46,74,.93);align-items:center;justify-content:center;}
.enc-box{background:var(--navy);border:3px solid var(--gold-br);max-width:500px;width:96%;padding:40px;text-align:center;}
.enc-ico{font-size:44px;margin-bottom:12px;}
.enc-tag{font-family:'Cinzel',serif;font-size:8px;letter-spacing:4px;text-transform:uppercase;color:var(--gold-br);margin-bottom:8px;}
.enc-box h2{font-family:'Cinzel',serif;font-size:20px;font-weight:900;color:var(--perg);margin-bottom:12px;letter-spacing:2px;}
.enc-box p{font-size:15px;line-height:1.7;color:var(--perg-dk);margin-bottom:20px;}

/* FINAL */
#final-screen{display:none;position:fixed;inset:0;z-index:700;background:var(--navy);align-items:center;justify-content:center;}
.final-box{background:var(--perg-lt);border:4px solid var(--gold-br);max-width:540px;width:97%;padding:44px;text-align:center;}
.final-tag{font-family:'Cinzel',serif;font-size:9px;letter-spacing:5px;text-transform:uppercase;color:var(--gold);margin-bottom:7px;}
.final-box h1{font-family:'Cinzel',serif;font-size:30px;font-weight:900;color:var(--navy);letter-spacing:3px;margin-bottom:6px;}
.final-score{font-family:'Cinzel',serif;font-size:58px;font-weight:900;color:var(--gold-br);line-height:1;margin:10px 0;}
.final-nivel{font-family:'Cinzel',serif;font-size:12px;letter-spacing:5px;text-transform:uppercase;color:var(--navy-md);margin-bottom:13px;}
.final-detail{font-family:'Cinzel',serif;font-size:11px;letter-spacing:1px;color:var(--navy-md);margin-top:12px;line-height:2.3;}
.final-detail span{color:var(--navy);font-weight:700;}

::-webkit-scrollbar{width:5px;}::-webkit-scrollbar-track{background:var(--perg);}::-webkit-scrollbar-thumb{background:rgba(28,46,74,.3);border-radius:3px;}
