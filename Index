<script>
const IND = {
  clima:{lbl:'CLIMA DEL EQUIPO',icon:'❤️',bar:'bc1'},
  desempenio:{lbl:'DESEMPEÑO',icon:'🎯',bar:'bc2'},
  desarrollo:{lbl:'DESARROLLO',icon:'📚',bar:'bc3'},
  recursos:{lbl:'GESTIÓN DE RECURSOS',icon:'💰',bar:'bc4'}
};
const ENC = {
  2:{titulo:'Encuentro 1 · Era I Completada',desc:'Completaste la Organización del Trabajo (casilleros 1–4). Reunite con los otros equipos para compartir aprendizajes y llevar los recursos obtenidos.'},
  3:{titulo:'Encuentro 2 · Era II Completada',desc:'Completaste la Gestión del Desempeño (casilleros 5–8). Nueva reunión grupal para evaluar el avance e integrar herramientas de gestión.'}
};
/* Ranking base (demo). El jugador se inserta y ordena en vivo. */
const RANKING_BASE = [
  {n:'María López',     d:'Dirección de Obras',  pts:2350},
  {n:'Juan Pérez',      d:'Desarrollo Humano',   pts:2180},
  {n:'Ana García',      d:'Secretaría Legal',    pts:1980},
  {n:'Lucas Martínez',  d:'Planificación',       pts:1680},
  {n:'Sofía Romero',    d:'Tránsito',            pts:1420},
  {n:'Diego Funes',     d:'Servicios Públicos',  pts:1190}
];

let g=null, modalData=null, bibOpen=false, agenteData=null;
let prevSnapshot=null;   // para calcular impacto de la acción
let prevCartas=null;     // para detectar cartas desbloqueadas

/* ── Nombre de equipo por dirección ── */
function getEquipo(direccion){
  const equipos={
    'Hacienda':'LOS CÓNDORES','Servicios Públicos':'LOS PUMAS','Capital Humano':'LOS HUEMULES',
    'Obras Particulares':'LOS GUANACOS','Tránsito':'LOS ZORROS','Promoción Social':'LOS PINGÜINOS'
  };
  return equipos[direccion]||'EQUIPO '+(direccion||'').toUpperCase().slice(0,8);
}
function iniciales(nombre){
  if(!nombre) return '··';
  const p=nombre.trim().split(/\s+/);
  return ((p[0]||'')[0]||'').toUpperCase()+((p[1]||'')[0]||'').toUpperCase();
}
/* ── Puntos y nivel (cliente) ── */
function computePts(estado){
  if(!estado) return 0;
  const i=estado.indicadores||{};
  const indSum=(i.clima||0)+(i.desempenio||0)+(i.desarrollo||0)+(i.recursos||0);
  const r=estado.recursos||{};
  const recSum=(r.comunicacion||0)+(r.liderazgo||0)+(r.bienestar||0)+(r.planificacion||0);
  const ins=(estado.insignias||[]).length;
  return Math.round(600 + indSum*60 + recSum*40 + ins*70 + (estado.casillero||0)*30);
}
function computeNivel(pts){ return Math.min(5, Math.floor(pts/600)+1); }

/* ── VALIDAR LEGAJO ── */
function validarLegajo(){
  const legajo=document.getElementById('inp-legajo').value.trim();
  if(!legajo){showStatus('Ingresá un número de legajo','err');return;}
  showStatus('Buscando en el registro municipal…','loading');
  showLoader();
  google.script.run
    .withSuccessHandler(res=>{
      hideLoader();
      if(res&&res.encontrado){
        agenteData={legajo:legajo,nombre:res.nombre,direccion:res.direccion,equipo:getEquipo(res.direccion)};
        showStatus('✓ Legajo encontrado','ok');
        document.getElementById('ac-avatar').innerText=iniciales(res.nombre);
        document.getElementById('ac-nombre').innerText=res.nombre;
        document.getElementById('ac-info').innerText='Legajo '+legajo+' · '+res.direccion;
        document.getElementById('ac-equipo').innerText=getEquipo(res.direccion);
        document.getElementById('agente-card').classList.add('visible');
        document.getElementById('agente-card-btn').style.display='block';
      }else{
        showStatus('Legajo no encontrado. Verificá el número o consultá con RRHH.','err');
        document.getElementById('agente-card').classList.remove('visible');
        document.getElementById('agente-card-btn').style.display='none';
      }
    })
    .withFailureHandler(e=>{hideLoader();showStatus('Error al consultar. Intentá de nuevo.','err');})
    .buscarAgente(legajo);
}
function showStatus(msg,type){const el=document.getElementById('legajo-status');el.innerText=msg;el.className='legajo-status '+type;}

/* ── PANTALLA 2 ── */
function mostrarPresentacion(){
  if(!agenteData) return;
  document.getElementById('screen-welcome').style.display='none';
  document.getElementById('screen-agente').style.display='flex';
  document.getElementById('ap-avatar').innerText=iniciales(agenteData.nombre);
  document.getElementById('ap-nombre').innerText=agenteData.nombre.toUpperCase();
  document.getElementById('ap-legajo-txt').innerText='Legajo '+agenteData.legajo;
  document.getElementById('ap-dir-txt').innerText='Dirección de '+agenteData.direccion;
  document.getElementById('ap-equipo-txt').innerText=agenteData.equipo;
  document.getElementById('ap-equipo-nm2').innerText=agenteData.equipo;
  document.getElementById('ap-mision-txt').innerHTML=
    `Como <strong>jefe/a de equipo</strong> en la Dirección de ${agenteData.direccion}, tu misión es tomar decisiones estratégicas, resolver situaciones reales y completar módulos de capacitación para desbloquear acciones avanzadas. Los <strong>recursos de RRHH</strong> que acumulás los llevás al encuentro presencial con tu equipo <strong>${agenteData.equipo}</strong>.`;
  showLoader();
  google.script.run
    .withSuccessHandler(res=>{hideLoader();g=res;renderIndsInicio(res.estado.indicadores);})
    .withFailureHandler(e=>{hideLoader();alert('Error: '+e.message);})
    .iniciarPartida(agenteData.legajo,agenteData.direccion,agenteData.equipo,agenteData.nombre);
}
function renderIndsInicio(indicadores){
  document.getElementById('ap-inds').innerHTML=
    Object.entries(indicadores).map(([k,v])=>
      `<div class="ind-c"><div class="ind-ico">${IND[k]?.icon||'●'}</div><div class="ind-lbl">${(IND[k]?.lbl||k).split(' ')[0]}</div><div class="ind-val100">${v*20}/100</div></div>`
    ).join('');
}

/* ── INICIAR JUEGO ── */
function iniciarJuego(){
  document.getElementById('screen-agente').style.display='none';
  document.getElementById('app').style.display='grid';
  actualizarHdrAvatar();
  render();
}
function actualizarHdrAvatar(){
  if(!agenteData) return;
  const ini=iniciales(agenteData.nombre);
  document.getElementById('hdr-av').innerText=ini;
  document.getElementById('mini-av').innerText=ini;
  document.getElementById('mini-nm').innerText=agenteData.nombre;
  document.getElementById('mini-dir').innerText=agenteData.direccion;
  document.getElementById('mini-equipo').innerText=agenteData.equipo;
  document.getElementById('app-dir').innerText=agenteData.direccion.toUpperCase();
}

/* ── RENDER DASHBOARD ── */
function render(){
  const e=g.estado;
  renderBoard(e.casillero);
  renderHeaderProgreso(e);
  renderHdrPlayer(e);
  /* indicadores X/100 */
  document.getElementById('ind-panel').innerHTML=
    Object.entries(e.indicadores).map(([k,v])=>
      `<div class="stat"><div class="stat-row"><span class="stat-lbl">${IND[k]?.icon} ${IND[k]?.lbl||k}</span><span class="stat-val">${v*20}/100</span></div><div class="bar-bg"><div class="bar-fg ${IND[k]?.bar||'bc2'}" style="width:${v*20}%"></div></div></div>`
    ).join('');
  /* situación */
  const tipo=(g.situacion.tipo||'situacion').toLowerCase();
  const tipoEl=document.getElementById('sit-tipo');
  tipoEl.className='sit-tipo '+tipo;
  tipoEl.innerText=tipo==='crisis'?'⚡ CRISIS · SITUACIÓN '+(e.casillero+1)+' DE 12':tipo==='final'?'🏆 MISIÓN COMPLETADA':'📋 SITUACIÓN '+(e.casillero+1)+' DE 12';
  document.getElementById('sit-title').innerText=g.situacion.titulo;
  document.getElementById('sit-desc').innerText=g.situacion.desc;
  /* recursos */
  const rec=e.recursos;
  document.getElementById('r-com').innerText=(rec.comunicacion??0);
  document.getElementById('r-lid').innerText=(rec.liderazgo??0);
  document.getElementById('r-bien').innerText=(rec.bienestar??0);
  document.getElementById('r-plan').innerText=(rec.planificacion??0);
  /* insignias */
  const ins=document.getElementById('ins-row');
  ins.innerHTML=e.insignias.length
    ? e.insignias.map(i=>`<div class="ins-badge" title="${i}">🎖</div>`).join('')
    : `<span style="font-size:11px;font-style:italic;color:var(--navy-md)">Completá módulos para ganar insignias</span>`;
  renderRanking(e);
  renderBib(); renderCartas();
}

function renderHeaderProgreso(e){
  const cas=e.casillero;
  const era=cas<4?'ERA I · ORGANIZACIÓN':cas<8?'ERA II · DESEMPEÑO':'ERA III · DESARROLLO';
  document.getElementById('hdr-era-txt').innerText=era;
  let dots='';
  for(let i=0;i<12;i++){
    const cls=i<cas?'done':i===cas?'active':'';
    dots+=`<div class="pdot ${cls}"></div>`;
  }
  document.getElementById('prog-dots').innerHTML=dots;
  document.getElementById('hdr-pct').innerText=Math.round(cas/12*100)+'%';
}
function renderHdrPlayer(e){
  const pts=computePts(e), lvl=computeNivel(pts);
  document.getElementById('hdr-info').innerHTML=
    `<strong>${agenteData.nombre.toUpperCase()}</strong>${agenteData.equipo} · <span class="hdr-pts">★ ${pts.toLocaleString('es-AR')} pts</span><span class="hdr-lvl">NIVEL ${lvl}</span>`;
}

function renderBoard(cas){
  const ERAS=[
    {nm:'ERA I · Organización',cls:'e1',nodes:[1,2,3,4],nc:'n1',lc:'nl1',enc:'ENCUENTRO 1'},
    {nm:'ERA II · Desempeño',  cls:'e2',nodes:[5,6,7,8],nc:'n2',lc:'nl2',enc:'ENCUENTRO 2'},
    {nm:'ERA III · Desarrollo',cls:'e3',nodes:[9,10,11,12],nc:'n3',lc:'nl3',enc:null}
  ];
  let html=`<div class="sb">INICIO</div>`;
  ERAS.forEach((era,ei)=>{
    if(ei>0){html+=`<div class="esep"></div>`;if(ERAS[ei-1].enc)html+=`<div class="enc-b">${ERAS[ei-1].enc}</div><div class="esep"></div>`;}
    html+=`<div class="era-blk"><div class="era-lbl ${era.cls}">${era.nm}</div><div class="era-nds">`;
    era.nodes.forEach((n,ni)=>{
      const done=cas>n,active=cas===n;
      html+=`<div class="node ${era.nc} ${done?'done':active?'active':''}">${done?'✓':n}</div>`;
      if(ni<era.nodes.length-1) html+=`<div class="nl ${era.lc}"></div>`;
    });
    html+=`</div></div>`;
  });
  html+=`<div class="esep"></div><div class="eb">🏁 META</div>`;
  document.getElementById('era-board').innerHTML=html;
}

/* ── RANKING ── */
function renderRanking(e){
  const pts=computePts(e);
  const me={n:agenteData.nombre,d:'Dirección de '+agenteData.direccion,pts:pts,me:true};
  const lista=RANKING_BASE.map(x=>({...x})).concat([me]).sort((a,b)=>b.pts-a.pts);
  const myPos=lista.findIndex(x=>x.me)+1;
  let rows=[];
  const top=lista.slice(0,4);
  top.forEach((x,idx)=>rows.push(rankRow(x,idx+1)));
  if(myPos>4){ rows.push(`<div class="rank-sep">···</div>`); rows.push(rankRow(me,myPos)); }
  document.getElementById('rank-panel').innerHTML=rows.join('');
}
function rankRow(x,pos){
  const medal=pos===1?'🥇':pos===2?'🥈':pos===3?'🥉':pos;
  const medalCls=pos<=3?'medal':'';
  return `<div class="rank-row ${x.me?'me':''}">
    <div class="rk-pos ${medalCls}">${medal}</div>
    <div class="rk-info"><div class="rk-nm">${x.n}</div><div class="rk-dir">${x.d}</div></div>
    <div class="rk-pts">${x.pts.toLocaleString('es-AR')}</div>
  </div>`;
}

/* ── BIBLIOTECA / MICROLEARNING ── */
function renderBib(){
  if(!g.biblioteca) return;
  document.getElementById('bib-panel').innerHTML=g.biblioteca.map(h=>{
    const done=g.estado.herramientas.includes(h.id);
    const onclk=done?'':`abrirHerr('${h.id}')`;
    return `<div class="hi ${done?'done':''}" onclick="${onclk}">
      <div class="hi-tit">${done?'✅':'🎓'} ${h.nombre} <span style="font-weight:400;color:var(--navy-md)">· ${h.duracion||'5 min'}</span></div>
      <div class="hi-sub">${done?'Completado · Insignia obtenida':'Mirá el módulo y respondé el cuestionario'}</div>
    </div>`;
  }).join('');
}
function toggleBib(){
  bibOpen=!bibOpen;
  document.getElementById('bib-panel').style.display=bibOpen?'block':'none';
  document.getElementById('bib-arrow').innerText=bibOpen?'▲':'▼';
}
function abrirHerr(id){
  const h=g.biblioteca.find(x=>x.id===id); if(!h) return;
  modalData={tipo:'herr',data:h};
  document.getElementById('m-hdr-ico').innerText='🎓';
  document.getElementById('m-hdr-titulo').innerText=h.nombre;
  document.getElementById('m-hdr-sub').innerText='Capacitación · Microlearning';
  document.getElementById('m-badge').innerText='⏱ '+(h.duracion||'5 min')+' · HERRAMIENTA';
  document.getElementById('m-badge').style.display='inline-block';
  document.getElementById('m-ml-tabs').style.display='flex';
  document.getElementById('m-video').style.display='flex';
  document.getElementById('m-video-lbl').innerText='0:00 / '+(h.duracion||'3:45');
  document.getElementById('m-accion-preview').style.display='none';
  document.getElementById('m-cont').innerText=h.contenido;
  document.getElementById('m-cont').style.display='block';
  document.getElementById('m-preg').innerHTML='<span class="qnum">Cuestionario · Pregunta 1 de 1</span>'+(h.pregunta||'¿Confirmás la lectura del módulo?');
  document.getElementById('m-inp').style.display='block';
  document.getElementById('m-inp').value='';
  document.getElementById('m-inp').placeholder='Escribí tu respuesta…';
  document.getElementById('modal').style.display='flex';
}

/* ── CARTAS ── */
function catCss(cat){
  if(!cat) return 'cc-def'; const c=cat.toLowerCase();
  if(c.includes('comunic')) return 'cc-com';
  if(c.includes('liderazg')||c.includes('profesion')) return 'cc-lid';
  if(c.includes('bienestar')||c.includes('climat')) return 'cc-bien';
  if(c.includes('planif')||c.includes('organiz')) return 'cc-plan';
  return 'cc-def';
}
function catIcon(cat){
  if(!cat) return '⚡'; const c=cat.toLowerCase();
  if(c.includes('comunic')) return '💬';
  if(c.includes('liderazg')||c.includes('profesion')) return '🧭';
  if(c.includes('bienestar')||c.includes('climat')) return '🌱';
  if(c.includes('planif')||c.includes('organiz')) return '📋';
  return '⚡';
}
function renderCartas(){
  const grid=document.getElementById('cards-grid');
  if(!g.cartas||!g.cartas.length){
    grid.innerHTML='<p style="font-style:italic;color:var(--navy-md);text-align:center;padding:18px">Recorrido completo.</p>';return;
  }
  grid.innerHTML=g.cartas.map(c=>{
    const cc=catCss(c.cat), ico=catIcon(c.cat);
    const esProfesional=(c.cat||'').toLowerCase().includes('profesion');
    const esBasica=(c.cat||'').toLowerCase().includes('básic')||(c.cat||'').toLowerCase().includes('basic');
    const badgeClass=esProfesional?'tipo-prof':esBasica?'tipo-bas':'tipo-prof';
    const badgeTxt=esProfesional?'⭐ PROFESIONAL':esBasica?'BÁSICA':c.cat;
    const reward=c.recursoGanado?`+${c.cantidadRecurso} ${c.recursoGanado.toUpperCase()}`:'';
    if(c.bloqueada){
      const herr=g.biblioteca?g.biblioteca.find(h=>h.id===c.req):null;
      const hn=herr?herr.nombre:c.req;
      return `<div class="card locked" onclick="abrirHerr('${c.req}')" title="Clic para desbloquear">
        <div class="lock-badge">🔒 BLOQUEADA</div>
        <div class="card-head ${cc}" style="opacity:.6"><div class="card-head-icon">${ico}</div>
          <div class="card-head-info"><div class="card-cat">${(c.cat||'').toUpperCase()}</div><div class="card-tipo-badge ${badgeClass}">${badgeTxt}</div></div></div>
        <div class="card-body"><div class="card-txt" style="color:var(--navy-md)">${c.texto}</div>
          <div class="unlock-h">🎓 CAPACITARTE PARA DESBLOQUEAR</div><div class="unlock-s">${hn}</div></div>
      </div>`;
    }
    return `<div class="card ${cc}" onclick="clickCarta('${c.id}','${c.cat}',false,'','${c.recursoGanado}',${c.cantidadRecurso},'${c.impactoInd}',${c.valorImpacto})">
      <div class="card-head"><div class="card-head-icon">${ico}</div>
        <div class="card-head-info"><div class="card-cat">${(c.cat||'').toUpperCase()}</div><div class="card-tipo-badge ${badgeClass}">${badgeTxt}</div></div></div>
      <div class="card-body"><div class="card-txt">${c.texto}</div></div>
      <div class="card-foot"><div class="card-reward">${reward}</div><div class="card-arr">→</div></div>
    </div>`;
  }).join('');
}
function clickCarta(id,cat,lock,req,recurso,cantidad,impInd,valImp){
  if(lock){abrirHerr(req);return;}
  modalData={tipo:'accion',data:{id,cat,recurso,cantidad,impInd,valImp}};
  document.getElementById('m-hdr-ico').innerText=catIcon(cat);
  document.getElementById('m-hdr-titulo').innerText='¿Confirmás esta acción?';
  document.getElementById('m-hdr-sub').innerText='Carta de acción · '+cat;
  document.getElementById('m-badge').style.display='none';
  document.getElementById('m-ml-tabs').style.display='none';
  document.getElementById('m-video').style.display='none';
  document.getElementById('m-cont').style.display='none';
  const preview=document.getElementById('m-accion-preview');
  preview.style.display='flex';
  document.getElementById('m-acc-ico').innerText=catIcon(cat);
  document.getElementById('m-acc-cat').innerText=(cat||'').toUpperCase();
  document.getElementById('m-acc-txt').innerText=`Sumará ${cantidad} punto(s) de ${recurso} y mejorará el indicador ${impInd}.`;
  document.getElementById('m-acc-efecto').innerText=`+${cantidad} ${(recurso||'').toUpperCase()} → ${impInd} ↑`;
  document.getElementById('m-preg').innerText='';
  document.getElementById('m-inp').style.display='none';
  document.getElementById('modal').style.display='flex';
}

/* ── CONFIRMAR MODAL ── */
function confirmarModal(){
  if(!modalData) return;
  if(modalData.tipo==='herr'){
    const h=modalData.data;
    const resp=document.getElementById('m-inp').value.trim().toLowerCase();
    if(resp===String(h.respuesta).toLowerCase()){
      cerrarModal(); showLoader();
      prevCartas=g.cartas?g.cartas.map(c=>({id:c.id,bloqueada:c.bloqueada})):[];
      google.script.run
        .withSuccessHandler(res=>{
          g.estado=res.estado; g.cartas=res.cartas; hideLoader();
          render();
          detectarUnlock(h);
        })
        .withFailureHandler(e=>{hideLoader();alert(e.message);})
        .completarCapacitacion(g.estado,h.id,h.insigniaID);
    }else alert('Respuesta incorrecta. Revisá el contenido del módulo e intentá de nuevo.');
  }else if(modalData.tipo==='accion'){
    const d=modalData.data; cerrarModal(); showLoader();
    prevSnapshot=snapshot(g.estado);
    google.script.run
      .withSuccessHandler(res=>{
        g=res; hideLoader();
        if(res.finalizado){ mostrarResultado(()=>mostrarFinal()); }
        else if(res.encuentro){ mostrarResultado(()=>mostrarEncuentro(res.nroEncuentro)); }
        else { mostrarResultado(()=>render()); }
      })
      .withFailureHandler(e=>{hideLoader();alert(e.message);})
      .procesarAccion(g.estado,d.id,d.cat,d.recurso,d.cantidad,d.impInd,d.valImp);
  }
}
function cerrarModal(){document.getElementById('modal').style.display='none';modalData=null;}

/* ── DETECTAR CARTA DESBLOQUEADA ── */
function detectarUnlock(herr){
  let nueva=null;
  if(prevCartas&&g.cartas){
    for(const c of g.cartas){
      const before=prevCartas.find(p=>p.id===c.id);
      if(before&&before.bloqueada&&!c.bloqueada){nueva=c;break;}
    }
  }
  if(nueva){
    document.getElementById('unlock-ico').innerText=catIcon(nueva.cat);
    document.getElementById('unlock-nm').innerText=nueva.texto;
    document.getElementById('unlock-desc').innerText='Completaste el microlearning y aprobaste el cuestionario. Sumaste "'+(herr?herr.nombre:nueva.cat)+'" a tu mazo de herramientas.';
    document.getElementById('unlock-modal').style.display='flex';
  }
}
function cerrarUnlock(){document.getElementById('unlock-modal').style.display='none';}

/* ── RESULTADO DE LA ACCIÓN ── */
function snapshot(estado){
  return {ind:Object.assign({},estado.indicadores), pts:computePts(estado)};
}
let resultadoCb=null;
function mostrarResultado(cb){
  resultadoCb=cb;
  const after=g.estado.indicadores;
  const before=prevSnapshot?prevSnapshot.ind:after;
  const ptsDelta=computePts(g.estado)-(prevSnapshot?prevSnapshot.pts:computePts(g.estado));
  let rows='';
  Object.keys(IND).forEach(k=>{
    const d=( (after[k]||0)-(before[k]||0) )*20;
    const cls=d>0?'up':d<0?'down':'zero';
    const sign=d>0?'+'+d+'%':d<0?d+'%':'0%';
    rows+=`<div class="res-d-row"><span>${IND[k].icon} ${IND[k].lbl}</span><span class="res-d-val ${cls}">${sign}</span></div>`;
  });
  if(ptsDelta>0) rows+=`<div class="res-d-row" style="border-top:1px dashed rgba(28,46,74,.2);margin-top:6px;padding-top:8px"><span>★ Puntaje</span><span class="res-d-val up">+${ptsDelta} pts</span></div>`;
  document.getElementById('res-deltas-rows').innerHTML=rows;
  const tipo=(g.situacion&&g.situacion.tipo||'').toLowerCase();
  document.getElementById('res-titulo').innerText=tipo==='final'?'¡MISIÓN CUMPLIDA!':'¡MUY BIEN!';
  document.getElementById('res-sub').innerText=tipo==='final'?'Completaste el recorrido':'Tu decisión impactó en el equipo';
  document.getElementById('res-modal').style.display='flex';
}
function cerrarResultado(){
  document.getElementById('res-modal').style.display='none';
  const cb=resultadoCb; resultadoCb=null; prevSnapshot=null;
  if(cb) cb();
}

/* ── ENCUENTRO ── */
function mostrarEncuentro(nro){
  const info=ENC[nro]||{titulo:'Encuentro Presencial',desc:'Reunite con los otros equipos.'};
  document.getElementById('enc-titulo').innerText=info.titulo;
  document.getElementById('enc-desc').innerText=info.desc;
  document.getElementById('enc-modal').style.display='flex';
}
function cerrarEncuentro(){document.getElementById('enc-modal').style.display='none';render();}

/* ── REGLAS ── */
function abrirReglas(){document.getElementById('modal-reglas').classList.add('open');}
function cerrarReglas(){document.getElementById('modal-reglas').classList.remove('open');}

/* ── FINAL ── */
function mostrarFinal(){
  google.script.run.withSuccessHandler(p=>{
    document.getElementById('final-equipo').innerText=(agenteData?.equipo||'').toUpperCase();
    document.getElementById('final-score').innerText=p.promedioIndicadores+' / 5';
    document.getElementById('final-nivel').innerText=p.nivel.toUpperCase();
    document.getElementById('final-detail').innerHTML=
      `Puntaje final: <span>${computePts(g.estado).toLocaleString('es-AR')} pts</span><br>Recursos totales: <span>${p.totalRecursos}</span><br>Insignias obtenidas: <span>${p.insignias}</span><br>Dirección: <span>${g.estado.direccion}</span>`;
    document.getElementById('final-screen').style.display='flex';
  }).calcularPuntajeFinal(g.estado);
}

/* ── UTILS ── */
function showLoader(){document.getElementById('loader').style.display='flex';}
function hideLoader(){document.getElementById('loader').style.display='none';}
</script>
