<!DOCTYPE html>
<html lang="es">
<head>
  <base target="_top">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <style>
/* ══════════════════════════════════════
   TOKENS — Mapa antiguo de Bariloche
══════════════════════════════════════ */
:root {
  --map-bg-img: url('data:image/jpeg;base64,');
  --perg:     #ede0ba;
  --perg-lt:  #f8f0d8;
  --perg-dk:  #ceb87a;
  --perg-mid: #dfd0a0;
  --navy:     #4a2109;
  --navy-md:  #7a3410;
  --navy-lt:  #a8551f;
  --gold:     #8a4d1e;
  --gold-lt:  #a07828;
  --gold-br:  #c0531e;
  --era1:     #2a6a4a;  /* teal bosque */
  --era2:     #4a2109;  /* navy */
  --era3:     #7a2020;  /* rojo andino */
  --grn:      #2a5024;
  --red:      #8b2020;
  --teal:     #2a6a4a;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Crimson Text',Georgia,serif;background:var(--perg);color:var(--navy);min-height:100vh;overflow-x:hidden}
button{font:inherit}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:var(--perg)}::-webkit-scrollbar-thumb{background:rgba(74,33,9,.3)}

#map-bg{position:fixed;inset:0;z-index:0;background:var(--map-bg-img) center/cover no-repeat;}

/* ── LOADER ── */
#loader{display:none;position:fixed;inset:0;z-index:9000;background:rgba(232,213,163,.94);align-items:center;justify-content:center;}
.loader-inn{background:var(--navy);border:2px solid var(--gold-br);padding:22px 38px;border-radius:12px;}
.loader-txt{font-family:'Cinzel',serif;font-size:11px;letter-spacing:5px;color:var(--perg);animation:pulse 1.2s infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
@keyframes mmpulse{0%,100%{box-shadow:0 0 0 0 rgba(192,83,30,.55)}50%{box-shadow:0 0 0 10px rgba(192,83,30,0)}}
@keyframes mmglow{0%,100%{box-shadow:0 5px 14px rgba(160,60,20,.35)}50%{box-shadow:0 5px 22px rgba(160,60,20,.65)}}

/* ══════════════════════════════════════
   PANTALLA LOGIN
══════════════════════════════════════ */
.screen-full{position:fixed;inset:0;z-index:100;overflow-y:auto;}
#screen-login .topbar-login{position:relative;z-index:2;display:flex;align-items:center;justify-content:space-between;padding:16px 30px;}
.brand-grp{display:flex;align-items:center;gap:10px;}
.brand-ico{font-size:20px;}
.brand-logo-img{width:42px;height:42px;flex:none;object-fit:contain;}
.brand-nm{font-family:'Cinzel',serif;font-size:16px;font-weight:900;letter-spacing:4px;color:var(--navy);text-shadow:0 0 5px rgba(255,250,235,.85),0 0 9px rgba(255,250,235,.6);}
.brand-sub{font-family:'Cinzel',serif;font-size:7px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;text-shadow:0 0 5px rgba(255,250,235,.85),0 0 9px rgba(255,250,235,.6);}
.brand-tag{font-family:'Cinzel',serif;font-size:7px;letter-spacing:1.5px;color:var(--navy-md);text-align:right;line-height:1.8;}

.login-wrap{position:relative;z-index:2;display:flex;flex-direction:row;align-items:flex-start;justify-content:center;gap:32px;min-height:calc(100vh - 60px);padding:32px 24px;flex-wrap:wrap;}
.login-col-left{display:flex;flex-direction:column;align-items:center;gap:20px;flex:0 0 auto;width:100%;max-width:440px;}
.login-col-right{flex:0 0 auto;width:100%;max-width:360px;align-self:flex-start;margin-top:0;}
.hero-title-wrap{display:flex;flex-direction:column;align-items:center;gap:10px;pointer-events:none;}
.hero-title-row{display:flex;align-items:center;gap:16px;}
.hero-flower{width:56px;height:auto;flex:none;filter:drop-shadow(0 0 5px rgba(255,250,235,.95)) drop-shadow(0 0 9px rgba(255,250,235,.8)) drop-shadow(0 0 3px rgba(255,250,235,1));}
.hero-title{font-family:'Cinzel',serif;font-weight:900;font-size:clamp(28px,4.6vw,52px);line-height:1.1;letter-spacing:6px;color:#c0531e;text-align:center;text-shadow:0 0 6px rgba(255,250,235,.9),0 0 12px rgba(255,250,235,.7),0 2px 0 rgba(120,50,10,.2);}
.hero-subtitle{font-family:'Cinzel',serif;font-weight:700;font-size:clamp(11px,1.7vw,16px);letter-spacing:5px;color:#c0531e;text-transform:uppercase;text-align:center;text-shadow:0 0 5px rgba(255,250,235,.95),0 0 9px rgba(255,250,235,.75);}
.login-card{
  width:100%;max-width:440px;
  background:linear-gradient(170deg,#fbeed3,#f2d9a9);
  border:1px solid #cf9a54;border-radius:18px;
  padding:34px 32px 28px;text-align:center;
  box-shadow:0 22px 48px rgba(70,33,9,.30), inset 0 0 0 2px rgba(150,78,30,.12);
}
.login-eyebrow{font-family:'Cinzel',serif;font-size:11px;font-weight:700;letter-spacing:3px;color:var(--gold-br);}
.login-p{margin:10px 0 20px;font-size:14px;line-height:1.5;color:var(--gold);}
.legajo-inp{width:100%;padding:13px 15px;font-family:'Spectral',Georgia,serif;font-size:18px;font-weight:600;letter-spacing:2px;text-align:center;color:#301a0a;background:#fffaf0;border:2px solid #cf9a54;border-radius:10px;outline:none;margin-bottom:14px;transition:.18s;}
.legajo-inp:focus{border-color:var(--gold-br);}
.legajo-inp::placeholder{color:#b0a070;font-weight:400;font-size:14px;letter-spacing:.5px;}
.btn-primary{display:inline-flex;align-items:center;justify-content:center;gap:9px;width:100%;padding:13px;font-family:'Cinzel',serif;font-size:13px;font-weight:700;letter-spacing:2px;color:#fff;background:linear-gradient(160deg,#e39445,var(--gold-br));border:none;border-radius:10px;cursor:pointer;box-shadow:0 8px 18px rgba(160,60,20,.34);transition:.18s;}
.btn-primary:hover{filter:brightness(1.07);transform:translateY(-1px);}
.legajo-status{font-size:12px;margin-top:8px;min-height:16px;}
.legajo-status.ok{color:var(--grn);font-weight:700;}
.legajo-status.err{color:var(--red);}
.legajo-status.loading{color:var(--navy-md);font-style:italic;}
.agente-card{display:none;background:rgba(74,33,9,.06);border:1px solid rgba(74,33,9,.18);border-radius:12px;padding:14px 16px;margin-top:12px;text-align:left;}
.agente-card.visible{display:block;}
.ac-nombre{font-family:'Cinzel',serif;font-size:14px;font-weight:700;color:var(--navy);margin-bottom:2px;}
.ac-info{font-size:13px;color:var(--navy-md);margin-bottom:4px;}
.ac-equipo-nm{font-family:'Cinzel',serif;font-size:12px;font-weight:700;color:var(--teal);margin-bottom:10px;}
.link-btn{background:none;border:none;font-family:'Spectral',Georgia,serif;font-size:12.5px;letter-spacing:.3px;color:var(--gold-br);cursor:pointer;text-decoration:underline;padding:4px;}
.card-footer{margin-top:16px;}

/* ══════════════════════════════════════
   PANTALLA BIENVENIDA / EQUIPO
══════════════════════════════════════ */
#screen-bienvenida{background:var(--navy);}
.bienv-wrap{position:relative;z-index:2;max-width:1080px;margin:0 auto;padding:40px 24px;}
.bienv-card{background:linear-gradient(170deg,#fbeed3,#f2d9a9);border:1px solid #cf9a54;border-radius:18px;padding:30px;box-shadow:0 22px 48px rgba(70,33,9,.30),inset 0 0 0 2px rgba(150,78,30,.12);}
.bienv-grid{display:grid;grid-template-columns:1.35fr 1fr;gap:30px;align-items:stretch;}
@media(max-width:780px){.bienv-grid{grid-template-columns:1fr;}}
.bienv-hello{font-family:'Spectral',Georgia,serif;font-style:italic;font-weight:600;font-size:19px;color:var(--gold-br);}
.bienv-name{font-family:'Cinzel',serif;font-weight:800;font-size:30px;line-height:1.05;color:#301a0a;margin-top:2px;}
.bienv-meta{margin-top:8px;font-size:14px;color:var(--gold);}
.bienv-dir{font-weight:600;font-size:14px;color:#301a0a;}
.bienv-lbl{margin:20px 0 9px;font-family:'Cinzel',serif;font-size:11px;font-weight:700;letter-spacing:2.5px;color:var(--gold);}
.bienv-team{display:flex;gap:14px;flex-wrap:wrap;}
.bt-av{display:flex;flex-direction:column;align-items:center;width:78px;text-align:center;}
.bt-circ{width:46px;height:46px;border-radius:50%;background:linear-gradient(150deg,#e8a95e,var(--gold));display:flex;align-items:center;justify-content:center;font-family:'Cinzel',serif;font-weight:700;font-size:15px;color:#fff;border:2px solid #f6e4c6;box-shadow:0 4px 10px rgba(90,40,12,.24);}
.bt-nm{margin-top:5px;font-family:'Spectral',Georgia,serif;font-weight:600;font-size:11px;line-height:1.15;color:#301a0a;}
.bt-role{font-size:9.5px;color:var(--gold);}
.bienv-tareas{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.bt-item{display:flex;align-items:center;gap:8px;background:rgba(255,250,240,.62);border:1px solid #d7a866;border-radius:9px;padding:9px 11px;}
.bt-dot{width:8px;height:8px;background:var(--gold-br);transform:rotate(45deg);flex:none;}
.bt-item span{font-size:12.5px;color:#301a0a;}
.bienv-side{background:rgba(255,250,240,.55);border:1px solid #d7a866;border-radius:13px;padding:20px 18px;display:flex;flex-direction:column;}
.bienv-side-lbl{font-family:'Cinzel',serif;font-size:11px;font-weight:700;letter-spacing:2px;color:var(--gold);margin-bottom:14px;}
.ind-row{margin-bottom:15px;}
.ind-row-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;}
.ind-row-lbl{display:flex;align-items:center;gap:7px;font-family:'Spectral',Georgia,serif;font-weight:600;font-size:12.5px;color:#301a0a;}
.ind-dot{width:10px;height:10px;border-radius:3px;flex:none;}
.ind-row-val{font-family:'Cinzel',serif;font-size:12px;font-weight:700;color:#301a0a;}
.ind-bar-bg{height:9px;background:#e6c491;border-radius:6px;overflow:hidden;box-shadow:inset 0 1px 2px rgba(90,40,12,.2);}
.ind-bar-fg{height:100%;border-radius:6px;transition:width .5s;}
.bienv-actions{display:flex;align-items:center;justify-content:center;gap:18px;margin-top:24px;flex-wrap:wrap;}
.bienv-actions .btn-primary{width:auto;padding:15px 38px;font-size:15px;}

/* ══════════════════════════════════════
   APP BAR + NAV
══════════════════════════════════════ */
#app{display:none;position:relative;z-index:10;min-height:100vh;background:var(--perg);}
.appbar{position:sticky;top:0;z-index:40;display:flex;align-items:center;gap:20px;flex-wrap:wrap;padding:10px 24px;background:linear-gradient(180deg,var(--navy-md),var(--navy));color:var(--perg);box-shadow:0 6px 20px rgba(50,18,4,.42);border-bottom:4px solid var(--gold-br);}
.appbar-logo{font-family:'Cinzel',serif;font-size:15px;font-weight:900;letter-spacing:4px;color:var(--perg);flex:none;}
.appbar-logo-img{width:38px;height:38px;flex:none;object-fit:contain;}
.appbar-nav{display:flex;gap:5px;background:rgba(0,0,0,.24);padding:4px;border-radius:11px;border:1px solid rgba(240,207,148,.20);}
.nav-btn{background:transparent;color:#e6bd85;border:none;border-radius:8px;padding:8px 16px;font-family:'Spectral',Georgia,serif;font-weight:500;font-size:12.5px;letter-spacing:.5px;cursor:pointer;transition:.15s;}
.nav-btn.active{background:var(--gold-br);color:#fff;font-weight:600;}
.appbar-spacer{flex:1;}
.btn-reglas-top{display:flex;align-items:center;gap:7px;background:transparent;color:var(--perg);border:1px solid rgba(240,207,148,.42);border-radius:9px;padding:7px 14px;font-family:'Spectral',Georgia,serif;font-weight:600;font-size:12px;letter-spacing:.5px;cursor:pointer;transition:.15s;}
.btn-reglas-top:hover{background:rgba(240,207,148,.14);}
.profile-chip{display:flex;align-items:center;gap:10px;padding:5px 13px 5px 6px;background:rgba(0,0,0,.22);border-radius:999px;border:1px solid rgba(240,207,148,.20);}
.profile-av{width:37px;height:37px;border-radius:50%;background:linear-gradient(150deg,#e39445,var(--gold-br));display:flex;align-items:center;justify-content:center;font-family:'Cinzel',serif;font-weight:700;font-size:14px;color:#fff;border:2px solid var(--perg);flex:none;}
.profile-info{line-height:1.15;font-family:'Spectral',Georgia,serif;}
.profile-nm{font-weight:600;font-size:12.5px;color:var(--perg);}
.profile-tm{font-weight:500;font-size:10.5px;color:#e0b579;}

.screen-body{max-width:1400px;margin:0 auto;padding:22px 26px 40px;display:none;}
.screen-body.active{display:block;}

/* ── TABLERO ── */
.tablero-grid{display:grid;grid-template-columns:1fr 300px;gap:24px;align-items:start;}
@media(max-width:900px){.tablero-grid{grid-template-columns:1fr;}}
.tablero-title{display:flex;align-items:baseline;gap:14px;margin-bottom:18px;flex-wrap:wrap;}
.tablero-title h2{font-family:'Cinzel',serif;font-size:22px;color:#301a0a;}
.tablero-title span{font-size:13px;font-style:italic;color:var(--gold);}
.lane{background:linear-gradient(170deg,rgba(251,238,211,.94),rgba(240,214,166,.94));border:1px solid #d29d57;border-radius:15px;padding:16px 22px 20px;box-shadow:0 10px 26px rgba(80,38,10,.18);margin-bottom:20px;}
.lane-hdr{display:flex;align-items:center;gap:12px;margin-bottom:14px;}
.lane-chip{font-family:'Cinzel',serif;font-size:11px;font-weight:700;letter-spacing:1.5px;padding:5px 12px;border-radius:7px;color:#fff;flex:none;}
.lane-nm{font-family:'Spectral',Georgia,serif;font-weight:600;font-size:13.5px;color:#301a0a;}
.lane-stops{display:flex;justify-content:space-between;flex-wrap:wrap;gap:14px;position:relative;}
.lane-stop{display:flex;flex-direction:column;align-items:center;flex:none;}
.lane-med{width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Cinzel',serif;font-weight:700;font-size:16px;position:relative;}
.lane-med.done{background:linear-gradient(160deg,#7e8a3c,#566425);border:3px solid #eef0d8;color:#fff;box-shadow:0 6px 14px rgba(70,80,30,.3);}
.lane-med.current{background:linear-gradient(160deg,#e39445,var(--gold-br));border:3px solid #f6e4cb;color:#fff;animation:mmpulse 2s infinite;cursor:pointer;}
.lane-med.pending{background:linear-gradient(160deg,#f6e6c6,#e8cfa0);border:3px solid #cf9a54;color:#8a4d1e;}
.lane-med.locked{background:linear-gradient(160deg,#e8dcc4,#cdbe9e);border:3px solid #b9a883;color:#9a8765;}
.lane-med-lbl{margin-top:5px;font-family:'Spectral',Georgia,serif;font-size:10px;color:#4a2109;}
.legend-row{display:flex;gap:20px;flex-wrap:wrap;margin-top:6px;padding:12px 18px;background:rgba(122,52,16,.08);border-radius:11px;}
.legend-it{display:flex;align-items:center;gap:7px;font-family:'Spectral',Georgia,serif;font-weight:500;font-size:12px;color:#4a2109;}
.legend-dot{width:15px;height:15px;border-radius:50%;flex:none;}

.side-card{background:linear-gradient(170deg,#fbeed3,#f0d6a6);border:1px solid #d29d57;border-radius:15px;padding:18px;box-shadow:0 10px 24px rgba(80,38,10,.18);margin-bottom:16px;}
.side-lbl{font-family:'Cinzel',serif;font-size:11px;font-weight:700;letter-spacing:2px;color:var(--gold);margin-bottom:13px;}
.res-item{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px dashed rgba(150,80,35,.26);}
.res-item:last-child{border-bottom:none;}
.res-left{display:flex;align-items:center;gap:8px;}
.res-dot{width:10px;height:10px;border-radius:50%;flex:none;}
.res-nm{font-family:'Spectral',Georgia,serif;font-weight:500;font-size:12.5px;color:#4a2109;}
.res-val{font-family:'Cinzel',serif;font-size:14px;font-weight:700;color:#301a0a;}
.ins-row{display:flex;flex-wrap:wrap;gap:6px;}
.ins-badge{width:34px;height:34px;border-radius:50%;border:2px solid var(--gold-br);display:flex;align-items:center;justify-content:center;font-size:16px;background:var(--perg);}

/* ── SITUACIÓN ── */
.situ-grid{display:grid;grid-template-columns:1fr 280px;gap:24px;align-items:start;}
@media(max-width:900px){.situ-grid{grid-template-columns:1fr;}}
.situ-card{background:linear-gradient(170deg,#fbeed3,#f0d6a6);border:1px solid #d29d57;border-radius:16px;padding:24px 26px;box-shadow:0 12px 30px rgba(80,38,10,.20);margin-bottom:22px;}
.situ-badge{display:inline-block;color:#fff;font-family:'Cinzel',serif;font-size:10px;font-weight:700;letter-spacing:1.5px;padding:4px 11px;border-radius:6px;margin-bottom:12px;}
.situ-badge.situacion{background:var(--teal);}.situ-badge.crisis{background:var(--red);}.situ-badge.final{background:var(--gold-br);}
.situ-tit{font-family:'Cinzel',serif;font-size:26px;font-weight:800;line-height:1.1;color:#301a0a;margin-bottom:10px;}
.situ-desc{font-family:'Spectral',Georgia,serif;font-size:15px;line-height:1.55;color:#6a3f1c;}
.hand-hdr{display:flex;align-items:baseline;gap:12px;margin:6px 0 14px;flex-wrap:wrap;}
.hand-hdr h3{font-family:'Cinzel',serif;font-size:16px;letter-spacing:1px;color:#301a0a;}
.hand-hdr span{font-style:italic;font-size:12.5px;color:var(--gold);}
.cards-row{display:flex;gap:16px;flex-wrap:wrap;}

.mm-card{width:180px;cursor:pointer;transition:transform .18s ease;}
.mm-card:hover{transform:translateY(-7px);}
.mm-card.selected{transform:translateY(-9px);}
.mm-frame{padding:9px;border-radius:16px;box-shadow:0 12px 24px rgba(40,20,8,.34), inset 0 1px 0 rgba(255,225,175,.22);}
.mm-card.selected .mm-frame{outline:3px solid var(--gold-br);outline-offset:2px;}
.mm-inner{border-radius:11px;box-shadow:inset 0 0 0 2px rgba(150,80,35,.14);padding:14px 12px;display:flex;flex-direction:column;align-items:center;gap:8px;min-height:230px;position:relative;background:linear-gradient(175deg,#fbf1d9,#f0d9ac);border:1px solid #caa46a;}
.mm-inner.locked{background:linear-gradient(175deg,#efe6d3,#ddceb0);border-color:#b7a685;filter:saturate(.65);}
.mm-stud{position:absolute;width:8px;height:8px;transform:rotate(45deg);box-shadow:0 0 0 1.5px rgba(255,240,210,.5);}
.mm-band{align-self:stretch;text-align:center;color:#fff7e8;font-family:'Cinzel',serif;font-weight:700;font-size:8.5px;letter-spacing:1.5px;padding:4px 9px;border-radius:7px;box-shadow:inset 0 -2px 0 rgba(0,0,0,.18);}
.mm-med{width:60px;height:60px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Cinzel',serif;font-weight:700;font-size:24px;color:#fff;box-shadow:0 5px 12px rgba(120,60,15,.35);margin-top:4px;}
.mm-lock{width:64px;height:64px;border-radius:50%;background:linear-gradient(160deg,#c2b299,#8a7a62);border:3px solid #ece0c9;display:flex;align-items:center;justify-content:center;box-shadow:0 5px 12px rgba(80,45,15,.28);margin-top:4px;font-size:22px;}
.mm-title{font-family:'Cinzel',serif;font-weight:700;font-size:13px;line-height:1.14;color:#301a0a;text-align:center;}
.mm-desc{font-family:'Spectral',Georgia,serif;font-size:11.5px;line-height:1.32;color:#6a3f1c;text-align:center;flex:1;}
.mm-pips{display:flex;align-items:center;gap:4px;}
.mm-pip{width:9px;height:9px;transform:rotate(45deg);box-shadow:inset 0 0 0 1px rgba(255,255,255,.35);}
.mm-foot{font-family:'Cinzel',serif;font-weight:700;font-size:9px;letter-spacing:.5px;text-align:center;padding:4px 10px;border-radius:999px;}

.confirm-bar{display:none;align-items:center;justify-content:space-between;gap:16px;margin-top:20px;padding:16px 20px;background:rgba(122,52,16,.08);border:2px solid var(--gold-br);border-radius:14px;flex-wrap:wrap;}
.confirm-bar.visible{display:flex;}
.confirm-txt{font-family:'Spectral',Georgia,serif;font-size:14px;color:#4a2109;}
.confirm-txt strong{color:var(--gold-br);}

/* ── CAPACITACIÓN ── */
.cap-grid{display:grid;grid-template-columns:1fr 280px;gap:24px;align-items:start;}
@media(max-width:900px){.cap-grid{grid-template-columns:1fr;}}
.cap-card{background:linear-gradient(170deg,#fbeed3,#f0d6a6);border:1px solid #d29d57;border-radius:16px;padding:24px 26px;box-shadow:0 12px 30px rgba(80,38,10,.20);}
.cap-badges{display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:10px;}
.cap-badge{display:inline-block;color:#f0cf94;background:var(--navy);font-family:'Cinzel',serif;font-size:10px;font-weight:700;letter-spacing:1.5px;padding:4px 11px;border-radius:6px;}
.cap-tit{font-family:'Cinzel',serif;font-size:24px;font-weight:800;color:#301a0a;margin-bottom:6px;}
