}
.modal-inp:focus{border-color:var(--gold-br);}
.modal-btns{display:flex;gap:9px;justify-content:center;}
.mbtn{padding:10px 26px;font-family:'Cinzel',serif;font-size:11px;font-weight:700;letter-spacing:2px;cursor:pointer;transition:.18s;border:2px solid var(--navy);}
.mbtn.prim{background:var(--navy);color:var(--perg);}
.mbtn.prim:hover{background:var(--gold-br);color:var(--navy);border-color:var(--gold-br);}
.mbtn.sec{background:transparent;color:var(--navy);}
.mbtn.sec:hover{background:var(--perg-dk);}

/* Confirmación de acción */
.modal-accion-preview{
  background:rgba(28,46,74,.06);
  border:1px solid rgba(28,46,74,.15);
  padding:12px 16px;margin-bottom:16px;
  display:flex;align-items:center;gap:12px;
}
.map-ico{font-size:28px;flex-shrink:0;}
.map-info{}
.map-cat{font-family:'Cinzel',serif;font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:3px;}
.map-txt{font-size:14px;color:var(--navy);line-height:1.4;}
.map-efecto{font-family:'Cinzel',serif;font-size:10px;color:var(--teal);margin-top:4px;font-weight:700;}

/* ── ENCUENTRO ── */
#enc-modal{display:none;position:fixed;inset:0;z-index:600;background:rgba(28,46,74,.93);align-items:center;justify-content:center;}
.enc-box{background:var(--navy);border:3px solid var(--gold-br);max-width:500px;width:96%;padding:40px;text-align:center;}
.enc-ico{font-size:44px;margin-bottom:12px;}
.enc-tag{font-family:'Cinzel',serif;font-size:8px;letter-spacing:4px;text-transform:uppercase;color:var(--gold-br);margin-bottom:8px;}
.enc-box h2{font-family:'Cinzel',serif;font-size:20px;font-weight:900;color:var(--perg);margin-bottom:12px;letter-spacing:2px;}
.enc-box p{font-size:15px;line-height:1.7;color:var(--perg-dk);margin-bottom:20px;}

/* ── FINAL ── */
#final-screen{display:none;position:fixed;inset:0;z-index:700;background:var(--navy);align-items:center;justify-content:center;}
.final-box{background:var(--perg-lt);border:4px solid var(--gold-br);max-width:540px;width:97%;padding:44px;text-align:center;}
.final-tag{font-family:'Cinzel',serif;font-size:9px;letter-spacing:5px;text-transform:uppercase;color:var(--gold);margin-bottom:7px;}
.final-box h1{font-family:'Cinzel',serif;font-size:30px;font-weight:900;color:var(--navy);letter-spacing:3px;margin-bottom:6px;}
.final-score{font-family:'Cinzel',serif;font-size:58px;font-weight:900;color:var(--gold-br);line-height:1;margin:10px 0;}
.final-nivel{font-family:'Cinzel',serif;font-size:12px;letter-spacing:5px;text-transform:uppercase;color:var(--navy-md);margin-bottom:13px;}
.final-detail{font-family:'Cinzel',serif;font-size:11px;letter-spacing:1px;color:var(--navy-md);margin-top:12px;line-height:2.3;}
.final-detail span{color:var(--navy);font-weight:700;}

::-webkit-scrollbar{width:4px;}::-webkit-scrollbar-track{background:var(--perg);}::-webkit-scrollbar-thumb{background:rgba(28,46,74,.3);}
