<!DOCTYPE html>

<html lang="es">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Nomenclador de Puestos Municipales \&#x2014; MSCB</title>

<style>

:root {

&#x20; --navy: #0b1d3a;

&#x20; --navy-mid: #163260;

&#x20; --navy-light: #1e4080;

&#x20; --accent: #2d6be4;

&#x20; --accent2: #0ea5e9;

&#x20; --teal: #0891b2;

&#x20; --green: #059669;

&#x20; --green-pale: #ecfdf5;

&#x20; --amber: #d97706;

&#x20; --amber-pale: #fffbeb;

&#x20; --red: #dc2626;

&#x20; --red-pale: #fef2f2;

&#x20; --bg: #f0f4f9;

&#x20; --surface: #ffffff;

&#x20; --surface2: #f7fafd;

&#x20; --border: #dde4ef;

&#x20; --border2: #c4cfe0;

&#x20; --text: #0b1d3a;

&#x20; --text2: #4b5e7a;

&#x20; --text3: #8fa3bc;

&#x20; --sidebar-w: 248px;

&#x20; --header-h: 56px;

&#x20; --r-sm: 6px;

&#x20; --r: 10px;

&#x20; --r-lg: 16px;

&#x20; --sh: 0 2px 12px rgba(11,29,58,.07), 0 1px 3px rgba(11,29,58,.04);

&#x20; --sh-lg: 0 8px 32px rgba(11,29,58,.12), 0 2px 8px rgba(11,29,58,.06);

}

\*, \*::before, \*::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body { overflow-x: hidden; }

body {

&#x20; font-family: Segoe UI, system-ui, Arial, sans-serif;

&#x20; background: var(--bg);

&#x20; color: var(--text);

&#x20; font-size: 13px;

&#x20; line-height: 1.6;

&#x20; min-height: 100vh;

&#x20; -webkit-font-smoothing: antialiased;

}

.app-shell { display: flex; min-height: 100vh; min-width: 0; }

.sidebar {

&#x20; width: var(--sidebar-w);

&#x20; background: var(--navy);

&#x20; display: flex;

&#x20; flex-direction: column;

&#x20; position: fixed;

&#x20; top: 0; left: 0; bottom: 0;

&#x20; z-index: 200;

&#x20; overflow: hidden;

}

.sidebar-brand {

&#x20; padding: 20px 16px 18px;

&#x20; display: flex;

&#x20; flex-direction: column;

&#x20; align-items: center;

&#x20; gap: 12px;

&#x20; border-bottom: 1px solid rgba(255,255,255,.07);

&#x20; flex-shrink: 0;

}

.brand-logo {

&#x20; width: 72px; height: 72px;

&#x20; border-radius: 14px;

&#x20; overflow: hidden;

&#x20; flex-shrink: 0;

&#x20; display: flex; align-items: center; justify-content: center;

&#x20; background: rgba(255,255,255,.08);

&#x20; border: 1px solid rgba(255,255,255,.12);

}

.brand-logo img { width: 100%; height: 100%; object-fit: cover; border-radius: 13px; }

.brand-text { flex: 1; min-width: 0; text-align: center; }

.brand-text .brand-name { font-size: 13px; font-weight: 700; color: #fff; letter-spacing: -.01em; line-height: 1.3; }

.brand-text .brand-sub { font-size: 11px; color: rgba(255,255,255,.45); margin-top: 4px; letter-spacing: .02em; }

.sidebar-nav { flex: 1; padding: 12px 10px; overflow-y: auto; scrollbar-width: none; }

.sidebar-nav::-webkit-scrollbar { display: none; }

.nav-section-label {

&#x20; font-size: 9.5px; font-weight: 700; letter-spacing: .1em;

&#x20; text-transform: uppercase; color: rgba(255,255,255,.3);

&#x20; padding: 12px 8px 6px;

}

.nav-item {

&#x20; display: flex; align-items: center; gap: 10px;

&#x20; padding: 9px 10px;

&#x20; border-radius: var(--r-sm);

&#x20; cursor: pointer;

&#x20; font-size: 12.5px; font-weight: 500;

&#x20; color: rgba(255,255,255,.6);

&#x20; transition: all .18s;

&#x20; user-select: none;

&#x20; margin-bottom: 2px;

&#x20; text-decoration: none;

}

.nav-item:hover { background: rgba(255,255,255,.07); color: rgba(255,255,255,.9); }

.nav-item.active { background: rgba(45,107,228,.35); color: #fff; box-shadow: inset 2px 0 0 var(--accent); }

.nav-item .nav-icon { width: 18px; height: 18px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 15px; opacity: .8; }

.nav-item.active .nav-icon { opacity: 1; }

.nav-item .nav-badge { margin-left: auto; background: rgba(45,107,228,.5); color: rgba(255,255,255,.9); font-size: 9px; font-weight: 700; padding: 2px 6px; border-radius: 20px; letter-spacing: .04em; }

.sidebar-cta { padding: 12px 10px; border-top: 1px solid rgba(255,255,255,.07); flex-shrink: 0; }

.btn-cta-sidebar {

&#x20; display: flex; align-items: center; gap: 10px;

&#x20; width: 100%; padding: 11px 14px;

&#x20; background: linear-gradient(135deg, #2d6be4, #1e4080);

&#x20; border: none; border-radius: var(--r);

&#x20; color: #fff; font-size: 12px; font-weight: 700;

&#x20; cursor: pointer; font-family: Segoe UI, Arial, sans-serif;

&#x20; letter-spacing: .01em; transition: all .2s;

&#x20; box-shadow: 0 3px 10px rgba(45,107,228,.4);

}

.btn-cta-sidebar:hover { background: linear-gradient(135deg, #3b7af3, #2d6be4); box-shadow: 0 5px 16px rgba(45,107,228,.5); transform: translateY(-1px); }

.btn-cta-sidebar .cta-icon { font-size: 16px; flex-shrink: 0; }

.btn-cta-sidebar .cta-text { display: flex; flex-direction: column; text-align: left; }

.btn-cta-sidebar .cta-label { font-size: 11px; font-weight: 700; line-height: 1.2; }

.btn-cta-sidebar .cta-sub { font-size: 9px; font-weight: 400; opacity: .7; margin-top: 1px; }

.sidebar-footer { padding: 12px 14px; border-top: 1px solid rgba(255,255,255,.06); flex-shrink: 0; }

.sidebar-footer p { font-size: 9.5px; color: rgba(255,255,255,.25); line-height: 1.5; letter-spacing: .02em; }

.main-area { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; min-width: 0; max-width: 100%; overflow-x: hidden; }

.top-header {

&#x20; height: var(--header-h);

&#x20; background: var(--surface);

&#x20; border-bottom: 1px solid var(--border);

&#x20; display: flex; align-items: center;

&#x20; padding: 0 28px;

&#x20; gap: 16px;

&#x20; position: sticky; top: 0; z-index: 100;

&#x20; box-shadow: var(--sh);

}

.header-breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text3); }

.header-breadcrumb .crumb-sep { opacity: .4; }

.header-breadcrumb .crumb-current { font-weight: 600; color: var(--text); }

.header-search { flex: 1; max-width: 480px; margin: 0 auto; position: relative; }

.header-search input {

&#x20; width: 100%;

&#x20; background: var(--surface2);

&#x20; border: 1.5px solid var(--border);

&#x20; border-radius: 24px;

&#x20; padding: 8px 16px 8px 38px;

&#x20; font-size: 12.5px; font-family: Segoe UI, Arial, sans-serif;

&#x20; color: var(--text); outline: none;

&#x20; transition: all .18s;

}

.header-search input:focus { border-color: var(--accent); background: #fff; box-shadow: 0 0 0 3px rgba(45,107,228,.12); }

.header-search input::placeholder { color: var(--text3); }

.header-search .search-icon { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); font-size: 14px; color: var(--text3); }

.header-actions { display: flex; align-items: center; gap: 10px; margin-left: auto; }

.header-btn {

&#x20; display: flex; align-items: center; gap: 6px;

&#x20; padding: 7px 14px; border-radius: 20px;

&#x20; border: 1.5px solid var(--border);

&#x20; background: var(--surface); color: var(--text2);

&#x20; font-size: 11.5px; font-weight: 600;

&#x20; cursor: pointer; font-family: Segoe UI, Arial, sans-serif;

&#x20; transition: all .18s; text-decoration: none;

}

.header-btn:hover { border-color: var(--accent); color: var(--accent); background: #eff6ff; }

.header-btn.primary { background: var(--accent); color: #fff; border-color: var(--accent); }

.header-btn.primary:hover { background: #1e5bcc; box-shadow: 0 3px 10px rgba(45,107,228,.35); }

.page-content { flex: 1; padding: 24px 28px 48px; min-width: 0; max-width: 100%; }

.vista { display: none; }

.vista.activa { display: block; animation: fadeSlide .25s ease; }

@keyframes fadeSlide { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

.inicio-hero {

&#x20; background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);

&#x20; border-radius: var(--r-lg);

&#x20; padding: 36px 40px;

&#x20; color: #fff;

&#x20; margin-bottom: 24px;

&#x20; position: relative; overflow: hidden;

}

.inicio-hero::before { content: ''; position: absolute; right: -40px; top: -40px; width: 260px; height: 260px; border-radius: 50%; background: rgba(255,255,255,.04); }

.inicio-hero::after { content: ''; position: absolute; right: 60px; bottom: -60px; width: 180px; height: 180px; border-radius: 50%; background: rgba(45,107,228,.15); }

.hero-label { font-size: 10px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.5); margin-bottom: 10px; }

.hero-title { font-size: 26px; font-weight: 700; line-height: 1.2; letter-spacing: -.02em; margin-bottom: 10px; }

.hero-title span { color: rgba(45,107,228,.9); }

.hero-sub { font-size: 13px; color: rgba(255,255,255,.6); max-width: 440px; line-height: 1.6; margin-bottom: 24px; }

.hero-stats { display: flex; gap: 28px; flex-wrap: wrap; }

.hero-stat { display: flex; flex-direction: column; }

.hero-stat .hs-num { font-size: 22px; font-weight: 700; color: #fff; letter-spacing: -.02em; }

.hero-stat .hs-label { font-size: 10px; color: rgba(255,255,255,.45); letter-spacing: .04em; }

.cards-inicio { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; margin-bottom: 24px; }

.card-inicio {

&#x20; background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg);

&#x20; padding: 20px; cursor: pointer; transition: all .2s;

&#x20; display: flex; flex-direction: column; gap: 12px;

&#x20; box-shadow: var(--sh);

}

.card-inicio:hover { border-color: var(--accent); box-shadow: var(--sh-lg); transform: translateY(-2px); }

.card-inicio .ci-icon { width: 40px; height: 40px; border-radius: var(--r); display: flex; align-items: center; justify-content: center; font-size: 20px; }

.card-inicio .ci-title { font-size: 13px; font-weight: 700; color: var(--text); }

.card-inicio .ci-desc { font-size: 11px; color: var(--text3); line-height: 1.5; }

.card-inicio .ci-count { margin-top: auto; font-size: 20px; font-weight: 700; color: var(--navy); letter-spacing: -.02em; }

.nom-layout { display: grid; grid-template-columns: 280px 1fr; gap: 18px; align-items: start; }

.filtros-panel { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 18px; box-shadow: var(--sh); position: sticky; top: 76px; }

.filtros-title { font-size: 11px; font-weight: 700; letter-spacing: .07em; text-transform: uppercase; color: var(--text3); margin-bottom: 14px; display: flex; align-items: center; gap: 6px; }

.filtro-grupo { margin-bottom: 16px; }

.filtro-label { font-size: 10.5px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--text2); margin-bottom: 8px; display: block; }

.filtro-opts { display: flex; flex-direction: column; gap: 4px; }

.filtro-opt { display: flex; align-items: center; gap: 8px; padding: 6px 10px; border-radius: var(--r-sm); cursor: pointer; font-size: 12px; color: var(--text2); transition: all .15s; user-select: none; }

.filtro-opt:hover { background: var(--surface2); color: var(--text); }

.filtro-opt.sel { background: #eff6ff; color: var(--accent); font-weight: 600; }

.filtro-opt .fo-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; background: var(--border2); transition: background .15s; }

.filtro-opt.sel .fo-dot { background: var(--accent); }

.filtro-opt .fo-count { margin-left: auto; font-size: 10px; color: var(--text3); }

.nom-resultados { display: flex; flex-direction: column; gap: 0; }

.nom-toolbar { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }

.nom-toolbar .total-label { font-size: 11.5px; color: var(--text3); font-weight: 500; }

.nom-toolbar .total-label strong { color: var(--text); }

.nom-orden { margin-left: auto; display: flex; align-items: center; gap: 6px; }

.nom-orden label { font-size: 11px; color: var(--text3); }

.nom-orden select { border: 1.5px solid var(--border); border-radius: var(--r-sm); padding: 5px 8px; font-size: 11.5px; font-family: Segoe UI, Arial, sans-serif; color: var(--text); background: var(--surface); cursor: pointer; outline: none; }

.nom-lista { display: flex; flex-direction: column; gap: 10px; }

.nom-card {

&#x20; background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg);

&#x20; padding: 16px 20px; cursor: pointer; transition: all .2s;

&#x20; box-shadow: var(--sh);

&#x20; display: grid; grid-template-columns: auto 1fr auto;

&#x20; align-items: start; gap: 0 16px;

}

.nom-card:hover { border-color: var(--accent); box-shadow: 0 6px 24px rgba(45,107,228,.12); transform: translateX(2px); }

.nom-card.activo { border-color: var(--accent); background: linear-gradient(135deg, #f0f6ff 0%, #fff 100%); box-shadow: 0 4px 20px rgba(45,107,228,.15); }

.nc-nivel { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; margin-top: 2px; }

.nc-nivel.dir { background: #dbeafe; color: #1e40af; }

.nc-nivel.dep { background: #ede9fe; color: #5b21b6; }

.nc-nivel.div { background: #d1fae5; color: #065f46; }

.nc-nivel.sec { background: #fff7ed; color: #9a3412; }

.nc-nivel.jef { background: #fce7f3; color: #831843; }

.nc-body { min-width: 0; }

.nc-nombre { font-size: 13.5px; font-weight: 700; color: var(--navy); letter-spacing: -.01em; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.nc-meta { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }

.nc-codigo { font-family: Courier New, monospace; font-size: 10px; font-weight: 500; background: var(--surface2); border: 1px solid var(--border); color: var(--text2); padding: 2px 7px; border-radius: 4px; }

.nc-sec { font-size: 10.5px; color: var(--text3); display: flex; align-items: center; gap: 4px; }

.nc-tags { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 6px; }

.nc-tag { font-size: 9.5px; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; padding: 2px 8px; border-radius: 20px; }

.nc-tag.adm { background: #dbeafe; color: #1e40af; }

.nc-tag.ope { background: #d1fae5; color: #065f46; }

.nc-tag.tec { background: #ede9fe; color: #5b21b6; }

.nc-tag.ins { background: #fff7ed; color: #9a3412; }

.nc-tag.svt { background: #fce7f3; color: #831843; }

.nc-right { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; }

.nc-arrow { color: var(--text3); font-size: 16px; margin-top: 2px; }

.detalle-overlay { position: fixed; inset: 0; z-index: 300; background: rgba(11,29,58,.45); display: none; align-items: stretch; justify-content: flex-end; }

.detalle-overlay.abierto { display: flex; animation: fadeIn .2s ease; }

@keyframes fadeIn { from{opacity:0} to{opacity:1} }

.detalle-panel { width: min(640px, 95vw); background: var(--surface); overflow-y: auto; display: flex; flex-direction: column; animation: slideRight .25s cubic-bezier(.34,1.2,.64,1); box-shadow: -8px 0 40px rgba(11,29,58,.18); }

@keyframes slideRight { from { transform: translateX(100%); } to { transform: translateX(0); } }

.detalle-header { padding: 20px 24px 16px; border-bottom: 1px solid var(--border); display: flex; align-items: flex-start; gap: 14px; position: sticky; top: 0; background: var(--surface); z-index: 10; }

.detalle-close { margin-left: auto; flex-shrink: 0; background: none; border: none; cursor: pointer; color: var(--text3); font-size: 18px; padding: 4px; border-radius: 6px; transition: all .15s; line-height: 1; }

.detalle-close:hover { color: var(--red); background: var(--red-pale); }

.dh-icono { width: 44px; height: 44px; border-radius: 10px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 22px; }

.dh-icono.dir { background: #dbeafe; }

.dh-icono.dep { background: #ede9fe; }

.dh-icono.div { background: #d1fae5; }

.dh-icono.sec { background: #fff7ed; }

.dh-info .dh-nivel { font-size: 9.5px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text3); margin-bottom: 3px; }

.dh-info .dh-nombre { font-size: 16px; font-weight: 700; color: var(--navy); letter-spacing: -.02em; line-height: 1.25; }

.dh-info .dh-codigo { font-family: Courier New, monospace; font-size: 11px; color: var(--text2); margin-top: 4px; display: flex; align-items: center; gap: 6px; }

.dh-codigo .copy-btn { background: none; border: none; cursor: pointer; font-size: 12px; color: var(--text3); padding: 1px 4px; border-radius: 4px; transition: all .15s; }

.dh-codigo .copy-btn:hover { color: var(--accent); background: #eff6ff; }

.detalle-tabs { display: flex; gap: 0; border-bottom: 1px solid var(--border); padding: 0 24px; flex-shrink: 0; }

.det-tab { padding: 12px 16px; font-size: 12px; font-weight: 600; color: var(--text3); cursor: pointer; border-bottom: 2px solid transparent; transition: all .15s; user-select: none; letter-spacing: .01em; }

.det-tab:hover { color: var(--text2); }

.det-tab.activo { color: var(--accent); border-bottom-color: var(--accent); }

.detalle-body { flex: 1; padding: 22px 24px; }

.det-section { margin-bottom: 24px; }

.det-section-title { font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text3); margin-bottom: 10px; display: flex; align-items: center; gap: 6px; }

.det-section-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }

.det-mision { font-size: 13px; line-height: 1.7; color: var(--text2); background: var(--surface2); border-radius: var(--r); padding: 14px 16px; border: 1px solid var(--border); }

.det-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

.det-info-item { background: var(--surface2); border-radius: var(--r); padding: 12px 14px; border: 1px solid var(--border); }

.det-info-item .dii-label { font-size: 9.5px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--text3); margin-bottom: 5px; }

.det-info-item .dii-val { font-size: 12.5px; font-weight: 600; color: var(--navy); }

.det-info-item .dii-val.mono { font-family: Courier New, monospace; font-size: 12px; }

.det-req-list { display: flex; flex-direction: column; gap: 8px; }

.det-req-item { display: flex; align-items: flex-start; gap: 10px; padding: 10px 14px; background: var(--surface2); border-radius: var(--r); border: 1px solid var(--border); font-size: 12px; color: var(--text2); }

.det-req-item .dr-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }

.det-req-item .dr-check { margin-left: auto; font-size: 12px; flex-shrink: 0; }

.det-req-item.cumple .dr-check { color: var(--green); }

.det-req-item.no-cumple .dr-check { color: var(--text3); }

.org-container { background: var(--surface); border-radius: var(--r-lg); border: 1px solid var(--border); box-shadow: var(--sh); overflow: hidden; max-width: 100%; }

.org-toolbar { padding: 14px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 12px; }

.org-toolbar select { border: 1.5px solid var(--border); border-radius: var(--r-sm); padding: 6px 10px; font-size: 12px; font-family: Segoe UI, Arial, sans-serif; color: var(--text); outline: none; cursor: pointer; }

.org-layout { display: flex; gap: 0; }

.org-area { min-height: 500px; padding: 32px; overflow-x: auto; display: flex; justify-content: flex-start; align-items: flex-start; flex: 1; min-width: 0; }

.org-dropdown { position: absolute; top: 12px; right: 12px; width: 280px; max-height: calc(100% - 24px); background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg); box-shadow: var(--sh-lg); overflow-y: auto; display: none; z-index: 20; }

.org-dropdown.visible { display: block; }

.org-sidebar-header { padding: 12px 14px; font-size: 11px; font-weight: 700; color: var(--navy); text-transform: uppercase; letter-spacing: .05em; border-bottom: 1px solid var(--border); background: var(--surface2); position: sticky; top: 0; }

.org-sidebar-item { padding: 7px 14px; font-size: 11.5px; color: var(--text); cursor: pointer; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 6px; transition: background .12s; }

.org-sidebar-item:hover { background: var(--surface2); }

.org-sidebar-item .osi-codigo { font-family: Courier New, monospace; font-size: 9px; color: var(--text3); min-width: 50px; flex-shrink: 0; }

.org-area > div { margin: 0 auto; }

.org-area::-webkit-scrollbar { height: 8px; }

.org-area::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 4px; }

.org-tree { display: flex; flex-direction: column; align-items: center; gap: 0; }

.org-level { display: flex; gap: 16px; justify-content: center; }

.org-node-wrap { display: flex; flex-direction: column; align-items: center; }

.org-connector-v { width: 2px; height: 24px; background: var(--border2); flex-shrink: 0; }



/\* ── Conectores de organigrama tipo árbol (línea horizontal entre hermanos + tallos verticales) ── \*/

.org-stem-down { width: 2px; height: 22px; background: var(--border2); flex-shrink: 0; }

.org-children {

&#x20; display: flex;

&#x20; flex-wrap: nowrap;

&#x20; justify-content: flex-start;

&#x20; gap: 18px;

&#x20; margin: 0 auto;

}

.org-child {

&#x20; position: relative;

&#x20; display: flex;

&#x20; flex-direction: column;

&#x20; align-items: center;

}

.org-child::before,

.org-child::after {

&#x20; content: '';

&#x20; position: absolute;

&#x20; top: 0;

&#x20; height: 0;

&#x20; border-top: 2px solid var(--border2);

}

.org-child::before { left: -9px; width: calc(50% + 9px); }

.org-child::after  { right: -9px; width: calc(50% + 9px); }

.org-child:first-child::before,

.org-child:last-child::after,

.org-child:only-child::before,

.org-child:only-child::after { display: none; }

.org-stem-v { width: 2px; height: 20px; background: var(--border2); }

.org-node { background: var(--surface); border: 1.5px solid var(--border); border-radius: var(--r); padding: 8px 10px; min-width: 104px; max-width: 140px; text-align: center; cursor: pointer; transition: all .2s; box-shadow: var(--sh); }

.org-node:hover { border-color: var(--accent); box-shadow: var(--sh-lg); }

.org-node.root { background: var(--navy); border-color: var(--navy); color: #fff; }

.org-node.secretaria { background: #dbeafe; border-color: #93c5fd; }

.org-node.direccion { background: var(--surface); border-color: var(--border2); }

.org-node.jefatura { background: var(--surface2); border-color: var(--border); font-size: 11px; }

.org-node.destacado { border-color: var(--accent) !important; background: #eff6ff !important; box-shadow: 0 0 0 4px rgba(59,130,246,.4), var(--sh-lg) !important; animation: destacado-pulse 1s ease-in-out infinite; }

@keyframes destacado-pulse { 0%,100% { box-shadow: 0 0 0 4px rgba(59,130,246,.4), var(--sh-lg); } 50% { box-shadow: 0 0 0 10px rgba(59,130,246,.08), var(--sh-lg); } }

.on-icono { font-size: 16px; margin-bottom: 3px; display: block; }

.on-nombre { font-size: 10.5px; font-weight: 700; line-height: 1.25; }

.org-node.root .on-nombre { color: #fff; }

.org-node.secretaria .on-nombre { color: #1e40af; }

.on-codigo { font-family: Courier New, monospace; font-size: 9px; color: var(--text3); margin-top: 3px; }

.org-node.root .on-codigo { color: rgba(255,255,255,.5); }

.areas-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }

.area-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg); overflow: hidden; cursor: pointer; transition: all .2s; box-shadow: var(--sh); }

.area-card:hover { box-shadow: var(--sh-lg); transform: translateY(-2px); }

.area-card-header { padding: 16px 18px; display: flex; align-items: center; gap: 12px; border-bottom: 1px solid var(--border); }

.area-icon { width: 38px; height: 38px; border-radius: 9px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 18px; }

.area-card-header .ar-titulo { font-size: 12.5px; font-weight: 700; color: var(--navy); }

.area-card-header .ar-codigo { font-family: Courier New, monospace; font-size: 9.5px; color: var(--text3); margin-top: 2px; }

.area-card-body { padding: 12px 18px; }

.area-stat-row { display: flex; gap: 16px; }

.area-stat { display: flex; flex-direction: column; }

.area-stat .as-num { font-size: 18px; font-weight: 700; color: var(--navy); }

.area-stat .as-label { font-size: 10px; color: var(--text3); }

.registro-vista { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg); overflow: hidden; box-shadow: var(--sh); }

.registro-topbar { padding: 14px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 12px; background: linear-gradient(90deg, #f0f6ff 0%, var(--surface) 100%); }

