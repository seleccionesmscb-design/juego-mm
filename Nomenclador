.print-header { margin-bottom: 18px; padding-bottom: 12px; border-bottom: 2px solid var(--navy); }

.print-nombre { font-size: 18px; font-weight: 700; color: var(--navy); }

.print-meta { font-size: 11px; color: var(--text3); margin-top: 4px; }

@media print {

&#x20; .app-shell, .detalle-overlay, #toast { display: none !important; }

