.registro-topbar .rt-sub { font-size: 11px; color: var(--text3); margin-top: 1px; }

.registro-iframe { width: 100%; height: calc(100vh - 180px); border: none; background: var(--bg); }

.page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }

.page-header-left .ph-title { font-size: 20px; font-weight: 700; color: var(--navy); letter-spacing: -.02em; }

.page-header-left .ph-sub { font-size: 12px; color: var(--text3); margin-top: 3px; }

.empty-state { text-align: center; padding: 56px 32px; display: flex; flex-direction: column; align-items: center; gap: 12px; }

.empty-state .es-icon { font-size: 40px; opacity: .35; }

.empty-state .es-title { font-size: 15px; font-weight: 700; color: var(--text); }

.empty-state .es-sub { font-size: 12px; color: var(--text3); max-width: 320px; line-height: 1.6; }

\#toast { position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%); background: var(--navy); color: #fff; padding: 11px 22px; border-radius: 30px; font-size: 12.5px; font-weight: 500; font-family: Segoe UI, Arial, sans-serif; box-shadow: var(--sh-lg); z-index: 999; display: none; }

\#toast.visible { display: block; animation: fadeUp .3s ease; }

\#toast.ok { background: var(--green); }

@keyframes fadeUp { from { opacity:0; transform: translateX(-50%) translateY(10px); } to { opacity:1; transform: translateX(-50%) translateY(0); } }

@media (max-width: 1024px) { .nom-layout { grid-template-columns: 1fr; } .filtros-panel { position: static; } }

@media (max-width: 768px) { :root { --sidebar-w: 0px; } .sidebar { display: none; } .main-area { margin-left: 0; } }

.loader-full { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 300px; gap: 14px; }

.spinner { width: 32px; height: 32px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin .65s linear infinite; }

@keyframes spin { to { transform: rotate(360deg); } }

.loader-full p { font-size: 12px; color: var(--text3); }

.chip { display: inline-flex; align-items: center; gap: 4px; font-size: 9.5px; font-weight: 700; letter-spacing: .05em; text-transform: uppercase; padding: 3px 9px; border-radius: 20px; }

.chip-blue { background: #dbeafe; color: #1e40af; }

.chip-purple { background: #ede9fe; color: #5b21b6; }

.chip-green { background: #d1fae5; color: #065f46; }

.chip-amber { background: #fef3c7; color: #92400e; }

.chip-red { background: #fee2e2; color: #991b1b; }

.chip-gray { background: var(--surface2); color: var(--text2); border: 1px solid var(--border); }

.tab-content { display: none; }

.tab-content.activo { display: block; }

/\* Badge de tipo puesto en tarjeta \*/

.nc-tag.puesto { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }

/\* Iconos SVG: heredan tamaño y color del texto contenedor \*/

.icon-svg { width: 1em; height: 1em; display: inline-block; vertical-align: -0.15em; flex-shrink: 0; }

