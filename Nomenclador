&#x20;     if (!seen\[p.nombreCargo]) { seen\[p.nombreCargo] = true; unique.push(p); }

&#x20;   });

&#x20;   sidebarTitulo.innerHTML = 'Puestos del \\xE1rea (' + unique.length + ')' +

&#x20;     '<button onclick="toggleOrgPuestos(false)" style="float:right;background:none;border:none;cursor:pointer;color:var(--text3);padding:0;line-height:1">' +

&#x20;       '<svg style="width:14px;height:14px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>';

&#x20;   if (unique.length === 0) {

&#x20;     sidebarLista.innerHTML = '<div style="padding:14px;font-size:11px;color:var(--text3)">Sin puestos no jerárquicos en este área</div>';

&#x20;   } else {

&#x20;     sidebarLista.innerHTML = unique.map(function(p){

&#x20;       var cod = esc(p.codigo);

&#x20;       var onclick = 'abrirDetalle(\\'' + cod + '\\',\\'nojerarquico\\')';

&#x20;       return '<div class="org-sidebar-item" onclick="' + onclick + '">' +

&#x20;         '<span class="osi-codigo">' + (p.tipoPuesto || '') + '</span>' +

&#x20;         '<span style="flex:1">' + (p.nombreCargo || '') + '</span>' +

&#x20;       '</div>';

&#x20;     }).join('');

&#x20;   }

&#x20;   if (toggleBtn) { toggleBtn.style.display = ''; }

&#x20;   if (toggleLbl) { toggleLbl.textContent = 'Puestos del \\xE1rea (' + unique.length + ')'; }

&#x20;   sidebar.classList.remove('visible'); // cerrado por defecto al re-renderizar

&#x20; } else {

&#x20;   if (sidebar) sidebar.classList.remove('visible');

&#x20;   if (toggleBtn) toggleBtn.style.display = 'none';

&#x20; }



&#x20; if (orgCodigoDestacado) {

&#x20;   var codigoTarget = orgCodigoDestacado;

&#x20;   orgCodigoDestacado = null;

&#x20;   setTimeout(function() {

&#x20;     var el = document.getElementById('org-node-' + codigoTarget);

&#x20;     if (el) {

&#x20;       el.scrollIntoView({ behavior: 'smooth', block: 'center', inline: 'center' });

&#x20;       el.classList.add('destacado');

&#x20;     }

&#x20;   }, 120);

&#x20; }

}



