function obtenerHojaRanking(ss) {
  let hoja = ss.getSheetByName("Ranking");
  if (!hoja) {
    hoja = ss.insertSheet("Ranking");
    hoja.appendRow(["Legajo","NombreAgente","Equipo","Direccion","Puntaje","Nivel","TotalRecursos","Insignias","Fecha"]);
  }
  return hoja;
}

function guardarResultado(estado, puntaje) {
  const ss = SpreadsheetApp.openById(SS_ID);
  const hoja = obtenerHojaRanking(ss);
  const legajoStr = String(estado.legajo).trim();
  const datos = hoja.getDataRange().getValues();

  let filaIdx = -1;
  for (let i = 1; i < datos.length; i++) {
    if (String(datos[i][0]).trim() === legajoStr) { filaIdx = i + 1; break; }
  }

  const fila = [
    estado.legajo,
    estado.nombreAgente,
    estado.nombreEquipo || ("Dirección de " + estado.direccion),
    estado.direccion,
    puntaje.puntaje || 0,
    puntaje.nivel || "",
    puntaje.totalRecursos || 0,
    puntaje.insignias || 0,
    new Date()
  ];

  if (filaIdx > 0) hoja.getRange(filaIdx, 1, 1, fila.length).setValues([fila]);
  else hoja.appendRow(fila);
}

function obtenerRanking() {
  const ss = SpreadsheetApp.openById(SS_ID);
  const hoja = obtenerHojaRanking(ss);
  const datos = hoja.getDataRange().getValues().slice(1)
    .filter(f => f[0])
    .map(f => ({
      legajo:    String(f[0]).trim(),
      nombre:    f[1] || "",
      equipo:    f[2] || "",
      direccion: f[3] || "",
      puntaje:   Number(f[4]) || 0,
      nivel:     f[5] || "",
      recursos:  Number(f[6]) || 0,
      insignias: Number(f[7]) || 0
    }));

  datos.sort((a, b) => b.puntaje - a.puntaje);
  return datos.slice(0, 10);
}

