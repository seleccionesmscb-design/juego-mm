function obtenerRanking() {
  const ss = SpreadsheetApp.openById(SS_ID);
  const hoja = obtenerHojaRanking(ss);
  const datos = hoja.getDataRange().getValues().slice(1)
    .filter(f => f[0])
    .map(f => ({
      legajo:    String(f[0]).trim(),
      nombre:    f[1] || "",
      equipo:    f[2] || "",
      direccion: f[3] || "",
      puntaje:   Number(f[4]) || 0,
      nivel:     f[5] || "",
      recursos:  Number(f[6]) || 0,
      insignias: Number(f[7]) || 0
    }));

  datos.sort((a, b) => b.puntaje - a.puntaje);
  return datos.slice(0, 10);
}

