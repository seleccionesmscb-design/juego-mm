// ─────────────────────────────────────────────
// COMPETENCIAS DE GESTIÓN (reemplazan a los indicadores)
// ─────────────────────────────────────────────
function cargarCompetencias(ss) {
  const DEFAULTS = [
    { codigo: "Liderazgo",          nombre: "Liderazgo" },
    { codigo: "Planificación",      nombre: "Planificación" },
    { codigo: "Gestión de equipo",  nombre: "Gestión de equipo" },
    { codigo: "Comunicación",       nombre: "Comunicación" }
  ];
  const hoja = ss.getSheetByName("Situaciones y respuestas");
  if (!hoja) return DEFAULTS;
  const mapa = {};
  hoja.getDataRange().getValues().slice(1).forEach(function(f) {
    const nombre = String(f[5] || "").trim();
    if (nombre && !mapa[nombre]) mapa[nombre] = { codigo: nombre, nombre: nombre };
  });
  const res = Object.values(mapa);
  return res.length ? res : DEFAULTS;
}

function competenciasIniciales(catalogo) {
  const comp = {};
  catalogo.forEach(c => { comp[c.codigo] = 0; });
  return comp;
}

// ─────────────────────────────────────────────
// GUARDAR / RETOMAR PROGRESO POR LEGAJO
// Se guarda el estado completo como JSON en la hoja "Progreso" (se
// crea sola con sus encabezados la primera vez). No toca la hoja
// "Partidas" existente para no romper datos manuales previos.
// ─────────────────────────────────────────────
function obtenerHojaProgreso(ss) {
  let hoja = ss.getSheetByName("Progreso");
  if (!hoja) {
    hoja = ss.insertSheet("Progreso");
    hoja.appendRow(["Legajo", "NombreAgente", "Direccion", "Casillero", "Encuentro", "UltimaActividad", "EstadoJSON"]);
  }
  return hoja;
}

function guardarProgreso(estado) {
  const ss = SpreadsheetApp.openById(SS_ID);
  const hoja = obtenerHojaProgreso(ss);
  const legajoStr = String(estado.legajo).trim();
  const datos = hoja.getDataRange().getValues();

  let filaIdx = -1;
  for (let i = 1; i < datos.length; i++) {
    if (String(datos[i][0]).trim() === legajoStr) { filaIdx = i + 1; break; }
  }

  const fila = [
    estado.legajo, estado.nombreAgente, estado.direccion,
    estado.casillero, estado.encuentro, new Date(), JSON.stringify(estado)
  ];

  if (filaIdx > 0) hoja.getRange(filaIdx, 1, 1, fila.length).setValues([fila]);
  else hoja.appendRow(fila);
}

function cargarProgreso(legajo) {
  const ss = SpreadsheetApp.openById(SS_ID);
  const hoja = obtenerHojaProgreso(ss);
  const legajoStr = String(legajo).trim();
  const datos = hoja.getDataRange().getValues().slice(1);

  for (const fila of datos) {
    if (String(fila[0]).trim() === legajoStr) {
      try {
        return JSON.parse(fila[6]);
      } catch (e) {
        return null;
      }
    }
  }
  return null;
}

// ─────────────────────────────────────────────
// INICIO DEL JUEGO (MEJORADO)
// ─────────────────────────────────────────────
function iniciarPartida(legajo, direccion, nombreEquipo, nombreLider) {
  const ss = SpreadsheetApp.openById(SS_ID);

  // Validación básica
  const val = validarLegajo(legajo);
  if (!val.valido) return { error: val.mensaje };

  // Buscar el agente en la base de datos
  const agente = buscarAgente(legajo);
  if (!agente.encontrado) {
    return { error: "Legajo no encontrado. Por favor, verificá que sea correcto." };
  }

  const catalogoCompetencias = cargarCompetencias(ss);

  // Si el legajo ya tiene una partida guardada, se retoma donde quedó
  let estado = cargarProgreso(agente.legajo);
  let retomada = !!estado;

  if (estado) {
    // Compatibilidad con partidas guardadas antes de sumar puntaje/4 cartas por situación
    if (typeof estado.puntaje !== "number") estado.puntaje = 0;
    if (!estado.situacionActualId) estado.situacionActualId = "";
    if (!estado.recursos) estado.recursos = {};
    ["desarrollo", "clima", "recursos", "planificacion", "desempenio"].forEach(k => {
      if (!estado.recursos.hasOwnProperty(k)) estado.recursos[k] = 0;
    });
  }

  if (!estado) {
    estado = {
      legajo:       String(agente.legajo).trim(),
      nombreAgente: agente.nombre,
      nombreEquipo: nombreEquipo || ("Dirección de " + agente.direccion),
      nombreLider:  nombreLider,
      direccion:    agente.direccion,
      equipo:       obtenerEquipo(agente.direccion),
      casillero:    0,
      recursos:     { desarrollo: 0, clima: 0, recursos: 0, planificacion: 0, desempenio: 0 },
      herramientas: [],
      insignias:    [],
      competencias: competenciasIniciales(catalogoCompetencias),
      puntaje:      0,
      situacionActualId: "",
      encuentro:    1
    };
    guardarProgreso(estado);
  }

  const situacion = obtenerSituacionAleatoria(ss, estado.direccion, estado.casillero);
  estado.situacionActualId = situacion.id;
  guardarProgreso(estado);

  return {
    estado:              estado,
    retomada:            retomada,
    situacion:           situacion,
    cartas:               cargarAcciones(ss, estado.herramientas, situacion.id),
    biblioteca:           cargarHerramientas(ss),
    competenciasCatalogo: catalogoCompetencias
  };
}

// ─────────────────────────────────────────────
// HERRAMIENTAS / MICROLEARNING
// Columnas: ID | Nombre | Contenido | Área | InsigniaID | Pregunta |
//           RespuestaCorrecta | Competencia | VideoURL* | InfografiaURL* |
//           OpcionA* | OpcionB* | OpcionC* | OpcionD*
// (*) Opcionales: si la hoja todavía no tiene esas columnas quedan
// vacías. Sin VideoURL/InfografiaURL la tarjeta muestra solo texto.
// Sin OpcionA..D la pregunta se responde con texto libre (como antes);
// si hay al menos 2 opciones cargadas, se muestra como opción múltiple
// y RespuestaCorrecta debe coincidir con el texto de la opción correcta.
// ─────────────────────────────────────────────
// Columnas hoja "Herramientas (contenido)":
// 0=Herramienta 1=Nivel 2=Área 3=Competencia 4=Contenido 5=Pregunta1 6=Respuesta1
// 7=OpcionA1 8=OpcionB1 9=OpcionC1 10=OpcionD1 11=VideoUrl 12=InfografiaUrl 13=InsigniaID
// 14=Era 15=Puntaje
// 16=Pregunta2 17=Respuesta2 18=OpcionA2 19=OpcionB2 20=OpcionC2 21=OpcionD2
// 22=Pregunta3 23=Respuesta3 24=OpcionA3 25=OpcionB3 26=OpcionC3 27=OpcionD3
function cargarHerramientas(ss) {
  const hoja = ss.getSheetByName("Herramientas (contenido)");
  if (!hoja) return [];
  return hoja.getDataRange().getValues().slice(1)
    .filter(function(f){ return String(f[0]).trim() !== ""; })
    .map(function(f) {
      const nombre = String(f[0]).trim();
      function opcArr(a, b, c, d) {
        return [a,b,c,d].map(function(o){ return (o||"").toString().trim(); }).filter(Boolean);
      }
      const preguntas = [];
      if (String(f[5]||"").trim()) preguntas.push({
        pregunta: String(f[5]).trim(),
        respuesta: String(f[6]||"si").trim().toLowerCase(),
        opciones: opcArr(f[7],f[8],f[9],f[10])
      });
      if (String(f[16]||"").trim()) preguntas.push({
        pregunta: String(f[16]).trim(),
        respuesta: String(f[17]||"").trim().toLowerCase(),
        opciones: opcArr(f[18],f[19],f[20],f[21])
      });
      if (String(f[22]||"").trim()) preguntas.push({
        pregunta: String(f[22]).trim(),
        respuesta: String(f[23]||"").trim().toLowerCase(),
        opciones: opcArr(f[24],f[25],f[26],f[27])
      });
      return {
        id:            nombre,
        nombre:        nombre,
        nivel:         String(f[1] || "").trim(),
        area:          String(f[2] || "").trim(),
        competencia:   String(f[3] || "").trim(),
        contenido:     String(f[4] || "").trim(),
        era:           String(f[14]|| "").trim(),
        puntaje:       Number(f[15]) || 0,
        pregunta:      preguntas.length ? preguntas[0].pregunta : "¿Confirmás la lectura del módulo?",
        respuesta:     preguntas.length ? preguntas[0].respuesta : "si",
        opcionA:       String(f[7] || "").trim(),
        opcionB:       String(f[8] || "").trim(),
        opcionC:       String(f[9] || "").trim(),
        opcionD:       String(f[10] || "").trim(),
        videoUrl:      String(f[11] || "").trim(),
        infografiaUrl: String(f[12] || "").trim(),
        insigniaID:    String(f[13] || "").trim(),
        opciones:      preguntas.length ? preguntas[0].opciones : [],
        preguntas:     preguntas
      };
    });
}

function completarCapacitacion(estado, toolID, insigniaID) {
  const ss = SpreadsheetApp.openById(SS_ID);

  if (!estado.herramientas.includes(toolID)) estado.herramientas.push(toolID);
  if (insigniaID && !estado.insignias.includes(insigniaID)) estado.insignias.push(insigniaID);

  // Fortalecer la competencia de la herramienta (matching normalizado para evitar problemas de tildes)
  const herramienta = cargarHerramientas(ss).find(function(h){ return h.id === toolID; });
  const cod = hallCompetencia(estado, herramienta ? herramienta.competencia : "");
  if (cod) {
    estado.competencias[cod] = Math.min(5, (estado.competencias[cod] || 0) + 1);
  }

  // Sumar el puntaje de la herramienta (5 o 10 pts) al score general
  if (herramienta && herramienta.puntaje) {
    estado.puntaje = (estado.puntaje || 0) + herramienta.puntaje;
  }

  guardarProgreso(estado);
  return { estado, cartas: cargarAcciones(ss, estado.herramientas, estado.situacionActualId) };
}

// ─────────────────────────────────────────────
// SELECCIÓN DE SITUACIONES
// ─────────────────────────────────────────────
function eraDeCasillero(casillero) {
  const n = casillero + 1;
  if (n <= CASILLEROS_POR_ERA) return "ERA I";
  if (n <= CASILLEROS_POR_ERA * 2) return "ERA II";
  return "ERA III";
}

function filaMatchEra(eraStr, tag) {
  const s = eraStr.toUpperCase();
  if (tag === "ERA I")   return s.indexOf("I ORGAN") > -1 || s === "ERA I";
  if (tag === "ERA II")  return s.indexOf("II GESTI") > -1 || s === "ERA II";
  return s.indexOf("III DESAR") > -1 || s === "ERA III";
}

function obtenerSituacionAleatoria(ss, area, casillero) {
  const hoja = ss.getSheetByName("Situaciones y respuestas");
  if (!hoja) return { id: "", titulo: "Sin datos", desc: "Verificá la hoja 'Situaciones y respuestas'.", tipo: "situacion" };

  const tag  = eraDeCasillero(casillero || 0);

  // Forward-fill ERA/Área/Situación/Descripción para soportar sheets con celdas combinadas o vacías
  let curEra = '', curArea = '', curNombre = '', curDesc = '', curComp = '', curTray = '';
  const mapa = {};
  hoja.getDataRange().getValues().slice(1).forEach(function(f) {
    if (String(f[0]).trim()) curEra    = String(f[0]).trim();
    if (String(f[1]).trim()) curTray   = String(f[1]).trim();
    if (String(f[2]).trim()) curArea   = String(f[2]).trim();
    if (String(f[3]).trim()) { curNombre = String(f[3]).trim(); curDesc = String(f[4]).trim(); curComp = String(f[5]).trim(); }
    if (!curEra || !curNombre) return;
    if (!filaMatchEra(curEra, tag)) return;
    const key = curEra + "||" + curArea + "||" + curNombre;
    if (!mapa[key]) {
      mapa[key] = {
        id:          key,
        titulo:      curNombre,
        desc:        curDesc,
        competencia: curComp,
        era:         curEra,
        area:        curArea,
        trayecto:    curTray,
        tipo:        "situacion"
      };
    }
  });

  let candidatos = Object.values(mapa);
  if (!candidatos.length) return { id: "", titulo: "Sin situaciones", desc: "No hay situaciones cargadas para esta Era.", tipo: "situacion" };

  const porArea = candidatos.filter(function(s){ return s.area.toLowerCase() === (area || "").toLowerCase(); });
  if (porArea.length) candidatos = porArea;

  return candidatos[Math.floor(Math.random() * candidatos.length)];
}

// ─────────────────────────────────────────────
// ACCIONES / CARTAS
// ─────────────────────────────────────────────
// Por eso cargarAcciones ahora exige situacionId y filtra: solo entran las
// cartas genéricas (sin Situación_ID) y las que coincidan con la situación
// actual. Sin este filtro se mostrarían las cartas de las 35 situaciones
// juntas en cada pantalla.
// ─────────────────────────────────────────────
function cargarAcciones(ss, herramientasUsuario, situacionId) {
  if (!situacionId) return [];
  const partes = situacionId.split("||");
  if (partes.length < 3) return [];
  const eraStr  = partes[0];
  const areaStr = partes[1];
  const nombre  = partes[2];

  const hoja = ss.getSheetByName("Situaciones y respuestas");
  if (!hoja) return [];

  // Forward-fill ERA/Área/Situación/Competencia: si una fila las tiene vacías hereda la fila anterior.
  // Esto soporta sheets donde solo la primera carta de cada situación tiene esos campos.
  let curEra = '', curArea = '', curNombre = '', curComp = '';
  const rows = [];
  hoja.getDataRange().getValues().slice(1).forEach(function(f) {
    if (String(f[0]).trim()) curEra    = String(f[0]).trim();
    if (String(f[2]).trim()) curArea   = String(f[2]).trim();
    if (String(f[3]).trim()) { curNombre = String(f[3]).trim(); curComp = String(f[5]).trim(); }
    if (curEra === eraStr && curArea === areaStr && curNombre === nombre) {
      rows.push([f, curComp]);
    }
  });

  return rows.map(function(item) {
    const f    = item[0];
    const comp = item[1];
    const tipo     = String(f[7]).trim();
    const herr     = String(f[10] || "").trim();
    const tipoNorm = tipo.toLowerCase()
      .normalize("NFD").replace(/[̀-ͯ]/g, "");
    const req  = (tipoNorm.includes("herramienta") && herr) ? herr : "";
    const pts  = Number(f[9]) || 0;
    return {
      id:               situacionId + "_C" + f[6],
      texto:            String(f[8]).trim(),
      puntaje:          pts,
      valor:            pts,   // usado por el frontend en seleccionarCarta / procesarAccion
      cat:              comp,  // competencia → determina colores de la carta
      competencia:      comp,
      req:              req,
      herramientaNombre: herr,
      tipo:             tipo,
      bloqueada:        req !== "" && !(herramientasUsuario || []).includes(req)
    };
  });
}

// ─────────────────────────────────────────────
// HELPERS — competencias
// ─────────────────────────────────────────────
function normStr(s) {
  return String(s || '').trim().toLowerCase()
    .normalize("NFD").replace(/[̀-ͯ]/g, "");
}

// Busca la clave exacta en estado.competencias que coincide (normalizado) con cat
function hallCompetencia(estado, cat) {
  const n = normStr(cat);
  if (!n) return "";
  return Object.keys(estado.competencias || {})
    .find(function(k){ return normStr(k) === n; }) || "";
}

// ─────────────────────────────────────────────
// PROCESAR ACCIÓN
// ─────────────────────────────────────────────
function procesarAccion(estado, accionID, cat, recursoGanado, cantidadRecurso, valorImpacto) {
  const ss = SpreadsheetApp.openById(SS_ID);
  estado.casillero += 1;
  estado.puntaje = (estado.puntaje || 0) + (Number(valorImpacto) || 0);

  if (recursoGanado && estado.recursos.hasOwnProperty(recursoGanado)) {
    estado.recursos[recursoGanado] += (Number(cantidadRecurso) || 0);
  }

  // Fortalecer la competencia de la carta jugada (+1 por acción)
  const compKey = hallCompetencia(estado, cat);
  if (compKey) {
    estado.competencias[compKey] = Math.min(5, (estado.competencias[compKey] || 0) + 1);
  }

  const esFinalizado = estado.casillero >= TOTAL_CASILLEROS;
  const esEncuentro  = !esFinalizado && estado.casillero % CASILLEROS_POR_ERA === 0;
  if (esEncuentro) estado.encuentro += 1;

  const situacion = esFinalizado
    ? { id: "", titulo: "¡MISIÓN CUMPLIDA!", desc: "Llegaste al encuentro final con las competencias fortalecidas para transformar la gestión.", tipo: "final" }
    : obtenerSituacionAleatoria(ss, estado.direccion, estado.casillero);
  estado.situacionActualId = situacion.id || "";

  guardarProgreso(estado);

  return {
    estado,
    situacion:    situacion,
    cartas:       esFinalizado ? [] : cargarAcciones(ss, estado.herramientas, situacion.id),
    finalizado:   esFinalizado,
    encuentro:    esEncuentro,
    nroEncuentro: estado.encuentro
  };
}

// ─────────────────────────────────────────────
// PUNTAJE FINAL — basado en Competencias de Gestión
// ─────────────────────────────────────────────
function calcularPuntajeFinal(estado) {
  const ss = SpreadsheetApp.openById(SS_ID);
  const catalogo = cargarCompetencias(ss);
  const valores = catalogo.map(c => estado.competencias[c.codigo] || 0);
  const prom = valores.length ? valores.reduce((a, b) => a + b, 0) / valores.length : 0;
  const recTot = Object.values(estado.recursos || {}).reduce((a, b) => a + (Number(b) || 0), 0);
  const fortalecidas = catalogo
    .filter(c => (estado.competencias[c.codigo] || 0) > 0)
    .map(c => c.nombre);

  return {
    promedioCompetencias:    prom.toFixed(1),
    competenciasFortalecidas: fortalecidas,
    totalRecursos: recTot,
    puntaje: estado.puntaje || 0,
    insignias: estado.insignias.length,
    nivel: prom >= 4 ? "Excelente" : prom >= 2.5 ? "Bueno" : "En desarrollo"
  };
}

