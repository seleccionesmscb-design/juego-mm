// ─────────────────────────────────────────────
// VALIDAR LEGAJO (MEJORADO)
// ─────────────────────────────────────────────
function validarLegajo(legajo) {
  // Validación básica: legajo debe tener 3-20 caracteres (números, letras, guiones)
  const num = String(legajo).trim();
  if (!/^[a-zA-Z0-9\-]{3,20}$/.test(num)) {
    return { valido: false, mensaje: "El legajo debe tener 3-20 caracteres (números, letras)." };
  }
  return { valido: true, mensaje: "Legajo válido" };
}

// ─────────────────────────────────────────────
// BUSCAR AGENTE POR LEGAJO
// ─────────────────────────────────────────────
function buscarAgente(legajo) {
  const ss = SpreadsheetApp.openById(SS_ID);
  const hoja = ss.getSheetByName("Agentes");
  if (!hoja) return { encontrado: false };

  const datos = hoja.getDataRange().getValues().slice(1); // saltar cabecera
  const legajoStr = String(legajo).trim();

  for (const fila of datos) {
    if (String(fila[0]).trim() === legajoStr) {
      return {
        encontrado: true,
        legajo: fila[0],
        nombre: fila[1],
        direccion: fila[2]
      };
    }
  }
  return { encontrado: false };
}

